<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Subscribe – City School{% endblock %}</title>
<link rel="stylesheet" href="{{ asset('css/portal.css') }}">
<style>
*,*::before,*::after{box-sizing:border-box}
body{margin:0;background:#f0f6fc;font-family:'Montserrat',sans-serif;color:#14324d}
.sub-shell{min-height:100vh;display:flex;flex-direction:column}
.sub-header{background:linear-gradient(90deg,#0f3a60,#145483);padding:0 28px;display:flex;align-items:center;height:58px;gap:14px}
.sub-logo{display:flex;align-items:center;gap:9px;text-decoration:none}
.sub-logo img{height:34px}
.sub-logo-text{color:#eef8ff;font-size:17px;font-weight:800}
.sub-logo-sub{color:#a5d6f2;font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:1px}
.sub-main{flex:1;display:flex;align-items:flex-start;justify-content:center;padding:36px 16px 60px}
.sub-card{background:#fff;border-radius:18px;box-shadow:0 16px 44px rgba(15,58,96,.12);width:100%;max-width:560px;padding:32px 36px}
.step-tracker{display:flex;gap:0;margin-bottom:28px;border-radius:10px;overflow:hidden;border:1px solid #d6e8f5}
.step-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:10px 6px;background:#f6fbff;border-right:1px solid #d6e8f5;font-size:10px;font-weight:700;text-transform:uppercase;color:#7fa8c5;letter-spacing:.04em;gap:2px}
.step-item:last-child{border-right:0}
.step-item.active{background:#1a7aa3;color:#fff}
.step-item.done{background:#e3f5ed;color:#1a7a4f}
.step-num{font-size:15px;font-weight:900;line-height:1}
.sub-title{margin:0 0 4px;font-size:24px;color:#0f3a60;font-family:'Arvo',serif}
.sub-subtitle{margin:0 0 22px;color:#5c849e;font-size:13px}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#3d6b8a;margin-bottom:5px}
.form-control{width:100%;border:1.5px solid #c8dff0;border-radius:9px;padding:10px 13px;font-size:14px;font-family:inherit;color:#14324d;background:#fafcff;transition:border-color .2s}
.form-control:focus{outline:none;border-color:#1a7aa3;background:#fff}
.form-error{color:#c0392b;font-size:12px;margin-top:4px}
.form-hint{color:#7fa8c5;font-size:11px;margin-top:3px}
.sub-btn{display:inline-block;background:#1a7aa3;color:#fff;border:0;border-radius:10px;padding:12px 28px;font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;cursor:pointer;text-decoration:none;margin-top:4px}
.sub-btn:hover{background:#135b7b}
.sub-btn.outline{background:#fff;color:#1a7aa3;border:2px solid #1a7aa3;margin-right:10px}
.sub-btn.outline:hover{background:#e8f5fb}
.sub-footer{text-align:center;padding:18px 0;color:#8faec3;font-size:12px}
.sub-footer a{color:#1a7aa3;text-decoration:none}
.alert{border-radius:9px;padding:10px 14px;font-size:13px;margin-bottom:16px}
.alert-error{background:#fde8e8;color:#922;border:1px solid #f5c6c6}
.has-error .form-control{border-color:#e74c3c}
</style>
</head>
<body>
<div class="sub-shell">
    <header class="sub-header">
        <a class="sub-logo" href="{{ path('index') }}">
            <img src="{{ asset('images/logo.png') }}" alt="City School">
            <div><div class="sub-logo-text">City School</div><div class="sub-logo-sub">SaaS Platform</div></div>
        </a>
    </header>

    <main class="sub-main">
        <div class="sub-card">
            <nav class="step-tracker" aria-label="Subscription steps">
                <div class="step-item {% if step == 1 %}active{% elseif step > 1 %}done{% endif %}">
                    <span class="step-num">{% if step > 1 %}✓{% else %}1{% endif %}</span>Create Account
                </div>
                <div class="step-item {% if step == 2 %}active{% elseif step > 2 %}done{% endif %}">
                    <span class="step-num">{% if step > 2 %}✓{% else %}2{% endif %}</span>Choose Plan
                </div>
                <div class="step-item {% if step == 3 %}active{% elseif step > 3 %}done{% endif %}">
                    <span class="step-num">{% if step > 3 %}✓{% else %}3{% endif %}</span>School Info
                </div>
                <div class="step-item {% if step == 4 %}active{% endif %}">
                    <span class="step-num">4</span>Payment
                </div>
            </nav>

            {% for message in app.flashes('error') %}
                <div class="alert alert-error">{{ message }}</div>
            {% endfor %}

            {% block content %}{% endblock %}
        </div>
    </main>

    <footer class="sub-footer">
        <p>Already have an account? <a href="{{ path('admin_login') }}">Sign in</a> &nbsp;|&nbsp; <a href="{{ path('pricing') }}">View plans</a> &nbsp;|&nbsp; <a href="{{ path('index') }}">Back to home</a></p>
    </footer>
</div>
</body>
</html>
