{% extends 'subscribe/layout.html.twig' %}
{% block title %}Step 4 – Payment{% endblock %}

{% block content %}
<h2 class="sub-title">{{ summary.mode == 'trial' ? 'Activate your free trial' : 'Review & Pay' }}</h2>
<p class="sub-subtitle">
    {% if summary.mode == 'trial' %}
        Start your 14-day trial now. No card is required today. Premium modules stay limited until you upgrade.
    {% else %}
        Confirm your order details then proceed to secure checkout. A 14-day free trial is included.
    {% endif %}
</p>

<div style="background:#f0f8ff;border:1.5px solid #c2dff0;border-radius:12px;padding:16px 18px;margin-bottom:22px">
    <div style="font-size:12px;font-weight:700;text-transform:uppercase;color:#3d6b8a;letter-spacing:.05em;margin-bottom:10px">Order Summary</div>
    <table style="width:100%;font-size:13px;border-collapse:collapse">
        <tr>
            <td style="padding:5px 0;color:#5c849e">School</td>
            <td style="padding:5px 0;font-weight:700;color:#0f3a60;text-align:right">{{ summary.school_name }}</td>
        </tr>
        <tr>
            <td style="padding:5px 0;color:#5c849e">Admin email</td>
            <td style="padding:5px 0;font-weight:700;color:#0f3a60;text-align:right">{{ summary.email }}</td>
        </tr>
        <tr>
            <td style="padding:5px 0;color:#5c849e">Plan</td>
            <td style="padding:5px 0;font-weight:700;color:#0f3a60;text-align:right">{{ summary.plan }}</td>
        </tr>
        <tr>
            <td style="padding:5px 0;color:#5c849e">Billing</td>
            <td style="padding:5px 0;font-weight:700;color:#0f3a60;text-align:right">{{ summary.cycle|capitalize }}</td>
        </tr>
        <tr>
            <td style="padding:5px 0;color:#5c849e">Location</td>
            <td style="padding:5px 0;font-weight:700;color:#0f3a60;text-align:right">{{ summary.step3.country ?? '' }}, {{ summary.step3.timezone ?? '' }}</td>
        </tr>
        <tr style="border-top:1.5px solid #c2dff0">
            <td style="padding:10px 0 4px;font-weight:800;color:#0f3a60;font-size:15px">{{ summary.mode == 'trial' ? 'Due today' : 'Total due today' }}</td>
            <td style="padding:10px 0 4px;font-weight:900;color:#1a7aa3;font-size:20px;text-align:right">{{ summary.mode == 'trial' ? '$0' : '$' ~ summary.amount }}</td>
        </tr>
    </table>
    <div style="margin-top:6px;font-size:11px;color:#1a7a4f;font-weight:700">
        {% if summary.mode == 'trial' %}
            ✓ Trial ends on {{ summary.trialEndsAt|date('M d, Y') }} · no payment required initially
        {% else %}
            ✓ 14-day free trial included — no charge until trial ends
        {% endif %}
    </div>
</div>

<div style="background:#fff8e8;border:1px solid #f5d87e;border-radius:10px;padding:11px 14px;margin-bottom:22px;font-size:12px;color:#7a5a00;display:flex;align-items:flex-start;gap:8px">
    <span style="font-size:16px">🔒</span>
    <span>
        {% if summary.mode == 'trial' %}
            Your trial unlocks the core workflow now. Premium modules stay limited until you upgrade to a paid plan.
        {% else %}
            Payment is processed securely by <strong>Stripe</strong>. City School never stores your card details.
        {% endif %}
    </span>
</div>

{% if summary.mode == 'trial' %}
    <div style="background:#f7fafc;border:1px solid #d9e6f2;border-radius:12px;padding:14px 16px;margin-bottom:22px;">
        <div style="font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#496b87;margin-bottom:10px">Premium modules locked during trial</div>
        <ul style="margin:0;padding-left:18px;color:#5c849e;font-size:13px;line-height:1.8">
            {% for feature in summary.limitedFeatures %}
                <li>{{ feature }}</li>
            {% endfor %}
        </ul>
    </div>
{% endif %}

<form method="post" action="{{ path('subscribe_step4') }}">
    <div style="display:flex;gap:10px;margin-top:4px">
        <a href="{{ path('subscribe_step3') }}" class="sub-btn outline">← Back</a>
        <button type="submit" class="sub-btn" style="flex:1;display:flex;align-items:center;justify-content:center;gap:8px">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            {{ summary.mode == 'trial' ? 'Activate Free Trial' : 'Subscribe & Start Free Trial' }}
        </button>
    </div>
</form>
{% endblock %}
