{% extends 'parent/base.html.twig' %}
{% block title %}Progress Reports{% endblock %}
{% block page_title %}Progress Reports{% endblock %}

{% block content %}

{# ── Child Tabs ──────────────────────────────────────────────────── #}
<div class="child-tabs">
    {% for child in children %}
    <a href="?child={{ child.id }}" class="child-tab {{ (app.request.query.get('child', children|first.id) == child.id) ? 'active' : '' }}">
        <div class="child-av">{{ child.avatar }}</div>
        {{ child.name }}
    </a>
    {% endfor %}
</div>

{% set activeId = app.request.query.get('child', children|first.id)|number_format %}
{% for child in children %}
{% if child.id == activeId %}
{% set childGrades = grades|filter(g => g.child == child.id) %}
{% set totalScore  = childGrades|map(g => g.score)|reduce((c,v) => c+v, 0) %}
{% set avgScore    = childGrades|length > 0 ? (totalScore / childGrades|length)|round : 0 %}

{# ── Monthly Report Banner ────────────────────────────────────────── #}
<div style="background:linear-gradient(135deg,#052e16 0%,#16a34a 100%);border-radius:14px;padding:24px 28px;color:#fff;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;">
    <div>
        <div style="font-size:12px;opacity:.7;margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em;"><i class="fa fa-calendar"></i> Monthly Progress Report — April 2026</div>
        <div style="font-size:22px;font-weight:900;margin-bottom:2px;">{{ child.name }}</div>
        <div style="font-size:13px;opacity:.85;">{{ child.class }} &nbsp;·&nbsp; Class Teacher: {{ child.teacher }}</div>
    </div>
    <div style="display:flex;gap:24px;flex-wrap:wrap;">
        <div style="text-align:center;">
            <div style="font-size:32px;font-weight:900;">{{ avgScore }}%</div>
            <div style="font-size:11px;opacity:.7;">Overall Average</div>
        </div>
        <div style="text-align:center;">
            <div style="font-size:32px;font-weight:900;">{{ child.attendance }}%</div>
            <div style="font-size:11px;opacity:.7;">Attendance</div>
        </div>
        <div style="text-align:center;">
            <div style="font-size:32px;font-weight:900;">{{ childGrades|length }}</div>
            <div style="font-size:11px;opacity:.7;">Subjects</div>
        </div>
    </div>
    <button class="btn-green" style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);" onclick="alert('Downloading PDF report…')"><i class="fa fa-download"></i> Download PDF</button>
</div>

<div class="grid-2" style="gap:20px;">
    {# ── Weekly Score Cards ───────────────────────────────────────── #}
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-calendar p-accent" style="margin-right:6px;"></i>Weekly Scores — April 2026</span></div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:6px;">
            {% set weeks = [['Week 1',75],['Week 2',80],['Week 3', avgScore - 2],['Week 4', avgScore]] %}
            {% for w in weeks %}
            <div class="week-card">
                <div class="wc-grade">{{ w[1] }}</div>
                <div class="wc-label">{{ w[0] }}</div>
            </div>
            {% endfor %}
        </div>
        <div style="margin-top:14px;">
            <div style="font-size:12px;color:#64748b;margin-bottom:6px;font-weight:700;">Monthly Trend</div>
            <div class="progress-bar-wrap" style="height:10px;">
                <div class="progress-bar-fill" style="width:{{ avgScore }}%;background:#16a34a;border-radius:8px;height:10px;"></div>
            </div>
            <div style="font-size:11px;color:#16a34a;margin-top:4px;font-weight:700;">↑ +4.2 points from March</div>
        </div>
    </div>

    {# ── Grade Breakdown ──────────────────────────────────────────── #}
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-star p-accent" style="margin-right:6px;"></i>Subject Grades</span></div>
        {% for g in childGrades %}
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
            <div style="width:6px;height:20px;border-radius:2px;background:{{ g.color }};flex-shrink:0;"></div>
            <div style="flex:1;font-size:13px;font-weight:600;">{{ g.subject }}</div>
            <div class="progress-bar-wrap" style="flex:2;">
                <div class="progress-bar-fill" style="width:{{ g.score }}%;background:{{ g.color }};"></div>
            </div>
            <span class="grade-pill grade-{{ g.grade|slice(0,1) }}" style="font-size:11px;min-width:36px;text-align:center;">{{ g.grade }}</span>
        </div>
        {% endfor %}
    </div>
</div>

{# ── Teacher Comments ─────────────────────────────────────────────── #}
<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-comments p-accent" style="margin-right:6px;"></i>Teacher Comments</span></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px;">
        {% set comments = [
            ['Mr. Smith','Mathematics','MS','Emma shows strong problem-solving ability. Focus on algebraic expressions next term.','#7c3aed'],
            ['Dr. Patel','Science','DP','Excellent lab work! Consistently top of the class in practical assessments.','#0891b2'],
            ['Ms. Brown','English','MB','Writing has improved significantly. Encourage more reading at home.','#f59e0b'],
        ] %}
        {% for c in comments %}
        <div style="padding:14px;background:#f0fdf4;border-radius:10px;border-left:3px solid {{ c[4] }};">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                <div class="av-init" style="width:28px;height:28px;font-size:10px;background:#dcfce7;color:#16a34a;">{{ c[2] }}</div>
                <div>
                    <div style="font-size:13px;font-weight:800;">{{ c[0] }}</div>
                    <div style="font-size:11px;color:#64748b;">{{ c[1] }}</div>
                </div>
            </div>
            <div style="font-size:13px;color:#475569;line-height:1.5;">{{ c[3] }}</div>
        </div>
        {% endfor %}
    </div>
</div>

{# ── Previous Reports ─────────────────────────────────────────────── #}
<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-history p-accent" style="margin-right:6px;"></i>Previous Reports</span></div>
    {% set reports = [['March 2026',78,'93%'],['February 2026',75,'90%'],['January 2026',72,'88%'],['December 2025',70,'91%']] %}
    <table class="portal-table">
        <thead><tr><th>Period</th><th>Average Score</th><th>Attendance</th><th>Download</th></tr></thead>
        <tbody>
        {% for r in reports %}
        <tr>
            <td style="font-weight:700;">{{ r[0] }}</td>
            <td><span style="font-weight:900;color:#16a34a;">{{ r[1] }}%</span></td>
            <td><span style="font-weight:900;color:#0891b2;">{{ r[2] }}</span></td>
            <td><button class="btn-green" style="font-size:11px;padding:4px 12px;" onclick="alert('Downloading {{ r[0] }} report…')"><i class="fa fa-download"></i> PDF</button></td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endif %}
{% endfor %}
{% endblock %}
