{% extends 'parent/base.html.twig' %}
{% block title %}My Profile{% endblock %}
{% block page_title %}My Profile{% endblock %}

{% block content %}
<div class="grid-2" style="gap:20px;">

    {# ── Profile Card ────────────────────────────────────────────── #}
    <div class="card" style="text-align:center;">
        <div style="position:relative;display:inline-block;margin-bottom:16px;">
            <div class="av-init" style="width:80px;height:80px;font-size:28px;background:#dcfce7;color:#16a34a;border:4px solid #16a34a;">SJ</div>
            <button onclick="alert('Photo upload coming soon!')" style="position:absolute;bottom:0;right:0;width:26px;height:26px;border-radius:50%;background:#16a34a;border:none;color:#fff;cursor:pointer;font-size:11px;">
                <i class="fa fa-camera"></i>
            </button>
        </div>
        <div style="font-size:20px;font-weight:800;">{{ parent.name }}</div>
        <div style="font-size:13px;color:#16a34a;font-weight:700;margin-bottom:2px;">Parent / Guardian</div>
        <div style="font-size:12px;color:#64748b;margin-bottom:16px;">Member since {{ parent.joined }}</div>

        <div style="display:flex;justify-content:space-around;padding:12px 0;border-top:1px solid #dcfce7;border-bottom:1px solid #dcfce7;margin-bottom:16px;">
            <div><div style="font-size:18px;font-weight:900;color:#16a34a;">{{ children|length }}</div><div style="font-size:11px;color:#64748b;">Children</div></div>
            <div><div style="font-size:18px;font-weight:900;color:#0891b2;">8</div><div style="font-size:11px;color:#64748b;">Messages</div></div>
            <div><div style="font-size:18px;font-weight:900;color:#f59e0b;">3</div><div style="font-size:11px;color:#64748b;">Alerts</div></div>
        </div>

        <div style="text-align:left;font-size:13px;color:#475569;">
            <div style="padding:6px 0;border-bottom:1px solid #f0fdf4;"><i class="fa fa-envelope-o p-accent" style="width:18px;margin-right:6px;"></i>{{ parent.email }}</div>
            <div style="padding:6px 0;border-bottom:1px solid #f0fdf4;"><i class="fa fa-phone p-accent" style="width:18px;margin-right:6px;"></i>{{ parent.phone }}</div>
            <div style="padding:6px 0;border-bottom:1px solid #f0fdf4;"><i class="fa fa-clock-o p-accent" style="width:18px;margin-right:6px;"></i>Last login: {{ parent.lastLogin }}</div>
        </div>

        {# ── Enrolled Children ──────────────────────────────── #}
        <div style="margin-top:14px;padding:12px;background:#f0fdf4;border-radius:8px;text-align:left;">
            <div style="font-size:11px;font-weight:700;color:#16a34a;margin-bottom:8px;"><i class="fa fa-child"></i> ENROLLED CHILDREN</div>
            {% for child in children %}
            <div style="display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid #dcfce7;">
                <div class="av-init" style="width:28px;height:28px;font-size:10px;background:#dcfce7;color:#16a34a;">{{ child.avatar }}</div>
                <div>
                    <div style="font-size:13px;font-weight:700;">{{ child.name }}</div>
                    <div style="font-size:11px;color:#64748b;">{{ child.class }}</div>
                </div>
                <span class="role-badge p-status-active" style="margin-left:auto;font-size:10px;">Active</span>
            </div>
            {% endfor %}
        </div>
    </div>

    {# ── Edit Form ────────────────────────────────────────────────── #}
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-edit p-accent" style="margin-right:6px;"></i>Edit Profile</span></div>
        <form method="post" action="{{ path('parent_profile') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('parent_profile_update') }}">
            <div class="grid-2" style="gap:14px;">
                <div class="form-group"><label class="form-label">First Name</label><input type="text" class="form-control" value="Sarah" name="first_name"></div>
                <div class="form-group"><label class="form-label">Last Name</label><input type="text" class="form-control" value="Jones" name="last_name"></div>
            </div>
            <div class="form-group"><label class="form-label">Email</label><input type="email" class="form-control" value="{{ parent.email }}" name="email"></div>
            <div class="form-group"><label class="form-label">Phone</label><input type="tel" class="form-control" value="{{ parent.phone }}" name="phone"></div>
            <div class="form-group"><label class="form-label">Relationship to Student</label>
                <select class="form-control" name="relationship">
                    <option selected>Mother</option><option>Father</option><option>Guardian</option><option>Other</option>
                </select>
            </div>
            <div class="form-group"><label class="form-label">Preferred Notification</label>
                <select class="form-control" name="notif_pref">
                    <option>Email &amp; SMS</option><option>Email only</option><option>SMS only</option><option>Portal only</option>
                </select>
            </div>

            <div style="padding-top:14px;border-top:1px solid #dcfce7;margin-bottom:14px;">
                <div style="font-size:14px;font-weight:800;margin-bottom:12px;color:#ef4444;"><i class="fa fa-lock" style="margin-right:6px;"></i>Change Password</div>
                <div class="form-group"><label class="form-label">Current Password</label><input type="password" class="form-control" name="current_password" placeholder="Current password"></div>
                <div class="grid-2" style="gap:14px;">
                    <div class="form-group"><label class="form-label">New Password</label><input type="password" class="form-control" name="new_password" placeholder="Min 8 characters"></div>
                    <div class="form-group"><label class="form-label">Confirm</label><input type="password" class="form-control" name="confirm_password"></div>
                </div>
            </div>

            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn-green"><i class="fa fa-save"></i> Save Changes</button>
                <a href="{{ path('parent_dashboard') }}" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
