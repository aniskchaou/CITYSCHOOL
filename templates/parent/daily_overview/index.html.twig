{% extends 'parent/base.html.twig' %}
{% block title %}Daily Overview{% endblock %}
{% block page_title %}Parent Dashboard - Daily Overview{% endblock %}

{% block content %}
<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-calendar"></i></div>
        <div class="stat-body"><div class="stat-value">{{ upcomingClasses|length }}</div><div class="stat-label">Upcoming Classes</div></div>
    </div>
    <div class="stat-card amber">
        <div class="stat-icon" style="background:#fef9c3;color:#b45309;"><i class="fa fa-tasks"></i></div>
        <div class="stat-body"><div class="stat-value">{{ homeworkDue|length }}</div><div class="stat-label">Homework Due</div></div>
    </div>
    <div class="stat-card blue">
        <div class="stat-icon" style="background:#e0f2fe;color:#0891b2;"><i class="fa fa-bullhorn"></i></div>
        <div class="stat-body"><div class="stat-value">{{ announcements|length }}</div><div class="stat-label">Announcements</div></div>
    </div>
    <div class="stat-card red">
        <div class="stat-icon" style="background:#fee2e2;color:#ef4444;"><i class="fa fa-exclamation-circle"></i></div>
        <div class="stat-body"><div class="stat-value">{{ alerts|length }}</div><div class="stat-label">Active Alerts</div></div>
    </div>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-clock-o p-accent" style="margin-right:6px;"></i>Upcoming Classes</span>
            <form method="post" action="{{ path('parent_daily_overview') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('parent_daily_open_classes') }}">
                <input type="hidden" name="action" value="open_classes">
                <button class="btn btn-outline btn-sm" type="submit">Open</button>
            </form>
        </div>
        {% for item in upcomingClasses %}
        <div style="display:flex;justify-content:space-between;gap:8px;padding:10px 0;border-bottom:1px solid #f0fdf4;">
            <div>
                <div style="font-size:13px;font-weight:800;">{{ item.time }} - {{ item.subject }}</div>
                <div style="font-size:12px;color:#64748b;">{{ item.teacher }} · {{ item.room }}</div>
            </div>
            <span style="font-size:11px;color:#16a34a;font-weight:700;">{{ item.child }}</span>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-pencil-square-o p-accent" style="margin-right:6px;"></i>Homework Due</span>
            <form method="post" action="{{ path('parent_daily_overview') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('parent_daily_review_homework') }}">
                <input type="hidden" name="action" value="review_homework">
                <button class="btn btn-outline btn-sm" type="submit">Review</button>
            </form>
        </div>
        {% for hw in homeworkDue %}
        <div style="padding:10px;border:1px solid #dcfce7;border-radius:8px;margin-bottom:8px;">
            <div style="display:flex;justify-content:space-between;gap:8px;align-items:center;">
                <div style="font-size:13px;font-weight:800;">{{ hw.title }}</div>
                <span class="role-badge {{ hw.priority == 'high' ? 'p-status-blocked' : 'p-status-pending' }}" style="font-size:10px;">{{ hw.priority|upper }}</span>
            </div>
            <div style="font-size:12px;color:#64748b;margin-top:4px;">{{ hw.subject }} · {{ hw.child }}</div>
            <div style="font-size:11px;color:#94a3b8;margin-top:3px;">Due: {{ hw.due }}</div>
        </div>
        {% endfor %}
    </div>
</div>

<div class="grid-2" style="gap:20px;margin-top:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-bullhorn p-accent" style="margin-right:6px;"></i>Announcements & Alerts</span>
            <div style="display:flex;gap:6px;">
                <form method="post" action="{{ path('parent_daily_overview') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('parent_daily_announcements') }}">
                    <input type="hidden" name="action" value="view_announcements">
                    <button class="btn btn-outline btn-sm" type="submit">Announcements</button>
                </form>
                <form method="post" action="{{ path('parent_daily_overview') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('parent_daily_alerts') }}">
                    <input type="hidden" name="action" value="resolve_alerts">
                    <button class="btn btn-outline btn-sm" type="submit">Alerts</button>
                </form>
            </div>
        </div>

        <div style="margin-bottom:12px;">
            {% for alert in alerts %}
            <div style="padding:10px;background:#fff7ed;border-left:4px solid {{ alert.severity == 'high' ? '#ef4444' : '#f59e0b' }};border-radius:6px;margin-bottom:8px;">
                <div style="font-size:13px;font-weight:800;color:#1f2937;">{{ alert.title }}</div>
                <div style="font-size:12px;color:#64748b;margin-top:3px;">{{ alert.detail }}</div>
                <div style="font-size:11px;color:#475569;margin-top:3px;">Child: {{ alert.child }}</div>
            </div>
            {% endfor %}
        </div>

        {% for ann in announcements|slice(0, 3) %}
        <div style="padding:8px 0;border-top:1px solid #f0fdf4;">
            <div style="font-size:13px;font-weight:700;">{{ ann.title }}</div>
            <div style="font-size:12px;color:#64748b;">{{ ann.body|slice(0, 85) }}{% if ann.body|length > 85 %}...{% endif %}</div>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-bolt p-accent" style="margin-right:6px;"></i>Quick Access</span>
            <form method="post" action="{{ path('parent_daily_overview') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('parent_daily_quick_access') }}">
                <input type="hidden" name="action" value="open_quick_access">
                <button class="btn btn-outline btn-sm" type="submit">Refresh</button>
            </form>
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
            <a href="{{ path('parent_grades') }}" class="btn-green"><i class="fa fa-star"></i> Grades</a>
            <a href="{{ path('parent_attendance') }}" class="btn-green"><i class="fa fa-calendar-check-o"></i> Attendance</a>
            <a href="{{ path('parent_notifications') }}" class="btn-green"><i class="fa fa-bell"></i> Notifications</a>
            <a href="{{ path('parent_messages') }}" class="btn-green"><i class="fa fa-comments"></i> Teachers</a>
            <a href="{{ path('parent_payments') }}" class="btn-green"><i class="fa fa-credit-card"></i> Payments</a>
        </div>

        <hr style="margin:14px 0;border:none;border-top:1px solid #dcfce7;">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
            <div style="font-size:13px;font-weight:800;"><i class="fa fa-diamond p-accent" style="margin-right:4px;"></i>Premium: Today's Insights</div>
            <form method="post" action="{{ path('parent_daily_overview') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('parent_daily_insights') }}">
                <input type="hidden" name="action" value="refresh_insights">
                <button class="btn btn-outline btn-sm" type="submit">Regenerate</button>
            </form>
        </div>
        <div style="padding:10px;background:#f8fafc;border-radius:8px;font-size:12px;color:#334155;line-height:1.5;">{{ todayInsights.summary }}</div>
        <ul style="margin:10px 0 0 18px;padding:0;color:#475569;font-size:12px;">
            {% for insight in todayInsights.highlights %}
            <li style="margin-bottom:5px;">{{ insight }}</li>
            {% endfor %}
        </ul>

        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:14px;margin-bottom:8px;">
            <div style="font-size:13px;font-weight:800;"><i class="fa fa-exclamation-triangle" style="color:#ef4444;margin-right:4px;"></i>Premium: Priority Alerts</div>
            <form method="post" action="{{ path('parent_daily_overview') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('parent_daily_priority') }}">
                <input type="hidden" name="action" value="focus_priority_alerts">
                <button class="btn btn-outline btn-sm" type="submit">Focus Mode</button>
            </form>
        </div>

        {% for item in priorityAlerts %}
        <div style="padding:9px;border:1px solid #fee2e2;border-radius:8px;background:#fff1f2;margin-bottom:7px;">
            <div style="font-size:12px;font-weight:800;color:#991b1b;">{{ item.label }}</div>
            <div style="font-size:12px;color:#374151;margin-top:2px;">{{ item.message }}</div>
            <div style="font-size:11px;color:#7f1d1d;margin-top:2px;">Impact: {{ item.impact }} · {{ item.child }}</div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
