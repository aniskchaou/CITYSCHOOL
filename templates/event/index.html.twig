<script>
/* ===== RSVP ===== */
var _rsvpTarget = null;
function rsvpEvent(btn, eventId) {
    _rsvpTarget = btn;
    var panel = document.getElementById('rsvpPanel');
    var nameEl = document.getElementById('rsvpEventName');
    nameEl.textContent = btn.closest('.event-row').querySelector('h3').textContent;
    document.getElementById('rsvpConfirm').style.display = 'none';
    panel.classList.add('open');
    panel.scrollIntoView({behavior:'smooth', block:'nearest'});
}
function confirmRsvp() {
    var name  = document.getElementById('rsvpName').value.trim();
    var email = document.getElementById('rsvpEmail').value.trim();
    if(!name || !email) { alert('Please enter your name and email.'); return; }
    document.getElementById('rsvpConfirm').style.display = 'block';
    if(_rsvpTarget) {
        _rsvpTarget.innerHTML = '<i class="fa fa-check"></i> RSVP\'d';
        _rsvpTarget.classList.add('rsvpd');
        _rsvpTarget.disabled = true;
    }
}

/* ===== EVENT LIST FILTER ===== */
function filterEvents(btn) {
    document.querySelectorAll('[data-ef]').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    var cat = btn.getAttribute('data-ef');
    document.querySelectorAll('#eventsList .event-row').forEach(function(row){
        row.style.display = (cat === 'all' || row.getAttribute('data-cat') === cat) ? '' : 'none';
    });
}

/* ===== PUSH NOTIFICATIONS ===== */
function pushNotice(btn) {
    btn.innerHTML = '<i class="fa fa-bell"></i> Notifying…';
    btn.classList.add('pushed');
    btn.disabled = true;
    setTimeout(function(){ btn.innerHTML = '<i class="fa fa-check"></i> Saved'; }, 900);
}
function requestPush(e) {
    e.preventDefault();
    if('Notification' in window) {
        Notification.requestPermission().then(function(p){
            if(p === 'granted') { new Notification('City School', {body:'Push notifications enabled!'}); }
        });
    }
}

/* ===== ACADEMIC CALENDAR ===== */
var calYear = 2026, calMonth = 4; /* May = index 4 */
var calCatFilter = 'all';
var calEvents = [
    {y:2026,m:4,d:2,  label:'Today',         cat:'event'},
    {y:2026,m:4,d:20, label:'Arts Showcase',  cat:'event'},
    {y:2026,m:4,d:26, label:'Exams Begin',    cat:'exam'},
    {y:2026,m:4,d:26, label:'Mid-Year Exams', cat:'exam'},
    {y:2026,m:4,d:31, label:'Open Day',       cat:'event'},
    {y:2026,m:5,d:6,  label:'Exams End',      cat:'exam'},
    {y:2026,m:5,d:10, label:'National Day',   cat:'holiday'},
    {y:2026,m:5,d:18, label:'STEM Fair',      cat:'event'},
    {y:2026,m:5,d:25, label:'Graduation',     cat:'event'},
    {y:2026,m:6,d:4,  label:'Term 2 Starts',  cat:'event'},
    {y:2026,m:7,d:15, label:'Sept Deadline',  cat:'exam'},
    {y:2026,m:8,d:1,  label:'Term 3 Starts',  cat:'event'},
];
var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function renderCal() {
    document.getElementById('calLabel').textContent = monthNames[calMonth] + ' ' + calYear;
    var grid = document.getElementById('calGrid');
    /* remove old day cells (keep 7 header cells) */
    while(grid.children.length > 7) grid.removeChild(grid.lastChild);
    var firstDay = new Date(calYear, calMonth, 1).getDay();
    var daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
    var today = new Date();
    /* leading blanks */
    for(var i = 0; i < firstDay; i++) {
        var blank = document.createElement('div');
        blank.className = 'cal-cell other-month';
        grid.appendChild(blank);
    }
    for(var d = 1; d <= daysInMonth; d++) {
        var cell = document.createElement('div');
        cell.className = 'cal-cell';
        if(today.getFullYear()===calYear && today.getMonth()===calMonth && today.getDate()===d) cell.classList.add('today');
        var dayEl = document.createElement('div');
        dayEl.className = 'cal-day-num';
        dayEl.textContent = d;
        cell.appendChild(dayEl);
        calEvents.forEach(function(ev){
            if(ev.y===calYear && ev.m===calMonth && ev.d===d) {
                if(calCatFilter==='all' || calCatFilter===ev.cat){
                    var dot = document.createElement('div');
                    dot.className = 'cal-event-dot ' + ev.cat;
                    dot.textContent = ev.label;
                    cell.appendChild(dot);
                }
            }
        });
        grid.appendChild(cell);
    }
}
function calPrev() { calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCal(); }
function calNext() { calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCal(); }
function calFilter(btn) {
    document.querySelectorAll('[data-cf]').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    calCatFilter = btn.getAttribute('data-cf');
    renderCal();
}
renderCal();
</script>

{% endblock %}
