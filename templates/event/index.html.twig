{% extends 'base.html.twig' %}

{% block title %}Events &amp; News | City School{% endblock %}

{% block stylesheets %}
<style>
/* ===== EVENTS PAGE ===== */
.ev-section      { padding:60px 0; }
.ev-section-alt  { padding:60px 0; background:#f7f9fc; }
.ev-section-dark { padding:60px 0; background:linear-gradient(135deg,#1a237e 0%,#283593 100%); color:#fff; }
.ev-label { display:inline-block; background:#1a237e; color:#fff; font-size:.68rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase; padding:4px 14px; border-radius:20px; margin-bottom:12px; }
.ev-label-light { background:rgba(255,255,255,.2); }
.ev-title { font-family:'Arvo',serif; font-size:1.9rem; font-weight:700; color:#1a237e; margin:0 0 8px; }
.ev-title-light { color:#fff; }
.ev-sub { color:#6b7a99; font-size:.97rem; margin:0 0 32px; max-width:600px; }
.ev-sub-light { color:rgba(255,255,255,.78); }

/* quick action bar */
.ev-actions-bar { background:linear-gradient(135deg,#1a237e 0%,#283593 60%,#3949ab 100%); padding:40px 0 34px; }
.ev-actions-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:18px; }
@media(max-width:900px){ .ev-actions-grid { grid-template-columns:repeat(2,1fr); } }
@media(max-width:500px){ .ev-actions-grid { grid-template-columns:1fr 1fr; } }
.ev-action-card { background:rgba(255,255,255,.1); border:1.5px solid rgba(255,255,255,.18); border-radius:14px; padding:24px 18px; text-align:center; color:#fff; text-decoration:none; transition:background .2s,transform .2s; display:block; }
.ev-action-card:hover { background:rgba(255,255,255,.2); transform:translateY(-4px); color:#fff; text-decoration:none; }
.ev-action-icon { width:48px; height:48px; background:rgba(255,255,255,.15); border-radius:11px; display:flex; align-items:center; justify-content:center; margin:0 auto 12px; font-size:1.3rem; }
.ev-action-card h4 { font-family:'Arvo',serif; font-size:.95rem; margin:0 0 5px; }
.ev-action-card p { font-size:.76rem; opacity:.82; margin:0; line-height:1.5; }

/* split layout */
.ev-split { display:grid; grid-template-columns:2fr 1fr; gap:26px; }
@media(max-width:900px){ .ev-split { grid-template-columns:1fr; } }
.ev-sidebar { display:flex; flex-direction:column; gap:18px; }
.ev-widget { background:#fff; border-radius:14px; padding:22px 20px; box-shadow:0 3px 18px rgba(26,35,126,.07); }
.ev-widget h4 { font-family:'Arvo',serif; font-size:1rem; color:#1a237e; margin:0 0 14px; border-bottom:2px solid #e8eaf6; padding-bottom:10px; }

/* news cards */
.news-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
@media(max-width:900px){ .news-grid { grid-template-columns:repeat(2,1fr); } }
@media(max-width:540px){ .news-grid { grid-template-columns:1fr; } }
.news-card { background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 4px 20px rgba(26,35,126,.08); transition:transform .2s,box-shadow .2s; }
.news-card:hover { transform:translateY(-5px); box-shadow:0 12px 32px rgba(26,35,126,.13); }
.news-card-img { height:140px; background:linear-gradient(135deg,#1a237e,#3949ab); display:flex; align-items:center; justify-content:center; font-size:2.5rem; color:rgba(255,255,255,.4); }
.news-card-body { padding:18px; }
.news-cat { display:inline-block; font-size:.66rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; padding:2px 10px; border-radius:20px; margin-bottom:8px; }
.news-cat.event    { background:#e8eaf6; color:#1a237e; }
.news-cat.holiday  { background:#e8f5e9; color:#2e7d32; }
.news-cat.exam     { background:#fff9c4; color:#f57f17; }
.news-cat.announce { background:#fce4ec; color:#c62828; }
.news-card h3 { font-family:'Arvo',serif; font-size:.97rem; color:#1a237e; margin:0 0 6px; line-height:1.4; }
.news-card p  { font-size:.8rem; color:#6b7a99; margin:0 0 12px; line-height:1.6; }
.news-meta { display:flex; gap:10px; font-size:.73rem; color:#9fa8da; flex-wrap:wrap; }
.news-meta span { display:flex; align-items:center; gap:4px; }

/* announcements */
.announce-list { display:flex; flex-direction:column; gap:14px; }
.announce-item { background:#fff; border-radius:12px; padding:18px 20px; box-shadow:0 3px 14px rgba(26,35,126,.07); display:flex; gap:16px; align-items:flex-start; border-left:4px solid #1a237e; transition:transform .18s; }
.announce-item:hover { transform:translateX(4px); }
.announce-item.urgent  { border-left-color:#c62828; }
.announce-item.exam    { border-left-color:#f57f17; }
.announce-item.holiday { border-left-color:#2e7d32; }
.announce-dot { width:38px; height:38px; border-radius:10px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:1rem; }
.announce-item .announce-dot        { background:#e8eaf6; color:#1a237e; }
.announce-item.urgent .announce-dot  { background:#ffebee; color:#c62828; }
.announce-item.exam .announce-dot    { background:#fff9c4; color:#f57f17; }
.announce-item.holiday .announce-dot { background:#e8f5e9; color:#2e7d32; }
.announce-info h4 { font-family:'Arvo',serif; font-size:.95rem; color:#1a237e; margin:0 0 4px; }
.announce-info p  { font-size:.82rem; color:#6b7a99; margin:0 0 6px; line-height:1.5; }
.announce-meta { display:flex; gap:10px; font-size:.72rem; color:#9fa8da; flex-wrap:wrap; }
.announce-meta span { display:flex; align-items:center; gap:4px; }
.push-badge { display:inline-flex; align-items:center; gap:5px; background:#e8eaf6; color:#1a237e; font-size:.68rem; font-weight:800; padding:2px 10px; border-radius:20px; margin-left:auto; flex-shrink:0; cursor:pointer; border:none; transition:background .2s; }
.push-badge:hover { background:#c5cae9; }
.push-badge.pushed { background:#e8f5e9; color:#2e7d32; }

/* calendar */
.cal-toolbar { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:20px; align-items:center; }
.cal-nav { display:flex; align-items:center; gap:10px; margin-right:auto; }
.cal-nav button { background:#f0f2fc; border:1.5px solid #c5cae9; color:#1a237e; padding:6px 14px; border-radius:8px; cursor:pointer; font-family:'Montserrat',sans-serif; font-weight:700; font-size:.82rem; transition:background .18s; }
.cal-nav button:hover { background:#e8eaf6; }
.cal-month-label { font-family:'Arvo',serif; font-size:1.05rem; color:#1a237e; font-weight:700; min-width:160px; text-align:center; }
.cal-filter-btn { padding:6px 14px; border-radius:20px; border:1.5px solid #dde3f0; background:#fff; color:#555; font-size:.76rem; font-weight:600; cursor:pointer; transition:background .18s,color .18s,border-color .18s; font-family:'Montserrat',sans-serif; }
.cal-filter-btn:hover  { border-color:#3949ab; color:#3949ab; }
.cal-filter-btn.active { background:#1a237e; color:#fff; border-color:#1a237e; }
.cal-export-btn { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid #c5cae9; color:#1a237e; padding:7px 14px; border-radius:8px; font-size:.78rem; font-weight:700; cursor:pointer; font-family:'Montserrat',sans-serif; text-decoration:none; transition:background .18s; }
.cal-export-btn:hover { background:#f0f2fc; color:#1a237e; text-decoration:none; }
.cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; }
.cal-head { text-align:center; font-size:.7rem; font-weight:800; color:#8a97b5; text-transform:uppercase; padding:6px 0; }
.cal-cell { min-height:82px; background:#fff; border-radius:8px; padding:6px; border:1.5px solid #e8eaf6; font-size:.78rem; transition:border-color .18s; }
.cal-cell.today { border-color:#1a237e; background:#f0f2fc; }
.cal-cell.other-month { background:#fafafa; opacity:.6; }
.cal-cell:hover { border-color:#9fa8da; }
.cal-day-num { font-weight:700; color:#1a237e; margin-bottom:4px; font-size:.82rem; }
.cal-cell.today .cal-day-num { background:#1a237e; color:#fff; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:.74rem; }
.cal-event-dot { font-size:.67rem; border-radius:4px; padding:1px 5px; margin-bottom:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; cursor:pointer; }
.cal-event-dot.event   { background:#e8eaf6; color:#1a237e; }
.cal-event-dot.exam    { background:#fff9c4; color:#e65100; }
.cal-event-dot.holiday { background:#e8f5e9; color:#2e7d32; }
@media(max-width:700px){ .cal-cell { min-height:52px; } .cal-event-dot { display:none; } }

/* rsvp modal */
.rsvp-panel { background:#fff; border-radius:14px; padding:26px 24px; box-shadow:0 6px 28px rgba(26,35,126,.12); border:2px solid #e8eaf6; margin-top:22px; display:none; }
.rsvp-panel.open { display:block; }
.rsvp-panel h4 { font-family:'Arvo',serif; font-size:1.05rem; color:#1a237e; margin:0 0 14px; }
.rsvp-form { display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end; }
.rsvp-form input, .rsvp-form select { flex:1 1 180px; padding:9px 13px; border:1.5px solid #dde3f0; border-radius:8px; font-family:'Montserrat',sans-serif; font-size:.87rem; color:#333; }
.rsvp-form input:focus, .rsvp-form select:focus { outline:none; border-color:#3949ab; }
.rsvp-btn { background:linear-gradient(135deg,#1a237e,#3949ab); color:#fff; border:none; padding:10px 22px; border-radius:8px; font-weight:700; font-size:.87rem; cursor:pointer; font-family:'Montserrat',sans-serif; white-space:nowrap; transition:opacity .2s; }
.rsvp-btn:hover { opacity:.85; }
.rsvp-confirm { background:#e8f5e9; border:1.5px solid #a5d6a7; border-radius:8px; padding:10px 16px; font-size:.85rem; color:#2e7d32; display:none; margin-top:10px; }

/* upcoming events list */
.events-list { display:flex; flex-direction:column; gap:16px; }
.event-row { background:#fff; border-radius:14px; padding:20px 22px; box-shadow:0 3px 18px rgba(26,35,126,.08); display:flex; gap:18px; align-items:flex-start; border-left:4px solid #1a237e; transition:transform .18s,box-shadow .18s; }
.event-row:hover { transform:translateY(-3px); box-shadow:0 8px 26px rgba(26,35,126,.12); }
.event-row.exam    { border-left-color:#f57f17; }
.event-row.holiday { border-left-color:#2e7d32; }
.event-date-box { min-width:56px; text-align:center; background:linear-gradient(135deg,#1a237e,#3949ab); border-radius:10px; padding:8px 6px; color:#fff; flex-shrink:0; }
.event-row.exam    .event-date-box { background:linear-gradient(135deg,#e65100,#ffa000); }
.event-row.holiday .event-date-box { background:linear-gradient(135deg,#2e7d32,#43a047); }
.event-date-box .edb-day  { font-size:1.5rem; font-weight:800; font-family:'Arvo',serif; line-height:1; }
.event-date-box .edb-mon  { font-size:.65rem; text-transform:uppercase; font-weight:700; letter-spacing:.08em; opacity:.88; }
.event-info { flex:1; }
.event-info h3 { font-family:'Arvo',serif; font-size:1rem; color:#1a237e; margin:0 0 5px; }
.event-info p  { font-size:.82rem; color:#6b7a99; margin:0 0 10px; line-height:1.5; }
.event-meta { display:flex; gap:12px; flex-wrap:wrap; font-size:.74rem; color:#8a97b5; margin-bottom:10px; }
.event-meta span { display:flex; align-items:center; gap:4px; }
.event-actions { display:flex; gap:8px; flex-wrap:wrap; }
.btn-rsvp   { background:linear-gradient(135deg,#1a237e,#3949ab); color:#fff; border:none; padding:7px 16px; border-radius:8px; font-size:.76rem; font-weight:700; cursor:pointer; font-family:'Montserrat',sans-serif; display:inline-flex; align-items:center; gap:5px; transition:opacity .2s; }
.btn-rsvp:hover { opacity:.85; }
.btn-rsvp.rsvpd { background:linear-gradient(135deg,#2e7d32,#43a047); }
.btn-read   { background:#f0f2fc; color:#1a237e; border:1.5px solid #c5cae9; padding:7px 14px; border-radius:8px; font-size:.76rem; font-weight:700; cursor:pointer; font-family:'Montserrat',sans-serif; display:inline-flex; align-items:center; gap:5px; transition:background .2s; }
.btn-read:hover { background:#e8eaf6; }
.ev-cat-badge { display:inline-block; font-size:.66rem; font-weight:800; text-transform:uppercase; letter-spacing:.08em; padding:2px 10px; border-radius:20px; }
.ev-cat-badge.event   { background:#e8eaf6; color:#1a237e; }
.ev-cat-badge.exam    { background:#fff9c4; color:#e65100; }
.ev-cat-badge.holiday { background:#e8f5e9; color:#2e7d32; }

/* sidebar widgets */
.ev-cta-btn { display:block; text-align:center; background:linear-gradient(135deg,#1a237e,#3949ab); color:#fff; padding:11px; border-radius:10px; font-weight:700; font-size:.86rem; text-decoration:none; transition:opacity .2s; }
.ev-cta-btn:hover { opacity:.85; color:#fff; }
.ev-widget ul { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; }
.ev-widget ul li { font-size:.83rem; color:#555; display:flex; align-items:flex-start; gap:8px; }
.ev-widget ul li i { color:#3949ab; margin-top:2px; flex-shrink:0; }
.mini-event { display:flex; gap:10px; align-items:center; padding:7px 0; border-bottom:1px solid #f0f2fc; font-size:.81rem; }
.mini-event:last-child { border-bottom:none; }
.mini-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.mini-dot.event   { background:#1a237e; }
.mini-dot.exam    { background:#f57f17; }
.mini-dot.holiday { background:#2e7d32; }
.mini-event-date { font-size:.7rem; color:#9fa8da; white-space:nowrap; margin-left:auto; }
</style>
{% endblock %}

{% block body %}


		<div id="site-content">
			<!-- ===== HEADER ===== -->
			<header class="site-header">
				<div class="primary-header">
					<div class="container">
						<a href="{{ path('index') }}" id="branding">
							<img src="/images/logo.png" alt="City School">
							<div>
								<h1 class="site-title">City School</h1>
								<span class="site-subtitle">Premium Learning Institution</span>
							</div>
						</a>

						<div class="main-navigation">
							<ul class="home-main-menu home-nav-v2">
								<li class="home-nav-item"><a class="home-nav-link" href="{{ path('index') }}">Home</a></li>
								<li class="home-nav-item"><a class="home-nav-link" href="{{ path('courses') }}">Courses</a></li>
								<li class="home-nav-item"><a class="home-nav-link" href="{{ path('values') }}">Values</a></li>
								<li class="home-nav-item current-menu-item"><a class="home-nav-link" href="{{ path('events') }}">Events</a></li>
								<li class="home-nav-item"><a class="home-nav-link" href="{{ path('admissions') }}">Admissions</a></li>
							<li class="home-nav-item"><a class="home-nav-link" href="{{ path('pricing') }}">Pricing</a></li>
								<li class="home-nav-item"><a class="home-nav-link" href="{{ path('contact') }}">Contact</a></li>
								<li class="home-nav-item nav-dropdown">
									<a class="home-nav-link" href="#"><i class="fa fa-sign-in home-nav-login-icon"></i> Login <span class="arrow">&#9660;</span></a>
									<ul class="dropdown-menu">
										<li><a href="{{ path('portal_login') }}"><span class="dm-icon"><i class="fa fa-book"></i></span> Student Portal</a></li>
										<li><a href="{{ path('teacher_login') }}"><span class="dm-icon"><i class="fa fa-sitemap"></i></span> Teacher Portal</a></li>
										<li><a href="{{ path('parent_login') }}"><span class="dm-icon"><i class="fa fa-home"></i></span> Parent Portal</a></li>
										<li><a href="{{ path('admin_login') }}"><span class="dm-icon"><i class="fa fa-cogs"></i></span> Admin Portal</a></li>
										<li class="dropdown-divider"></li>
										<li><a href="{{ path('super_admin_login') }}"><span class="dm-icon"><i class="fa fa-shield"></i></span> Super Admin</a></li>
									</ul>
								</li>
								<li class="home-nav-item nav-lang-switcher">
									<button class="lang-btn active" data-lang="en" onclick="switchLang('en')">EN</button>
									<button class="lang-btn" data-lang="fr" onclick="switchLang('fr')">FR</button>
									<button class="lang-btn" data-lang="es" onclick="switchLang('es')">ES</button>
								</li>
							</ul>
						</div>
					</div>
				</div>

				<!-- HERO -->
				<div class="home-slider">
					<div class="container">
						<div class="slide-caption">
							<h2 class="slide-title">Where Excellence Meets<br>Opportunity</h2>
							<p>City School provides a premium learning environment built on personalized instruction, modern labs, career mentoring, and a curriculum designed to unlock every student's potential.</p>
							<div class="hero-cta-row">
								<a href="{{ path('courses') }}" class="button large hero-btn hero-btn-programs"><i class="fa fa-book"></i>Explore Our Programs</a>
								<a href="{{ path('contact') }}" class="button large hero-btn hero-btn-consult"><i class="fa fa-calendar"></i>Book a Consultation</a>
							</div>
						</div>
						<div class="slider-img">
							<img src="/dummy/kid.png" alt="Student at City School">
						</div>
					</div>
				</div>
			</header>
		</div>

    <main>

        <!-- ===== QUICK ACTION BAR ===== -->
        <div class="ev-actions-bar">
            <div class="container">
                <div class="ev-actions-grid">
                    <a href="#school-news" class="ev-action-card">
                        <div class="ev-action-icon"><i class="fa fa-newspaper-o"></i></div>
                        <h4>School News</h4>
                        <p>Latest updates and stories from City School.</p>
                    </a>
                    <a href="#upcoming-events" class="ev-action-card">
                        <div class="ev-action-icon"><i class="fa fa-calendar-check-o"></i></div>
                        <h4>Upcoming Events</h4>
                        <p>View and RSVP to events happening soon.</p>
                    </a>
                    <a href="#announcements" class="ev-action-card">
                        <div class="ev-action-icon"><i class="fa fa-bullhorn"></i></div>
                        <h4>Announcements</h4>
                        <p>Important notices and urgent alerts.</p>
                    </a>
                    <a href="#academic-calendar" class="ev-action-card">
                        <div class="ev-action-icon"><i class="fa fa-calendar"></i></div>
                        <h4>Academic Calendar</h4>
                        <p>Holidays, exams, and term dates at a glance.</p>
                    </a>
                </div>
            </div>
        </div>

        <!-- ===== SCHOOL NEWS ===== -->
        <section class="ev-section" id="school-news">
            <div class="container">
                <span class="ev-label">Latest from City School</span>
                <h2 class="ev-title">School News</h2>
                <p class="ev-sub">Stay up to date with achievements, programmes, and community highlights from across the school.</p>
                <div class="news-grid">
                    <div class="news-card">
                        <div class="news-card-img" style="background:linear-gradient(135deg,#1a237e,#3949ab);"><i class="fa fa-trophy"></i></div>
                        <div class="news-card-body">
                            <span class="news-cat announce">Achievement</span>
                            <h3>City School Wins Regional Science Olympiad</h3>
                            <p>Our Grade 10 STEM team claimed first place at the Regional Science Olympiad, beating 24 competing schools.</p>
                            <div class="news-meta"><span><i class="fa fa-calendar"></i> Apr 28, 2026</span><span><i class="fa fa-user"></i> Admin</span></div>
                        </div>
                    </div>
                    <div class="news-card">
                        <div class="news-card-img" style="background:linear-gradient(135deg,#283593,#5c6bc0);"><i class="fa fa-book"></i></div>
                        <div class="news-card-body">
                            <span class="news-cat event">Programme</span>
                            <h3>New A.I. &amp; Robotics Lab Opening in September</h3>
                            <p>City School is proud to announce the opening of a state-of-the-art A.I. &amp; Robotics laboratory for Grades 8–12.</p>
                            <div class="news-meta"><span><i class="fa fa-calendar"></i> Apr 22, 2026</span><span><i class="fa fa-user"></i> Principal</span></div>
                        </div>
                    </div>
                    <div class="news-card">
                        <div class="news-card-img" style="background:linear-gradient(135deg,#2e7d32,#43a047);"><i class="fa fa-leaf"></i></div>
                        <div class="news-card-body">
                            <span class="news-cat holiday">Community</span>
                            <h3>Students Lead Green Campus Initiative</h3>
                            <p>The Student Environment Council launched a school-wide recycling and urban-gardening project this spring term.</p>
                            <div class="news-meta"><span><i class="fa fa-calendar"></i> Apr 15, 2026</span><span><i class="fa fa-user"></i> Ms. Asante</span></div>
                        </div>
                    </div>
                    <div class="news-card">
                        <div class="news-card-img" style="background:linear-gradient(135deg,#e65100,#ffa000);"><i class="fa fa-book"></i></div>
                        <div class="news-card-body">
                            <span class="news-cat exam">Academic</span>
                            <h3>Grade 12 University Acceptance Results 2026</h3>
                            <p>97% of our graduating class received university offers, with 34 students placed in top-ranked institutions worldwide.</p>
                            <div class="news-meta"><span><i class="fa fa-calendar"></i> Apr 10, 2026</span><span><i class="fa fa-user"></i> Admin</span></div>
                        </div>
                    </div>
                    <div class="news-card">
                        <div class="news-card-img" style="background:linear-gradient(135deg,#6a1b9a,#ab47bc);"><i class="fa fa-music"></i></div>
                        <div class="news-card-body">
                            <span class="news-cat announce">Arts</span>
                            <h3>Annual Performing Arts Showcase — May 20</h3>
                            <p>Join us for an evening of music, dance, and drama performed by students from Grades 3 to 12.</p>
                            <div class="news-meta"><span><i class="fa fa-calendar"></i> Apr 5, 2026</span><span><i class="fa fa-user"></i> Arts Dept.</span></div>
                        </div>
                    </div>
                    <div class="news-card">
                        <div class="news-card-img" style="background:linear-gradient(135deg,#00695c,#00897b);"><i class="fa fa-users"></i></div>
                        <div class="news-card-body">
                            <span class="news-cat event">Partnership</span>
                            <h3>City School Partners with Tech Futures Foundation</h3>
                            <p>A new partnership will bring coding bootcamps, mentorship, and internships to upper secondary students.</p>
                            <div class="news-meta"><span><i class="fa fa-calendar"></i> Mar 28, 2026</span><span><i class="fa fa-user"></i> Admin</span></div>
                        </div>
