<script>
/* ===== WIZARD NAVIGATION ===== */
function wizGo(step) {
    document.querySelectorAll('.wizard-panel').forEach(function(p){ p.classList.remove('active'); });
    document.querySelectorAll('.wizard-step-btn').forEach(function(b, i){
        b.classList.remove('active','done');
        if(i + 1 < step)  b.classList.add('done');
        if(i + 1 === step) b.classList.add('active');
    });
    var panel = document.getElementById('step-' + step);
    if(panel) { panel.classList.add('active'); panel.closest('.wizard-outer').scrollIntoView({behavior:'smooth',block:'start'}); }
}

/* ===== SUBMIT APPLICATION ===== */
function submitApp() {
    var ref = 'REF–' + new Date().getFullYear() + String(Math.floor(Math.random()*90000)+10000);
    document.getElementById('refNumber').textContent = ref;
    document.getElementById('confirm-box-preview').style.display = 'none';
    document.getElementById('confirm-box-done').style.display = 'block';
    /* mark all steps done */
    document.querySelectorAll('.wizard-step-btn').forEach(function(b){ b.classList.remove('active'); b.classList.add('done'); });
}

/* ===== DOCUMENT UPLOAD ===== */
function handleDocUpload(input) {
    var list = document.getElementById('docList');
    Array.from(input.files).forEach(function(file){
        var li = document.createElement('li');
        li.innerHTML = '<i class="fa fa-file-text-o"></i> ' + file.name + ' <span class="doc-status">Uploaded</span>';
        list.appendChild(li);
    });
}

/* ===== TRACK APPLICATION ===== */
function trackApp() {
    var val = document.getElementById('trackInput').value.trim();
    if(!val) return;
    document.getElementById('trackerSteps').scrollIntoView({behavior:'smooth',block:'start'});
}
</script>
