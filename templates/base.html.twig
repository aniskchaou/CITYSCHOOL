                        'footer.social_desc':'Suivez-nous pour les actualités, événements et réussites des élèves.',
                        'footer.students_title':'Étudiants en vedette','footer.newsletter_title':'Lettre d\'information',
                        'footer.newsletter_desc':'Restez informé des actualités et événements scolaires.',
                        'footer.subscribe':'S\'abonner','footer.email_ph':'Adresse e-mail...',
                        'footer.privacy':'Politique de confidentialité','footer.terms':'Conditions d\'utilisation','footer.cookies':'Paramètres des cookies'
                    },
                    es:{
                        'nav.home':'Inicio','nav.courses':'Cursos','nav.values':'Valores',
                        'nav.events':'Eventos','nav.admissions':'Admisiones','nav.contact':'Contacto','nav.login':'Acceder',
                        'footer.contact_title':'Contáctenos','footer.social_title':'Redes sociales',
                        'footer.social_desc':'Síguenos para noticias, eventos y logros estudiantiles.',
                        'footer.students_title':'Estudiantes destacados','footer.newsletter_title':'Boletín informativo',
                        'footer.newsletter_desc':'Mantente actualizado con noticias y eventos escolares.',
                        'footer.subscribe':'Suscribirse','footer.email_ph':'Dirección de correo...',
                        'footer.privacy':'Política de privacidad','footer.terms':'Términos de servicio','footer.cookies':'Configuración de cookies'
                    }
                };

                /* ── auto-tag translatable elements by their English source text ── */
                function autoTag(){
                    var navMap={'Home':'nav.home','Courses':'nav.courses','Values':'nav.values',
                                'Events':'nav.events','Admissions':'nav.admissions','Contact':'nav.contact'};
                    var ftTitleMap={'Contact us':'footer.contact_title','Social media':'footer.social_title',
                                    'Featured students':'footer.students_title','Newsletter':'footer.newsletter_title'};
                    var ftDescMap={'Stay updated with school news and events.':'footer.newsletter_desc',
                                   'Follow us for news, events, and student achievements.':'footer.social_desc'};
                    var copyMap={'Privacy Policy':'footer.privacy','Terms of Service':'footer.terms','Cookie Settings':'footer.cookies'};

                    /* nav simple links */
                    document.querySelectorAll('.home-main-menu .home-nav-link').forEach(function(el){
                        var txt=el.textContent.trim();
                        if(navMap[txt]){ el.setAttribute('data-i18n',navMap[txt]); return; }
                        /* login button — update only the text node between icon & arrow */
                        el.childNodes.forEach(function(node){
                            if(node.nodeType===3 && node.textContent.trim()==='Login'){
                                var span=document.createElement('span');
                                span.setAttribute('data-i18n','nav.login');
                                span.textContent='Login';
                                node.parentNode.replaceChild(span,node);
                            }
                        });
                    });
                    /* footer widget titles */
                    document.querySelectorAll('.site-footer .widget-title').forEach(function(el){
                        var k=ftTitleMap[el.textContent.trim()]; if(k) el.setAttribute('data-i18n',k);
                    });
                    /* footer widget paragraphs */
                    document.querySelectorAll('.site-footer .widget>p').forEach(function(el){
                        var k=ftDescMap[el.textContent.trim()]; if(k) el.setAttribute('data-i18n',k);
                    });
                    /* subscribe button & email placeholder */
                    document.querySelectorAll('.site-footer .subscribe input[type=submit]').forEach(function(el){
                        el.setAttribute('data-i18n-value','footer.subscribe');
                    });
                    document.querySelectorAll('.site-footer .subscribe input[type=email]').forEach(function(el){
                        el.setAttribute('data-i18n-placeholder','footer.email_ph');
                    });
                    /* copy links */
                    document.querySelectorAll('.copy a').forEach(function(el){
                        var k=copyMap[el.textContent.trim()]; if(k) el.setAttribute('data-i18n',k);
                    });
                }

                /* ── apply translations ── */
                function applyTranslations(lang){
                    var d=LANGS[lang]||LANGS['en'];
                    document.querySelectorAll('[data-i18n]').forEach(function(el){
                        var k=el.getAttribute('data-i18n'); if(d[k]!==undefined) el.textContent=d[k];
                    });
                    document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el){
                        var k=el.getAttribute('data-i18n-placeholder'); if(d[k]!==undefined) el.placeholder=d[k];
                    });
                    document.querySelectorAll('[data-i18n-value]').forEach(function(el){
                        var k=el.getAttribute('data-i18n-value'); if(d[k]!==undefined) el.value=d[k];
                    });
                    document.documentElement.lang=lang;
                    document.querySelectorAll('.lang-btn').forEach(function(btn){
                        btn.classList.toggle('active',btn.getAttribute('data-lang')===lang);
                    });
                    localStorage.setItem('cs_lang',lang);
                }

                window.switchLang=function(lang){ applyTranslations(lang); };

                /* ── PREMIUM: auto-detect browser language ── */
                var saved=localStorage.getItem('cs_lang');
                var detected=null;
                if(!saved){
                    var bl=(navigator.language||navigator.userLanguage||'en').toLowerCase().slice(0,2);
                    if(LANGS[bl]&&bl!=='en') detected=bl;
                }
                var activeLang=saved||detected||'en';

                document.addEventListener('DOMContentLoaded',function(){
                    autoTag();
                    applyTranslations(activeLang);
                    /* show toast when language was auto-detected */
                    if(detected){
                        var toast=document.createElement('div');
                        toast.className='lang-toast';
                        var name={fr:'Français',es:'Español'}[detected]||detected.toUpperCase();
                        toast.innerHTML='<i class="fa fa-map-marker" style="margin-right:6px;color:#90caf9;"></i> Language auto-detected: <strong>'+name+'</strong>';
                        document.body.appendChild(toast);
                        setTimeout(function(){toast.classList.add('show');},700);
                        setTimeout(function(){toast.classList.remove('show');},4200);
                    }
                });
            })();
            </script>
