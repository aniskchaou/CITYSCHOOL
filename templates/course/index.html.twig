<script>
/* ===== GRADE FILTER TABS ===== */
(function(){
    var tabs   = document.querySelectorAll('.grade-tab');
    var cards  = document.querySelectorAll('#gradesGrid .grade-card');
    var search = document.getElementById('gradeSearch');
    function apply(){
        var active = document.querySelector('.grade-tab.active');
        var group  = active ? active.getAttribute('data-grade') : 'all';
        var q = search ? search.value.toLowerCase().trim() : '';
        cards.forEach(function(card){
            var mg = group === 'all' || card.getAttribute('data-group') === group;
            var mq = q === '' || card.textContent.toLowerCase().indexOf(q) > -1;
            card.style.display = (mg && mq) ? '' : 'none';
        });
    }
    tabs.forEach(function(tab){
        tab.addEventListener('click', function(){
            tabs.forEach(function(t){ t.classList.remove('active'); });
            tab.classList.add('active');
            apply();
        });
    });
    if(search) search.addEventListener('input', apply);
})();

/* ===== COURSE CATALOG FILTER ===== */
(function(){
    var s  = document.getElementById('courseSearch');
    var lv = document.getElementById('levelFilter');
    var ct = document.getElementById('categoryFilter');
    var cards = document.querySelectorAll('#coursesGrid .course-card');
    var noR   = document.getElementById('noResults');
    function filter(){
        var q   = s  ? s.value.toLowerCase().trim() : '';
        var lvl = lv ? lv.value.toLowerCase()       : '';
        var cat = ct ? ct.value.toLowerCase()       : '';
        var vis = 0;
        cards.forEach(function(card){
            var text = card.textContent.toLowerCase();
            var show = (q===''||text.indexOf(q)>-1) && (lvl===''||text.indexOf(lvl)>-1) && (cat===''||text.indexOf(cat)>-1);
            card.style.display = show ? '' : 'none';
            if(show) vis++;
        });
        if(noR) noR.style.display = vis===0 ? 'block' : 'none';
    }
    if(s)  s.addEventListener('input',  filter);
    if(lv) lv.addEventListener('change', filter);
    if(ct) ct.addEventListener('change', filter);
})();
</script>

