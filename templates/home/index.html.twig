{% extends 'base.html.twig' %}

{% block title %}City School — Premium Learning{% endblock %}

{% block stylesheets %}
<style>
/* ==============================
   GLOBAL RESETS FOR PREMIUM PAGE
   ============================== */
*, *::before, *::after { box-sizing: border-box; }
body { margin: 0; font-family: 'Arvo', Georgia, serif; background: #fff; }
.container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
.row { display: flex; flex-wrap: wrap; gap: 24px; }
.col-md-6 { flex: 1 1 calc(50% - 12px); min-width: 280px; }
.col-md-4 { flex: 1 1 calc(33.33% - 16px); min-width: 240px; }
.col-md-3 { flex: 1 1 calc(25% - 18px); min-width: 200px; }
blockquote { margin: 0; padding: 12px 16px; border-left: 4px solid #cde3f8; background: #f0f7fd; border-radius: 0 8px 8px 0; font-style: italic; color: #3a5570; }
blockquote footer { margin-top: 6px; font-size: 12px; color: #7899b5; font-style: normal; }

/* ==============================
   HEADER & NAV
   ============================== */
.site-header { background: linear-gradient(90deg, #0f3a60 0%, #145483 100%); position: sticky; top: 0; z-index: 999; box-shadow: 0 8px 26px rgba(0,0,0,.26); border-bottom: 2px solid rgba(255,255,255,.30); margin-bottom: 0 !important; padding: 0 !important; }
.site-header::after { content: none !important; display: none !important; }
.primary-header { background: none !important; padding-bottom: 0 !important; }
.primary-header .container { display: flex; align-items: center; padding: 0 22px; min-height: 62px; gap: 0; }
#branding { display: flex; align-items: center; gap: 11px; text-decoration: none; flex-shrink: 0; margin-right: 22px; }
#branding img { height: 38px; width: auto; }
.site-title { margin: 0; font-size: 18px; font-weight: 800; color: #eef8ff; letter-spacing: -.2px; font-family: 'Montserrat', 'Arvo', sans-serif; }
.site-subtitle { font-size: 9px; color: #a5d6f2; font-weight: 500; display: block; margin-top: 1px; letter-spacing: 1px; text-transform: uppercase; font-family: 'Open Sans', sans-serif; }
.main-navigation { display: flex; align-items: center; justify-content: flex-end; flex: 1; margin-top: 0 !important; float: none !important; }
.home-main-menu { list-style: none; margin: 0; padding: 4px; display: flex !important; flex-wrap: nowrap !important; align-items: center; gap: 2px; background: rgba(255,255,255,.10); border: 1px solid rgba(255,255,255,.20); border-radius: 999px; backdrop-filter: blur(4px); font-family: 'Montserrat', 'Arvo', sans-serif; }
.main-navigation .home-main-menu > li.menu-item { float: none !important; margin: 0 !important; display: flex !important; align-items: center; height: 34px; }
.main-navigation .home-main-menu > li.menu-item > a { text-decoration: none; padding: 0 12px !important; height: 100%; min-height: 0; display: inline-flex; align-items: center; justify-content: center; gap: 5px; font-size: 11.5px !important; font-weight: 700; color: #d9efff !important; letter-spacing: .3px; text-transform: uppercase; border: none !important; border-radius: 999px !important; background: transparent !important; box-shadow: none !important; transition: color .18s, background .18s; white-space: nowrap; line-height: 1; }
.main-navigation .home-main-menu > li.menu-item > a > i,
.main-navigation .home-main-menu > li.menu-item > a .arrow { display: inline-flex; align-items: center; line-height: 1; }
.main-navigation .home-main-menu > li.menu-item > a > .nav-login-icon { margin-right: 2px; }
.main-navigation .home-main-menu > li.menu-item > a:hover { color: #0f3a60 !important; background: #ffffff !important; box-shadow: 0 1px 0 rgba(0,0,0,.08) !important; }
.main-navigation .home-main-menu > li.menu-item.current-menu-item > a { color: #0f3a60 !important; background: #ffffff !important; box-shadow: 0 1px 0 rgba(0,0,0,.08) !important; }
/* --- dropdown nav item --- */
.nav-dropdown { position: relative; }
.nav-dropdown > a .arrow { font-size: 9px; margin-left: 2px; transition: transform .2s; opacity: .75; }
.nav-dropdown:hover > a .arrow { transform: rotate(180deg); opacity: 1; }
.nav-dropdown:hover > a { color: #0f3a60 !important; background: #ffffff !important; }
.dropdown-menu { display: none; position: absolute; top: calc(100% + 8px); left: 0; background: #0d3150; border: 1px solid rgba(90,168,220,.45); border-radius: 12px; box-shadow: 0 14px 38px rgba(0,0,0,.34); min-width: 220px; padding: 8px 0; z-index: 1000; }
.nav-dropdown:hover .dropdown-menu { display: block; }
.dropdown-menu li { list-style: none; }
.main-navigation .home-main-menu .dropdown-menu a { display: grid !important; grid-template-columns: 24px 1fr; align-items: center !important; column-gap: 8px; padding: 8px 14px !important; font-size: 10.5px !important; color: #d7ecfd !important; text-decoration: none; font-weight: 700; letter-spacing: .35px; text-transform: uppercase; font-family: 'Montserrat', 'Arvo', sans-serif; white-space: nowrap; background: transparent !important; border: none !important; border-radius: 0 !important; box-shadow: none !important; }
.main-navigation .home-main-menu .dropdown-menu a .dm-icon { width: 24px; height: 24px; border-radius: 6px; background: rgba(75,179,255,.18); color: #67c2ff; display: inline-flex !important; align-items: center; justify-content: center; font-size: 11px; transition: background .15s, color .15s; }
.main-navigation .home-main-menu .dropdown-menu a .dm-icon i { display: inline-block !important; font-family: FontAwesome !important; line-height: 1; color: inherit !important; }
.main-navigation .home-main-menu .dropdown-menu a:hover { background: rgba(103,194,255,.20) !important; color: #ffffff !important; }
.main-navigation .home-main-menu .dropdown-menu a:hover .dm-icon { background: #67c2ff; color: #0d3150; }
.dropdown-divider { height: 1px; background: rgba(103,194,255,.32); margin: 6px 12px; }
/* --- misc --- */
.nav-spacer { flex: 1; }
.menu-toggle { display: none; background: none; border: 1px solid rgba(255,255,255,.35); border-radius: 8px; padding: 6px 10px; cursor: pointer; color: #d9efff; margin-left: auto; }

/* --- dedicated v2 nav classes for stable alignment --- */
.home-nav-v2 { display: flex !important; flex-wrap: nowrap !important; align-items: center !important; background: transparent !important; border: none !important; box-shadow: none !important; }
.home-nav-v2 > li.home-nav-item { display: flex !important; align-items: stretch !important; height: 34px; margin: 0 !important; float: none !important; }
.home-nav-v2 > li.home-nav-item > a.home-nav-link { display: inline-flex !important; align-items: center !important; justify-content: center !important; height: 100%; padding: 0 12px !important; gap: 5px; text-decoration: none; border-radius: 999px !important; line-height: 1; color: #d9efff !important; background: transparent !important; }
.home-nav-v2 > li.home-nav-item > a.home-nav-link:hover,
.home-nav-v2 > li.home-nav-item.current-menu-item > a.home-nav-link { color: #0f3a60 !important; background: #ffffff !important; box-shadow: 0 1px 0 rgba(0,0,0,.08) !important; }
.home-nav-v2 > li.home-nav-item > a.home-nav-link > .home-nav-login-icon,
.home-nav-v2 > li.home-nav-item > a.home-nav-link > .arrow { display: inline-flex; align-items: center; line-height: 1; }
.home-nav-v2 > li.home-nav-item > a.home-nav-link > .home-nav-login-icon { margin-right: 2px; }

/* ==============================
   HERO SLIDER AREA
   ============================== */
.home-slider { background: linear-gradient(135deg, #0e3f6e 0%, #1a8ba3 60%, #21b5b5 100%); padding: 0; color: #fff; overflow: hidden; }
.home-slider .container { display: flex; align-items: stretch; gap: 0; padding: 0; max-width: 100%; }
.slide-caption { flex: 1; padding: 60px 48px; display: flex; flex-direction: column; justify-content: center; }
.slide-caption .slide-title { font-size: 48px; line-height: 1.2; margin: 0 0 20px; color: #fff; }
.slide-caption p { font-size: 18px; color: #c8eaf8; line-height: 1.8; margin: 0 0 28px; }
.slider-img { text-align: right; }
.slider-img img { width: 100%; height: 520px; object-fit: cover; border-radius: 0; box-shadow: none; display: block; margin: 4px 0; }

/* ==============================
   BUTTONS
   ============================== */
.button { display: inline-block; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 700; text-decoration: none; cursor: pointer; transition: background .2s, transform .15s; }
.button.primary { background: #fff; color: #174f7a; }
.button.primary:hover { background: #e5f3ff; }
.button.secondary { background: transparent; color: #fff; border: 2px solid #fff; }
.button.secondary:hover { background: rgba(255,255,255,.15); }
.button.large { padding: 14px 30px; font-size: 16px; }
.button.green { background: #1d9c6e; color: #fff; border-color: #1d9c6e; }
.button.dark { background: #174f7a; color: #fff; border: none; }
.button.dark:hover { background: #0e3a5e; }
.button.outline-dark { background: transparent; color: #174f7a; border: 2px solid #174f7a; }
.button.outline-dark:hover { background: #eaf4fc; }

/* Hero CTA redesign */
.hero-cta-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 8px; }
.hero-cta-row .hero-btn { min-width: 230px; text-align: center; border-radius: 12px; padding: 14px 22px; font-size: 15px; letter-spacing: .2px; transition: transform .18s, box-shadow .18s, background .18s, color .18s; }
.hero-cta-row .hero-btn i { margin-right: 8px; }
.hero-btn-programs { background: linear-gradient(135deg, #ffffff 0%, #e8f6ff 100%); color: #0f3a60; border: 1px solid rgba(255,255,255,.85); box-shadow: 0 8px 22px rgba(5,28,44,.20); }
.hero-btn-programs:hover { background: #ffffff; transform: translateY(-1px); box-shadow: 0 12px 28px rgba(5,28,44,.26); }
.hero-btn-consult { background: rgba(8,31,49,.35); color: #f1f9ff; border: 1px solid rgba(190,229,255,.55); box-shadow: 0 8px 20px rgba(5,28,44,.16); }
.hero-btn-consult:hover { background: rgba(6,22,36,.55); color: #ffffff; transform: translateY(-1px); box-shadow: 0 12px 28px rgba(5,28,44,.24); }

/* ==============================
   SECTION SHARED
   ============================== */
.main-content { background: radial-gradient(circle at 10% 0%, #eef7ff 0%, transparent 36%), radial-gradient(circle at 100% 20%, #edfdfb 0%, transparent 28%), #ffffff; }
.section { padding: 64px 0; position: relative; }
.section-alt { background: linear-gradient(180deg, #f7fbff 0%, #eff8ff 100%); }
.section-dark { background: linear-gradient(120deg, #0e3f6e 0%, #1a8ba3 100%); color: #fff; }
.section-title-block { margin-bottom: 36px; }
.section-label { display: inline-block; padding: 5px 14px; border-radius: 999px; background: #dff0fa; color: #1056a0; font-size: 11px; font-weight: 800; letter-spacing: .9px; margin-bottom: 12px; text-transform: uppercase; }
.section-title-block h2 { margin: 0 0 12px; font-size: 35px; color: #113b60; letter-spacing: -.5px; line-height: 1.2; }
.section-title-block p { margin: 0; color: #5d7891; line-height: 1.9; max-width: 690px; font-size: 15px; }
.section-dark .section-title-block h2 { color: #fff; }
.section-dark .section-title-block p { color: #bde3f5; }
.section-dark .section-label { background: rgba(255,255,255,.15); color: #e0f4ff; }

/* ==============================
   STATS BAR
   ============================== */
.stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; border-radius: 16px; }
.stat-item { padding: 24px 18px; background: linear-gradient(180deg, #ffffff 0%, #f6fbff 100%); border: 1px solid #d7ebf9; border-radius: 14px; text-align: center; box-shadow: 0 8px 18px rgba(18,62,95,.08); transition: transform .18s, box-shadow .18s; }
.stat-item:hover { transform: translateY(-3px); box-shadow: 0 14px 24px rgba(18,62,95,.12); }
.stat-item h3 { margin: 0 0 6px; font-size: 40px; color: #0c5f95; letter-spacing: -.8px; }
.stat-item p { margin: 0; font-size: 13px; color: #6686a0; font-weight: 700; }

/* ==============================
   PROGRAM CARDS
   ============================== */
.program-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.program-card { border: 1px solid #d9ecfa; border-radius: 16px; padding: 24px; background: #fff; box-shadow: 0 10px 26px rgba(14,63,110,.08); transition: transform .22s, box-shadow .22s, border-color .22s; position: relative; overflow: hidden; }
.program-card::before { content: ""; position: absolute; left: 0; top: 0; right: 0; height: 4px; background: linear-gradient(90deg, #1e79ab 0%, #2eb8bd 100%); opacity: .75; }
.program-card:hover { transform: translateY(-5px); border-color: #acd9f1; box-shadow: 0 18px 38px rgba(14,63,110,.16); }
.program-card .icon-badge { width: 50px; height: 50px; border-radius: 14px; background: #eaf4fc; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; font-size: 22px; color: #1a6fa3; }
.program-card h3 { margin: 0 0 9px; font-size: 20px; color: #133f61; }
.program-card p { margin: 0 0 15px; color: #5f7f9f; line-height: 1.75; font-size: 14px; }
.program-meta { font-size: 11.5px; color: #7e9bb3; display: flex; gap: 9px; flex-wrap: wrap; font-weight: 700; }

/* ==============================
   FEATURE SPLIT
   ============================== */
.feature-split { display: grid; grid-template-columns: 1.1fr 1fr; gap: 32px; align-items: start; }
.feature-list { list-style: none; margin: 0; padding: 0; }
.feature-list li { padding: 12px 12px; border: 1px solid #e6eff7; border-radius: 12px; margin-bottom: 10px; font-size: 15px; color: #4a6070; display: flex; gap: 10px; align-items: flex-start; background: #fff; }
.feature-list li:last-child { border-bottom: none; }
.feature-icon { width: 30px; height: 30px; border-radius: 9px; background: #eaf4fc; color: #1a6fa3; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 13px; }
.intake-box { border: 1px solid #d6eaf8; border-radius: 14px; padding: 22px; background: #f7fbff; box-shadow: 0 10px 22px rgba(14,63,110,.07); }
.intake-box h4 { margin: 0 0 14px; color: #143d5e; font-size: 19px; }
.intake-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #e4eef7; font-size: 14px; gap: 8px; }
.intake-row:last-of-type { border-bottom: none; }
.intake-row strong { color: #174f7a; }
.intake-row span { color: #6080a0; }
.badge { padding: 3px 9px; border-radius: 999px; font-size: 12px; font-weight: 700; }
.badge-open { background: #d4f0e0; color: #1a7a4f; }
.badge-soon { background: #fff3cd; color: #8a6200; }

/* ==============================
   COURSES HIGHLIGHT
   ============================== */
.courses-highlight-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
.course-hl-card { border: 1px solid #d8e8f2; border-radius: 14px; padding: 20px; background: #fff; box-shadow: 0 9px 22px rgba(15,60,95,.08); transition: transform .18s, box-shadow .18s; }
.course-hl-card:hover { transform: translateY(-3px); box-shadow: 0 16px 30px rgba(15,60,95,.14); }
.course-hl-card h4 { margin: 0 0 6px; color: #143d5e; font-size: 17px; }
.course-hl-card p { margin: 0 0 12px; color: #6080a0; font-size: 14px; line-height: 1.6; }
.course-hl-meta { font-size: 12px; color: #8daabf; display: flex; gap: 10px; flex-wrap: wrap; }

/* ==============================
   FACULTY
   ============================== */
.faculty-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.faculty-card { border: 1px solid #d8e8f2; border-radius: 16px; padding: 24px 22px; background: #fff; text-align: center; box-shadow: 0 10px 24px rgba(15,60,95,.08); transition: transform .18s, box-shadow .18s; }
.faculty-card:hover { transform: translateY(-4px); box-shadow: 0 18px 32px rgba(15,60,95,.14); }
.faculty-avatar { width: 74px; height: 74px; border-radius: 50%; background: linear-gradient(145deg, #ddf1fd, #cde7fa); margin: 0 auto 13px; display: flex; align-items: center; justify-content: center; font-size: 27px; color: #1a6fa3; }
.faculty-card h4 { margin: 0 0 4px; color: #143d5e; font-size: 17px; }
.faculty-card .role { font-size: 13px; color: #7096b5; margin: 0 0 10px; }
.faculty-card p { margin: 0; font-size: 14px; color: #6080a0; line-height: 1.6; }

/* ==============================
   TESTIMONIALS
   ============================== */
.testimonial-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.testimonial-card { border: 1px solid #d8e8f2; border-radius: 16px; padding: 24px; background: #fff; box-shadow: 0 10px 24px rgba(15,60,95,.08); position: relative; }
.testimonial-card::before { content: "\201C"; position: absolute; top: 10px; right: 14px; font-size: 44px; line-height: 1; color: #d6e9f7; font-family: Georgia, serif; }
.testimonial-card blockquote { border: none; background: none; padding: 0; color: #3d5c74; }
.testimonial-card blockquote footer { margin-top: 10px; font-weight: 700; color: #174f7a; }
.stars { color: #f5a623; font-size: 13px; margin-bottom: 10px; letter-spacing: 1px; }

/* ==============================
   NEWS + EVENTS (kept from original)
   ============================== */
.news-event-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.posts { list-style: none; margin: 0; padding: 0; }
.posts .post { padding: 12px 0; border-bottom: 1px solid #e8f1f9; }
.posts .post:last-child { border-bottom: none; }
.posts .post h3 { margin: 0 0 4px; font-size: 15px; }
.posts .post a { color: #174f7a; text-decoration: none; }
.posts .post a:hover { color: #0e5f95; text-decoration: underline; }
.posts .post .date, .posts .post .author, .posts .post .location, .posts .post .time, .posts .post .price { display: inline-block; font-size: 12px; color: #8daabf; margin-right: 10px; }

/* ==============================
   CTA BANNER
   ============================== */
.cta-banner { border-radius: 20px; background: linear-gradient(120deg, #0b3f6b 0%, #177aa6 100%); color: #fff; padding: 44px 38px; display: flex; align-items: center; justify-content: space-between; gap: 24px; margin: 24px 0; box-shadow: 0 20px 40px rgba(9,47,79,.35); }
.cta-banner h2 { margin: 0 0 8px; font-size: 30px; letter-spacing: -.5px; }
.cta-banner p { margin: 0; color: #c5e8f9; }
.cta-actions { display: flex; gap: 12px; flex-shrink: 0; flex-wrap: wrap; }

/* ==============================
   PORTAL QUICK ACCESS
   ============================== */
.portal-access { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
.portal-access-card { border: 1px solid #d6eaf8; border-radius: 14px; padding: 20px 16px; background: #fff; text-align: center; box-shadow: 0 8px 20px rgba(15,60,95,.07); transition: transform .18s, box-shadow .18s; }
.portal-access-card:hover { transform: translateY(-3px); box-shadow: 0 14px 26px rgba(15,60,95,.12); }
.portal-access-card .pa-icon { font-size: 28px; color: #1a6fa3; margin-bottom: 10px; }
.portal-access-card h4 { margin: 0 0 5px; font-size: 15px; color: #143d5e; }
.portal-access-card p { margin: 0 0 12px; font-size: 13px; color: #7096b5; line-height: 1.55; }

/* ==============================
   SITE FOOTER
   ============================== */
.site-footer { background: #0e2d45; color: #9ab8cc; padding: 40px 0 0; margin-top: 0; }
.widget-title { color: #e0f0fb; margin: 0 0 12px; font-size: 16px; }
.widget address { font-style: normal; line-height: 1.8; font-size: 14px; }
.widget a { color: #9ab8cc; text-decoration: none; font-size: 14px; }
.widget a:hover { color: #fff; }
.social-links.circle a { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; border: 1px solid #2a5a75; margin-right: 6px; color: #9ab8cc; transition: background .2s; }
.social-links.circle a:hover { background: #1a6fa3; color: #fff; }
.student-list { list-style: none; margin: 0; padding: 0; }
.student-list li { margin-bottom: 10px; }
.student-list a { display: flex; gap: 10px; align-items: center; color: #9ab8cc; text-decoration: none; }
.student-list .fn { display: block; font-size: 14px; color: #c8dde9; }
.student-list .average { font-size: 12px; }
.student-list .avatar { width: 36px; height: 36px; border-radius: 50%; }
.subscribe { display: flex; gap: 8px; margin-top: 8px; }
.subscribe input[type="email"] { flex: 1; padding: 8px 10px; border: 1px solid #2a5a75; border-radius: 8px; background: #162f42; color: #d0e8f5; font-size: 13px; }
.subscribe input[type="submit"] { background: #1a7aa3; color: #fff; border: none; border-radius: 8px; padding: 8px 14px; font-size: 13px; cursor: pointer; }
.copy { text-align: center; color: #5a7d90; border-top: 1px solid #1e3f55; margin-top: 32px; padding: 16px 0; font-size: 13px; }

/* ==============================
   RESPONSIVE
   ============================== */
@media screen and (max-width: 1000px) {
    .program-grid, .faculty-grid, .testimonial-grid, .courses-highlight-grid, .news-event-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-bar { grid-template-columns: repeat(2, 1fr); }
    .portal-access { grid-template-columns: repeat(3, 1fr); }
    .feature-split { grid-template-columns: 1fr; }
    .primary-header .container { padding: 0 14px; }
    #branding { margin-right: 10px; }
    .site-subtitle { display: none; }
    .main-navigation .home-main-menu > li.menu-item > a { padding: 6px 8px !important; font-size: 10px !important; letter-spacing: .2px; }
    .cta-banner { flex-direction: column; text-align: center; }
    .cta-actions { justify-content: center; }
    .home-slider .container { flex-direction: column; gap: 20px; }
    .slider-img { display: none; }
}
@media screen and (max-width: 640px) {
    .program-grid, .faculty-grid, .testimonial-grid, .courses-highlight-grid, .news-event-grid, .stats-bar, .portal-access { grid-template-columns: 1fr; }
    .main-navigation { flex-direction: row; align-items: center; justify-content: flex-end; }
    .menu-toggle { display: block; }
    .home-main-menu { display: none !important; }
}
.premium-main {
	background: linear-gradient(180deg, #f7fbff 0%, #fefdf8 42%, #ffffff 100%);
}

.premium-strip {
	margin-top: 36px;
	margin-bottom: 30px;
}

.premium-stats {
	display: grid;
	grid-template-columns: repeat(4, minmax(0, 1fr));
	gap: 14px;
}

.premium-stat {
	background: #ffffff;
	border: 1px solid #e5edf3;
	border-radius: 14px;
	padding: 20px;
	box-shadow: 0 10px 26px rgba(43, 72, 91, 0.08);
}

.premium-stat h3 {
	margin: 0;
	font-size: 32px;
	color: #174f7a;
}

.premium-stat p {
	margin: 6px 0 0;
	color: #617a8e;
