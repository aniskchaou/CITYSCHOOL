{% extends 'portal/base.html.twig' %}

{% block title %}Grades{% endblock %}
{% block page_title %}Grades & Feedback{% endblock %}

{% block content %}

{# ── GPA Summary ── #}
<div class="stats-grid" style="margin-bottom:24px;">
    <div class="stat-card">
        <div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-star"></i></div>
        <div><div class="stat-value">{{ student.gpa }}</div><div class="stat-label">GPA (4.0 scale)</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-trophy"></i></div>
        <div><div class="stat-value">#{{ student.rank }}</div><div class="stat-label">Class Rank / {{ student.total_students }}</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="fa fa-check-circle"></i></div>
        <div><div class="stat-value">{{ grade_book|length }}</div><div class="stat-label">Courses This Semester</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fef9c3;color:#a16207;"><i class="fa fa-bar-chart"></i></div>
        <div>
            {% set total_score = 0 %}
            {% for gb in grade_book %}{% set total_score = total_score + gb.score %}{% endfor %}
            <div class="stat-value">{{ (total_score / grade_book|length)|round }}%</div>
            <div class="stat-label">Average Score</div>
        </div>
    </div>
</div>

<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-list-alt" style="color:#2563eb;margin-right:6px;"></i>Grades by Subject / Exam</span>
        <form method="post" action="{{ path('portal_grades') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('student_refresh_grades') }}">
            <input type="hidden" name="action" value="refresh_grades">
            <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
        </form>
    </div>
    <table class="portal-table">
        <thead><tr><th>Subject</th><th>Exam</th><th>Current</th><th>Past</th><th>Class Avg</th><th>Teacher Comment</th></tr></thead>
        <tbody>
            {% for row in subjectExamGrades %}
            <tr>
                <td class="fw-bold" style="font-size:13px;">{{ row.subject }}</td>
                <td style="font-size:12px;color:#64748b;">{{ row.exam }}</td>
                <td><span class="badge badge-success">{{ row.current }}%</span></td>
                <td><span class="badge badge-secondary">{{ row.previous }}%</span></td>
                <td style="font-size:12px;">{{ row.classAverage }}%</td>
                <td style="font-size:12px;color:#0369a1;"><i class="fa fa-comment-o"></i> {{ row.teacherComment }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="grid-2" style="gap:20px;margin-bottom:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-line-chart" style="color:#16a34a;margin-right:6px;"></i>Past vs Current Performance</span>
            <form method="post" action="{{ path('portal_grades') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('student_refresh_trends') }}">
                <input type="hidden" name="action" value="refresh_trends">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        {% for point in gradeTrend %}
        <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;">
                <span>{{ point.label }}</span>
                <span>{{ point.score }}%</span>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:{{ point.score }}%;background:#22c55e;"></div>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-diamond" style="color:#7c3aed;margin-right:6px;"></i>Premium Insights</span>
            <form method="post" action="{{ path('portal_grades') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('student_refresh_analysis') }}">
                <input type="hidden" name="action" value="refresh_analysis">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        <div style="font-size:13px;font-weight:700;margin-bottom:6px;">Strengths</div>
        {% for item in performanceAnalysis.strengths %}
        <div style="font-size:12px;color:#16a34a;margin-bottom:4px;"><i class="fa fa-check-circle"></i> {{ item }}</div>
        {% endfor %}

        <div style="font-size:13px;font-weight:700;margin:10px 0 6px 0;">Weaknesses</div>
        {% for item in performanceAnalysis.weaknesses %}
        <div style="font-size:12px;color:#dc2626;margin-bottom:4px;"><i class="fa fa-exclamation-circle"></i> {{ item }}</div>
        {% endfor %}

        <div style="font-size:13px;font-weight:700;margin:10px 0 6px 0;">What to improve next</div>
        {% for item in performanceAnalysis.improvements %}
        <div style="font-size:12px;color:#475569;margin-bottom:5px;"><i class="fa fa-lightbulb-o" style="color:#f59e0b;"></i> {{ item }}</div>
        {% endfor %}
    </div>
</div>

{# ── Grade per course ── #}
{% for gb in grade_book %}
<div class="card" style="margin-bottom:20px;border-left:4px solid {{ gb.color }};">
    <div class="card-header" style="margin-bottom:10px;">
        <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:38px;height:38px;border-radius:8px;background:{{ gb.color }};display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;flex-shrink:0;">
                <i class="fa fa-book"></i>
            </div>
            <div>
                <div style="font-size:15px;font-weight:700;">{{ gb.course }}</div>
                <div style="font-size:12px;color:#64748b;">{{ gb.teacher }}</div>
            </div>
        </div>
        <div style="text-align:right;">
            <div style="font-size:28px;font-weight:800;color:{{ gb.color }};">{{ gb.grade }}</div>
            <div style="font-size:13px;color:#64748b;">{{ gb.score }}%</div>
        </div>
    </div>
    <div class="progress-bar-wrap" style="margin-bottom:14px;">
        <div class="progress-bar-fill" style="width:{{ gb.score }}%;background:{{ gb.color }};height:8px;"></div>
    </div>
    {% if gb.assignments is not empty %}
    <table class="portal-table">
        <thead><tr><th>Assignment</th><th>Score</th><th>Feedback</th></tr></thead>
        <tbody>
            {% for a in gb.assignments %}
            <tr>
                <td style="font-size:13px;font-weight:600;">{{ a.title }}</td>
                <td>
                    <span class="badge badge-{% if (a.score/a.points) >= 0.9 %}success{% elseif (a.score/a.points) >= 0.75 %}primary{% else %}warning{% endif %}">
                        {{ a.score }}/{{ a.points }}
                    </span>
                </td>
                <td style="font-size:12px;color:#0369a1;">
                    {% if a.feedback %}<i class="fa fa-comment-o"></i> {{ a.feedback }}{% else %}–{% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p style="font-size:13px;color:#94a3b8;padding:6px 0;">No graded assignments yet for this course.</p>
    {% endif %}
</div>
{% endfor %}

{% endblock %}
