{% extends 'portal/base.html.twig' %}

{% block title %}AI Learning{% endblock %}
{% block page_title %}AI & Smart Learning{% endblock %}

{% block content %}

<div class="grid-2" style="gap:20px;margin-bottom:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-question-circle" style="color:#2563eb;margin-right:6px;"></i>Ask Questions About Lessons</span>
        </div>
        <form method="post" action="{{ path('portal_ai_learning') }}" style="margin-bottom:12px;">
            <input type="hidden" name="_token" value="{{ csrf_token('ask_lesson_ai') }}">
            <input type="hidden" name="action" value="ask_lesson_ai">
            <div class="form-group">
                <label class="form-label">Your lesson question</label>
                <textarea class="form-control" name="question" rows="3" placeholder="Ask AI about any lesson concept..."></textarea>
            </div>
            <button class="btn btn-primary" type="submit"><i class="fa fa-send"></i> Ask AI</button>
        </form>
        {% for row in lessonQna %}
        <div style="padding:8px;border:1px solid #e2e8f0;border-radius:6px;margin-bottom:7px;">
            <div style="font-size:12px;font-weight:700;">{{ row.lesson }}: {{ row.question }}</div>
            <div style="font-size:12px;color:#475569;margin-top:4px;">{{ row.answer }}</div>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-file-text-o" style="color:#0ea5e9;margin-right:6px;"></i>Summaries & Recommendations</span>
        </div>
        <form method="post" action="{{ path('portal_ai_learning') }}" style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;">
            <input type="hidden" name="_token" value="{{ csrf_token('generate_material_summary') }}">
            <input type="hidden" name="action" value="generate_material_summary">
            <button class="btn btn-outline btn-sm" type="submit">Generate Summary</button>
        </form>
        {% for item in materialSummaries %}
        <div style="padding:8px;background:#f8fafc;border-radius:6px;margin-bottom:7px;">
            <div style="font-size:12px;font-weight:700;">{{ item.material }}</div>
            <div style="font-size:12px;color:#475569;margin-top:3px;">{{ item.summary }}</div>
        </div>
        {% endfor %}

        <div style="font-size:13px;font-weight:700;margin:10px 0 8px 0;">Study recommendations</div>
        {% for rec in recommendations %}
        <div style="font-size:12px;color:#475569;margin-bottom:6px;"><i class="fa fa-lightbulb-o" style="color:#f59e0b;margin-right:5px;"></i>{{ rec }}</div>
        {% endfor %}
        <form method="post" action="{{ path('portal_ai_learning') }}" style="margin-top:8px;">
            <input type="hidden" name="_token" value="{{ csrf_token('refresh_study_recommendations') }}">
            <input type="hidden" name="action" value="refresh_study_recommendations">
            <button class="btn btn-outline btn-sm" type="submit">Refresh Recommendations</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-diamond" style="color:#7c3aed;margin-right:6px;"></i>Premium AI Tools</span>
    </div>
    <div class="grid-2" style="gap:20px;">
        <div>
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">AI Tutor (concept explanations)</div>
            {% for tip in aiTutorTips %}
            <div style="padding:8px;border:1px solid #e2e8f0;border-radius:6px;margin-bottom:7px;">
                <div style="font-size:12px;font-weight:700;">{{ tip.concept }}</div>
                <div style="font-size:12px;color:#475569;margin-top:3px;">{{ tip.explanation }}</div>
            </div>
            {% endfor %}
            <form method="post" action="{{ path('portal_ai_learning') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('open_ai_tutor') }}">
                <input type="hidden" name="action" value="open_ai_tutor">
                <button class="btn btn-outline btn-sm" type="submit">Open AI Tutor</button>
            </form>
        </div>

        <div>
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">Auto-generated notes from lessons</div>
            {% for note in autoNotes %}
            <div style="font-size:12px;color:#475569;margin-bottom:6px;"><i class="fa fa-sticky-note-o" style="color:#2563eb;margin-right:5px;"></i>{{ note.lesson }}: {{ note.note }}</div>
            {% endfor %}
            <form method="post" action="{{ path('portal_ai_learning') }}" style="margin:8px 0 10px 0;">
                <input type="hidden" name="_token" value="{{ csrf_token('generate_auto_notes') }}">
                <input type="hidden" name="action" value="generate_auto_notes">
                <button class="btn btn-outline btn-sm" type="submit">Generate Notes</button>
            </form>

            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">Personalized revision plan</div>
            {% for plan in revisionPlan %}
            <div style="padding:7px;background:#f8fafc;border-radius:6px;margin-bottom:6px;font-size:12px;">
                <strong>{{ plan.day }}</strong>: {{ plan.focus }} ({{ plan.duration }})
            </div>
            {% endfor %}
            <form method="post" action="{{ path('portal_ai_learning') }}" style="margin-top:8px;">
                <input type="hidden" name="_token" value="{{ csrf_token('build_revision_plan') }}">
                <input type="hidden" name="action" value="build_revision_plan">
                <button class="btn btn-outline btn-sm" type="submit">Build Revision Plan</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}