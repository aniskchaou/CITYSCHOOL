{% extends 'portal/base.html.twig' %}

{% block title %}My Courses{% endblock %}
{% block page_title %}My Courses{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1>My Courses</h1>
        <p>{{ courses|length }} active courses this semester</p>
    </div>
</div>

<div class="grid-auto">
    {% for course in courses %}
    <a href="{{ path('portal_course_show', {id: course.id}) }}" class="course-card">
        <div class="course-card-top" style="background:{{ course.color }};"></div>
        <div class="course-card-body">
            <div class="course-icon" style="background:{{ course.color }};">
                <i class="fa fa-{{ course.icon }}"></i>
            </div>
            <div class="course-name">{{ course.name }}</div>
            <div class="course-teacher"><i class="fa fa-user" style="margin-right:4px;"></i>{{ course.teacher }}</div>

            <div style="margin-bottom:8px;">
                <div style="display:flex;justify-content:space-between;font-size:12px;color:#64748b;margin-bottom:4px;">
                    <span>Progress</span><span>{{ course.progress }}%</span>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-fill" style="width:{{ course.progress }}%;background:{{ course.color }};"></div>
                </div>
            </div>

            <div class="course-meta">
                <span><i class="fa fa-file-text-o" style="margin-right:3px;"></i>{{ course.materials }} materials</span>
                <span class="badge badge-{% if course.grade starts with 'A' %}success{% elseif course.grade starts with 'B' %}primary{% else %}warning{% endif %}">{{ course.grade }} &nbsp; {{ course.score }}%</span>
            </div>
            {% if course.assignments_due > 0 %}
            <div style="margin-top:10px;">
                <span class="badge badge-warning"><i class="fa fa-clock-o"></i> {{ course.assignments_due }} due</span>
            </div>
            {% endif %}
        </div>
    </a>
    {% endfor %}
</div>
{% endblock %}
