{% extends 'portal/base.html.twig' %}

{% block title %}Assignments{% endblock %}
{% block page_title %}Assignments{% endblock %}

{% block content %}

{# ── Filter Tabs ── #}
{% set pending  = assignments|filter(a => a.status == 'pending') %}
{% set overdue  = assignments|filter(a => a.status == 'overdue') %}
{% set submitted = assignments|filter(a => a.status == 'submitted') %}
{% set graded   = assignments|filter(a => a.status == 'graded') %}

<div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
    <span class="badge badge-warning" style="font-size:13px;padding:7px 14px;">Pending: {{ pending|length }}</span>
    <span class="badge badge-danger"  style="font-size:13px;padding:7px 14px;">Overdue: {{ overdue|length }}</span>
    <span class="badge badge-info"    style="font-size:13px;padding:7px 14px;">Submitted: {{ submitted|length }}</span>
    <span class="badge badge-success" style="font-size:13px;padding:7px 14px;">Graded: {{ graded|length }}</span>
</div>

<div class="grid-2" style="gap:20px;margin-bottom:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-upload" style="color:#2563eb;margin-right:6px;"></i>Submit Work (File, Text, Link)</span>
        </div>
        <form method="post" action="{{ path('portal_assignments') }}" enctype="multipart/form-data">
            <input type="hidden" name="_token" value="{{ csrf_token('student_submit_work') }}">
            <input type="hidden" name="action" value="submit_work">
            <div class="form-group">
                <label class="form-label">Assignment</label>
                <select name="assignment_id" class="form-control">
                    {% for a in pending %}
                    <option value="{{ a.id }}">{{ a.title }} ({{ a.course }}) - due {{ a.due }}</option>
                    {% endfor %}
                    {% for a in overdue %}
                    <option value="{{ a.id }}">{{ a.title }} ({{ a.course }}) - overdue</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Text editor response</label>
                <textarea class="form-control" name="submission_text" rows="4" placeholder="Write your answer or notes here..."></textarea>
            </div>
            <div class="grid-2" style="gap:14px;">
                <div class="form-group">
                    <label class="form-label">Reference link</label>
                    <input type="url" class="form-control" name="submission_link" placeholder="https://...">
                </div>
                <div class="form-group">
                    <label class="form-label">Upload file</label>
                    <input type="file" class="form-control" name="submission_file">
                </div>
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <button type="submit" class="btn btn-primary"><i class="fa fa-check"></i> Submit Now</button>
                <button type="submit" formaction="{{ path('portal_assignments') }}" name="action" value="save_draft" class="btn btn-outline"><i class="fa fa-save"></i> Save Draft</button>
                <button type="submit" formaction="{{ path('portal_assignments') }}" name="action" value="run_plagiarism_check" class="btn btn-outline"><i class="fa fa-search"></i> Check Plagiarism</button>
            </div>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-diamond" style="color:#7c3aed;margin-right:6px;"></i>Premium Submission Tools</span>
            <form method="post" action="{{ path('portal_assignments') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('student_refresh_countdowns') }}">
                <input type="hidden" name="action" value="refresh_countdowns">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        <div style="padding:10px;background:#f5f3ff;border-radius:8px;margin-bottom:10px;">
            <div style="font-size:12px;color:#475569;"><strong>Auto-save:</strong> {{ draftStatus.autosave }}</div>
            <div style="font-size:12px;color:#475569;margin-top:4px;"><strong>Last saved:</strong> {{ draftStatus.lastSavedAt }}</div>
            <div style="font-size:12px;color:#475569;margin-top:4px;"><strong>Draft words:</strong> {{ draftStatus.currentDraftWords }}</div>
            <div style="font-size:12px;color:#475569;margin-top:4px;"><strong>Latest similarity:</strong> {{ draftStatus.lastCheckedSimilarity }}</div>
        </div>
        {% for item in deadlineCountdowns %}
        <div style="padding:8px;border-left:4px solid {{ item.urgency == 'high' ? '#ef4444' : (item.urgency == 'medium' ? '#f59e0b' : '#22c55e') }};background:#f8fafc;border-radius:6px;margin-bottom:8px;">
            <div style="font-size:12px;font-weight:700;">{{ item.assignment }}</div>
            <div style="font-size:11px;color:#64748b;margin-top:3px;">Countdown: {{ item.countdown }}</div>
        </div>
        {% endfor %}
    </div>
</div>

{# ── Overdue ── #}
{% if overdue|length > 0 %}
<div class="card" style="margin-bottom:20px;border-left:4px solid #ef4444;">
    <div class="card-header">
        <span class="card-title" style="color:#dc2626;"><i class="fa fa-exclamation-triangle"></i> Overdue Assignments</span>
    </div>
    {% for a in overdue %}
    <div style="padding:14px;background:#fef2f2;border-radius:8px;margin-bottom:8px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">
            <div>
                <div style="font-size:14px;font-weight:700;color:#b91c1c;">{{ a.title }}</div>
                <div style="font-size:12px;color:#64748b;margin-top:3px;">{{ a.course }} &middot; Due: {{ a.due }} &middot; {{ a.points }} pts</div>
            </div>
            <div>
                <span class="badge badge-danger">Overdue</span>
                <form method="post" action="{{ path('portal_assignment_submit', {id: a.id}) }}" style="display:inline-block;margin-left:6px;">
                    <input type="hidden" name="_token" value="{{ csrf_token('submit_'~a.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm"><i class="fa fa-upload"></i> Submit Late</button>
                </form>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ── Pending ── #}
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-clock-o" style="color:#f59e0b;margin-right:6px;"></i>Pending Assignments</span>
    </div>
    <table class="portal-table">
        <thead><tr><th>Assignment</th><th>Course</th><th>Details & Deadline</th><th>Points</th><th>Action</th></tr></thead>
        <tbody>
            {% for a in pending %}
            <tr>
                <td class="fw-bold" style="font-size:13px;">{{ a.title }}</td>
                <td style="font-size:12px;color:#64748b;">{{ a.course }}</td>
                <td style="font-size:13px;">
                    <div>Due {{ a.due }}</div>
                    <div style="font-size:11px;color:#64748b;margin-top:2px;">Status: {{ a.status|capitalize }}</div>
                </td>
                <td><span class="badge badge-secondary">{{ a.points }} pts</span></td>
                <td>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;">
                        <form method="post" action="{{ path('portal_assignment_submit', {id: a.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('submit_'~a.id) }}">
                            <button type="submit" class="btn btn-primary btn-sm"><i class="fa fa-upload"></i> Submit</button>
                        </form>
                        <form method="post" action="{{ path('portal_assignments') }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('edit_submit_'~a.id) }}">
                            <input type="hidden" name="action" value="edit_submission">
                            <button type="submit" class="btn btn-outline btn-sm"><i class="fa fa-pencil"></i> Edit</button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="text-muted" style="text-align:center;padding:20px;">All caught up! No pending assignments.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# ── Graded / Past ── #}
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-check-circle" style="color:#22c55e;margin-right:6px;"></i>Graded Assignments</span>
    </div>
    <table class="portal-table">
        <thead><tr><th>Assignment</th><th>Course</th><th>Score</th><th>Feedback</th></tr></thead>
        <tbody>
            {% for a in graded %}
            <tr>
                <td class="fw-bold" style="font-size:13px;">{{ a.title }}</td>
                <td style="font-size:12px;color:#64748b;">{{ a.course }}</td>
                <td>
                    <span class="badge badge-success">{{ a.score }}/{{ a.points }}</span>
                    <span style="font-size:12px;color:#64748b;margin-left:4px;">({{ ((a.score / a.points) * 100)|round }}%)</span>
                </td>
                <td style="font-size:12px;color:#0369a1;">
                    {% if a.feedback %}<i class="fa fa-comment-o"></i> {{ a.feedback }}{% else %}–{% endif %}
                </td>
            </tr>
            {% endfor %}
            {% for a in submitted %}
            <tr>
                <td class="fw-bold" style="font-size:13px;">{{ a.title }}</td>
                <td style="font-size:12px;color:#64748b;">{{ a.course }}</td>
                <td><span class="badge badge-info">Awaiting grade</span></td>
                <td style="font-size:12px;color:#64748b;">–</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-history" style="color:#2563eb;margin-right:6px;"></i>Submission History & Receipts</span>
    </div>
    <table class="portal-table">
        <thead><tr><th>Assignment</th><th>Submitted</th><th>Version</th><th>Status</th><th>Feedback / Grade</th><th>Receipt</th><th></th></tr></thead>
        <tbody>
            {% for item in submissionHistory %}
            <tr>
                <td>
                    <div style="font-size:13px;font-weight:700;">{{ item.assignment }}</div>
                    <div style="font-size:11px;color:#64748b;margin-top:2px;">{{ item.course }} &middot; {{ item.method }}</div>
                </td>
                <td style="font-size:12px;color:#475569;">{{ item.submittedAt }}</td>
                <td><span class="badge badge-secondary">{{ item.version|upper }}</span></td>
                <td>
                    <span class="badge badge-{{ item.status == 'graded' ? 'success' : (item.status == 'submitted' ? 'info' : 'warning') }}">{{ item.status|capitalize }}</span>
                </td>
                <td style="font-size:12px;">
                    {% if item.grade %}
                    <div style="font-weight:700;color:#16a34a;">{{ item.grade }}</div>
                    {% endif %}
                    <div style="color:#0369a1;margin-top:2px;">{{ item.feedback }}</div>
                </td>
                <td style="font-size:12px;color:#475569;">{{ item.receipt }}</td>
                <td>
                    <div style="display:flex;gap:6px;flex-wrap:wrap;">
                        <form method="post" action="{{ path('portal_assignments') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('receipt_'~item.assignmentId) }}">
                            <input type="hidden" name="action" value="download_receipt">
                            <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-download"></i></button>
                        </form>
                        {% if item.canEdit %}
                        <form method="post" action="{{ path('portal_assignments') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('resubmit_'~item.assignmentId) }}">
                            <input type="hidden" name="action" value="resubmit_submission">
                            <button class="btn btn-outline btn-sm" type="submit">Resubmit</button>
                        </form>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
