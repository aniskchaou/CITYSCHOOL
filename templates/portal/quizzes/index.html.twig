{% extends 'portal/base.html.twig' %}

{% block title %}Quizzes & Tests{% endblock %}
{% block page_title %}Quizzes & Tests{% endblock %}

{% block content %}

{% set upcoming = quizzes|filter(q => q.status == 'upcoming') %}
{% set completed = quizzes|filter(q => q.status == 'completed') %}

{# ── Upcoming Quizzes ── #}
<div class="page-header">
    <div><h1>Upcoming Quizzes</h1><p>{{ upcoming|length }} quiz(es) scheduled</p></div>
</div>

<div class="grid-auto" style="margin-bottom:28px;">
    {% for q in upcoming %}
    <div class="quiz-card">
        <div class="quiz-card-header">
            <div>
                <div class="quiz-title">{{ q.title }}</div>
                <div style="font-size:12px;color:#64748b;margin-top:3px;">{{ q.course }}</div>
            </div>
            <span class="badge badge-info">Upcoming</span>
        </div>
        <div class="quiz-meta">
            <span><i class="fa fa-clock-o"></i> {{ q.duration }} min</span>
            <span><i class="fa fa-question-circle"></i> {{ q.questions }} questions</span>
            <span><i class="fa fa-calendar"></i> Opens: {{ q.opens }}</span>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-top:10px;border-top:1px solid #e2e8f0;">
            <span style="font-size:12px;color:#64748b;"><i class="fa fa-hourglass-end"></i> Closes: {{ q.closes }}</span>
            <form method="post" action="{{ path('portal_quizzes') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('start_quiz_'~q.id) }}">
                <input type="hidden" name="action" value="start_quiz">
                <button class="btn btn-primary btn-sm" type="submit"><i class="fa fa-pencil"></i> Start Quiz</button>
            </form>
        </div>
    </div>
    {% endfor %}
</div>

{# ── Completed Quizzes ── #}
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-check-circle" style="color:#22c55e;margin-right:6px;"></i>Completed Quizzes</span>
    </div>
    <table class="portal-table">
        <thead><tr><th>Quiz</th><th>Course</th><th>Duration</th><th>Score</th><th>Grade</th></tr></thead>
        <tbody>
            {% for q in completed %}
            <tr>
                <td class="fw-bold" style="font-size:13px;">{{ q.title }}</td>
                <td style="font-size:12px;color:#64748b;">{{ q.course }}</td>
                <td style="font-size:12px;">{{ q.duration }} min / {{ q.questions }} qs</td>
                <td>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div class="progress-bar-wrap" style="width:80px;">
                            <div class="progress-bar-fill" style="width:{{ q.score }}%;background:{% if q.score >= 90 %}#22c55e{% elseif q.score >= 75 %}#f59e0b{% else %}#ef4444{% endif %};"></div>
                        </div>
                        <span style="font-size:13px;font-weight:700;">{{ q.score }}%</span>
                    </div>
                </td>
                <td>
                    <span class="badge badge-{% if q.score >= 90 %}success{% elseif q.score >= 75 %}primary{% else %}warning{% endif %}">
                        {% if q.score >= 90 %}A{% elseif q.score >= 80 %}B{% elseif q.score >= 70 %}C{% else %}D{% endif %}
                    </span>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="grid-2" style="gap:20px;margin-top:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-check-square-o" style="color:#2563eb;margin-right:6px;"></i>Review Answers (Correct / Incorrect)</span>
            <form method="post" action="{{ path('portal_quizzes') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('review_answers') }}">
                <input type="hidden" name="action" value="review_answers">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        {% for review in quizReviews %}
        <div style="padding:10px;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:8px;">
            <div style="font-size:13px;font-weight:700;">{{ review.quiz }}</div>
            <div style="font-size:11px;color:#64748b;margin-top:2px;">{{ review.course }}</div>
            <div style="display:flex;gap:12px;margin-top:6px;font-size:12px;">
                <span style="color:#16a34a;"><i class="fa fa-check"></i> Correct: {{ review.correct }}</span>
                <span style="color:#dc2626;"><i class="fa fa-times"></i> Incorrect: {{ review.incorrect }}</span>
            </div>
            <div style="font-size:11px;color:#475569;margin-top:6px;">Weak topics: {{ review.weakTopics|join(', ') }}</div>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-flask" style="color:#0ea5e9;margin-right:6px;"></i>Practice with Mock Tests</span>
        </div>
        {% for test in mockTests %}
        <div style="padding:10px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;gap:8px;align-items:center;">
            <div>
                <div style="font-size:13px;font-weight:700;">{{ test.title }}</div>
                <div style="font-size:11px;color:#64748b;margin-top:2px;">{{ test.course }} &middot; {{ test.questions }} questions</div>
            </div>
            <form method="post" action="{{ path('portal_quizzes') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('start_mock_'~loop.index) }}">
                <input type="hidden" name="action" value="start_mock">
                <button class="btn btn-outline btn-sm" type="submit">Start</button>
            </form>
        </div>
        {% endfor %}
    </div>
</div>

<div class="grid-2" style="gap:20px;margin-top:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-diamond" style="color:#7c3aed;margin-right:6px;"></i>Premium: Adaptive + Exam Simulation</span>
        </div>
        <div style="padding:10px;background:#f5f3ff;border-radius:8px;margin-bottom:10px;">
            <div style="font-size:12px;color:#475569;"><strong>Status:</strong> {{ adaptivePlan.status }}</div>
            <div style="font-size:12px;color:#475569;margin-top:3px;"><strong>Level:</strong> {{ adaptivePlan.currentLevel }}</div>
            <div style="font-size:12px;color:#475569;margin-top:3px;">{{ adaptivePlan.nextAdjustment }}</div>
            <form method="post" action="{{ path('portal_quizzes') }}" style="margin-top:10px;">
                <input type="hidden" name="_token" value="{{ csrf_token('start_adaptive') }}">
                <input type="hidden" name="action" value="start_adaptive">
                <button class="btn btn-outline btn-sm" type="submit">Start Adaptive Quiz</button>
            </form>
        </div>
        {% for sim in examSimulations %}
        <div style="padding:9px;border:1px solid #e2e8f0;border-radius:6px;margin-bottom:8px;display:flex;justify-content:space-between;gap:8px;align-items:center;">
            <div>
                <div style="font-size:12px;font-weight:700;">{{ sim.name }}</div>
                <div style="font-size:11px;color:#64748b;">{{ sim.duration }} min &middot; {{ sim.rules }}</div>
            </div>
            <form method="post" action="{{ path('portal_quizzes') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('sim_'~loop.index) }}">
                <input type="hidden" name="action" value="start_exam_simulation">
                <button class="btn btn-outline btn-sm" type="submit">Start</button>
            </form>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-bar-chart" style="color:#16a34a;margin-right:6px;"></i>Premium: Performance & Question Bank</span>
            <form method="post" action="{{ path('portal_quizzes') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('refresh_breakdown') }}">
                <input type="hidden" name="action" value="refresh_breakdown">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        {% for row in performanceByTopic %}
        <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;">
                <span>{{ row.topic }}</span>
                <span>{{ row.accuracy }}%</span>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:{{ row.accuracy }}%;background:{{ row.trend == 'down' ? '#ef4444' : (row.trend == 'steady' ? '#f59e0b' : '#22c55e') }};"></div>
            </div>
        </div>
        {% endfor %}
        <div style="padding-top:10px;border-top:1px solid #e2e8f0;">
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">Revision Question Bank</div>
            {% for bank in questionBank %}
            <div style="font-size:12px;color:#475569;margin-bottom:6px;"><i class="fa fa-bookmark-o" style="color:#2563eb;margin-right:5px;"></i>{{ bank.topic }}: {{ bank.questions }} questions ({{ bank.difficulty }})</div>
            {% endfor %}
            <form method="post" action="{{ path('portal_quizzes') }}" style="margin-top:10px;">
                <input type="hidden" name="_token" value="{{ csrf_token('open_qbank') }}">
                <input type="hidden" name="action" value="open_question_bank">
                <button class="btn btn-outline btn-sm" type="submit">Open Question Bank</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}
