{% extends 'portal/base.html.twig' %}

{% block title %}My Progress{% endblock %}
{% block page_title %}Progress & Analytics{% endblock %}

{% block content %}

{# ── Overall Stats ── #}
<div class="stats-grid" style="margin-bottom:24px;">
    <div class="stat-card">
        <div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-star"></i></div>
        <div><div class="stat-value">{{ student.gpa }}</div><div class="stat-label">GPA</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-line-chart"></i></div>
        <div><div class="stat-value">+15%</div><div class="stat-label">vs Last Semester</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="fa fa-trophy"></i></div>
        <div><div class="stat-value">#{{ student.rank }}</div><div class="stat-label">Class Rank</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fef9c3;color:#a16207;"><i class="fa fa-calendar-check-o"></i></div>
        <div><div class="stat-value">{{ student.attendance }}%</div><div class="stat-label">Attendance</div></div>
    </div>
</div>

<div class="grid-2" style="margin-bottom:24px;gap:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-check-square-o" style="color:#2563eb;margin-right:6px;"></i>Track Completed Tasks</span>
            <form method="post" action="{{ path('portal_progress') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('progress_completed') }}">
                <input type="hidden" name="action" value="refresh_completed_tasks">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        {% for task in completedTasks %}
        <div style="padding:8px;border-bottom:1px solid #e2e8f0;">
            <div style="font-size:13px;font-weight:700;">{{ task.task }}</div>
            <div style="font-size:11px;color:#64748b;">{{ task.subject }} &middot; {{ task.completedAt }}</div>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-clock-o" style="color:#16a34a;margin-right:6px;"></i>Study Time & Goals</span>
            <form method="post" action="{{ path('portal_progress') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('progress_study') }}">
                <input type="hidden" name="action" value="refresh_study_time">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        {% for row in studyTime %}
        <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;">
                <span>{{ row.subject }}</span>
                <span>{{ row.minutes }} min</span>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:{{ (row.minutes / 240 * 100)|round }}%;background:#22c55e;"></div>
            </div>
        </div>
        {% endfor %}
        <div style="padding-top:8px;border-top:1px solid #e2e8f0;">
            <div style="font-size:12px;font-weight:700;margin-bottom:6px;">Goal Monitor</div>
            {% for goal in goals %}
            <div style="font-size:12px;color:#475569;margin-bottom:5px;"><i class="fa fa-bullseye" style="color:#7c3aed;margin-right:5px;"></i>{{ goal.subject }}: target {{ goal.targetGrade }}, current {{ goal.currentScore }}%</div>
            {% endfor %}
            <form method="post" action="{{ path('portal_progress') }}" style="margin-top:8px;">
                <input type="hidden" name="_token" value="{{ csrf_token('progress_goals') }}">
                <input type="hidden" name="action" value="refresh_goals">
                <button class="btn btn-outline btn-sm" type="submit">Refresh Goals</button>
            </form>
        </div>
    </div>
</div>

{# ── Weekly Performance Chart ── #}
<div class="card" style="margin-bottom:24px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-bar-chart" style="color:#4361ee;margin-right:6px;"></i>Weekly Performance (Last 8 Weeks)</span>
    </div>
    <div class="bar-chart">
        {% for w in weekly %}
        <div class="bar-wrap">
            <div class="bar" data-val="{{ w.score }}" style="height:{{ w.score }}%;background:{% if w.score >= 85 %}#22c55e{% elseif w.score >= 70 %}#4361ee{% else %}#f59e0b{% endif %};"></div>
            <div class="bar-label">{{ w.week|split(' ')|last }}</div>
        </div>
        {% endfor %}
    </div>
    <div style="display:flex;justify-content:center;gap:20px;margin-top:12px;font-size:12px;">
        <span style="display:flex;align-items:center;gap:5px;"><span style="width:12px;height:12px;border-radius:2px;background:#22c55e;display:inline-block;"></span>≥85% (Excellent)</span>
        <span style="display:flex;align-items:center;gap:5px;"><span style="width:12px;height:12px;border-radius:2px;background:#4361ee;display:inline-block;"></span>70–84% (Good)</span>
        <span style="display:flex;align-items:center;gap:5px;"><span style="width:12px;height:12px;border-radius:2px;background:#f59e0b;display:inline-block;"></span>&lt;70% (Needs Work)</span>
    </div>
</div>

<div class="grid-2" style="margin-bottom:24px;gap:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-diamond" style="color:#7c3aed;margin-right:6px;"></i>Premium Productivity</span>
            <form method="post" action="{{ path('portal_progress') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('progress_streaks') }}">
                <input type="hidden" name="action" value="refresh_streaks">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
            <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:10px;">
                <div style="font-size:18px;font-weight:800;color:#7c3aed;">{{ streaks.studyStreakDays }}</div>
                <div style="font-size:10px;color:#64748b;">Study Streak (days)</div>
            </div>
            <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:10px;">
                <div style="font-size:18px;font-weight:800;color:#0891b2;">{{ streaks.tasksCompletedThisWeek }}</div>
                <div style="font-size:10px;color:#64748b;">Tasks This Week</div>
            </div>
            <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:10px;">
                <div style="font-size:12px;font-weight:800;color:#16a34a;">{{ streaks.motivationBadge }}</div>
                <div style="font-size:10px;color:#64748b;">Motivation Badge</div>
            </div>
        </div>
        <form method="post" action="{{ path('portal_progress') }}" style="margin-top:10px;">
            <input type="hidden" name="_token" value="{{ csrf_token('progress_stats') }}">
            <input type="hidden" name="action" value="refresh_productivity_stats">
            <button class="btn btn-outline btn-sm" type="submit">Refresh Stats</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-file-text-o" style="color:#f59e0b;margin-right:6px;"></i>Premium Weekly Summary</span>
            <form method="post" action="{{ path('portal_progress') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('progress_weekly_summary') }}">
                <input type="hidden" name="action" value="refresh_weekly_summary">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        <div style="padding:10px;background:#fffbeb;border-radius:8px;font-size:12px;color:#475569;margin-bottom:10px;">{{ weeklySummary.summary }}</div>
        {% for item in weeklySummary.highlights %}
        <div style="font-size:12px;color:#475569;margin-bottom:6px;"><i class="fa fa-check-circle" style="color:#16a34a;margin-right:5px;"></i>{{ item }}</div>
        {% endfor %}
    </div>
</div>

{# ── Per Subject Progress ── #}
<div class="grid-2" style="margin-bottom:24px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-book" style="color:#7c3aed;margin-right:6px;"></i>Subject Performance</span>
        </div>
        {% for course in courses %}
        <div style="margin-bottom:14px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
                <span style="font-size:13px;font-weight:600;">{{ course.name }}</span>
                <div style="display:flex;align-items:center;gap:8px;">
                    <span class="badge badge-{% if course.grade starts with 'A' %}success{% elseif course.grade starts with 'B' %}primary{% else %}warning{% endif %}">{{ course.grade }}</span>
                    <span style="font-size:12px;color:#64748b;">{{ course.score }}%</span>
                </div>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:{{ course.score }}%;background:{{ course.color }};height:10px;"></div>
            </div>
        </div>
        {% endfor %}
    </div>

    {# Smart Suggestions #}
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-lightbulb-o" style="color:#f59e0b;margin-right:6px;"></i>Personalized Study Tips</span>
        </div>
        {% for s in suggestions %}
        <div class="reminder-item reminder-{% if s.priority == 'high' %}danger{% elseif s.priority == 'medium' %}warning{% else %}info{% endif %}" style="margin-bottom:10px;border-radius:10px;flex-direction:column;align-items:flex-start;gap:4px;">
            <div style="display:flex;align-items:center;gap:8px;font-weight:700;">
                <i class="fa fa-{% if s.priority == 'high' %}exclamation-triangle{% elseif s.priority == 'medium' %}bell{% else %}check-circle{% endif %}"></i>
                {{ s.subject }}
                <span class="badge badge-{% if s.priority == 'high' %}danger{% elseif s.priority == 'medium' %}warning{% else %}success{% endif %}" style="font-size:10px;">{{ s.priority|upper }}</span>
            </div>
            <div style="font-size:13px;padding-left:20px;">{{ s.tip }}</div>
        </div>
        {% endfor %}

        <div style="margin-top:14px;padding:14px;background:#f1f5f9;border-radius:10px;">
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;"><i class="fa fa-clock-o" style="color:#4361ee;margin-right:5px;"></i>Recommended Study Schedule</div>
            <ul style="list-style:none;font-size:13px;color:#475569;">
                <li style="padding:3px 0;"><i class="fa fa-circle" style="font-size:6px;margin-right:8px;color:#4361ee;"></i>History — 45 min/day (focus)</li>
                <li style="padding:3px 0;"><i class="fa fa-circle" style="font-size:6px;margin-right:8px;color:#4361ee;"></i>Physics — 30 min/day (review)</li>
                <li style="padding:3px 0;"><i class="fa fa-circle" style="font-size:6px;margin-right:8px;color:#4361ee;"></i>Mathematics — 20 min/day (practice)</li>
            </ul>
        </div>
    </div>
</div>

{# ── Achievements ── #}
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-trophy" style="color:#f59e0b;margin-right:6px;"></i>Achievements & Badges</span>
    </div>
    <div style="display:flex;gap:16px;flex-wrap:wrap;padding:8px 0;">
        {% for badge in [
            {icon: 'star',         label: 'Honor Roll',        color: '#f59e0b', earned: true},
            {icon: 'check-circle', label: 'Perfect Week',       color: '#22c55e', earned: true},
            {icon: 'fire',         label: 'Study Streak 7d',    color: '#f97316', earned: true},
            {icon: 'graduation-cap', label: 'CS Expert',        color: '#7c3aed', earned: true},
            {icon: 'users',        label: 'Team Player',        color: '#4361ee', earned: false},
            {icon: 'bolt',         label: 'Speed Reader',       color: '#ef4444', earned: false},
        ] %}
        <div style="text-align:center;opacity:{% if badge.earned %}1{% else %}0.35{% endif %};">
            <div style="width:56px;height:56px;border-radius:14px;background:{% if badge.earned %}{{ badge.color }}{% else %}#e2e8f0{% endif %};display:flex;align-items:center;justify-content:center;font-size:22px;color:#fff;margin:0 auto 6px;">
                <i class="fa fa-{{ badge.icon }}"></i>
            </div>
            <div style="font-size:11px;color:#475569;font-weight:600;max-width:64px;">{{ badge.label }}</div>
        </div>
        {% endfor %}
    </div>
</div>

{% endblock %}
