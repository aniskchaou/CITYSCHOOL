{% extends 'portal/base.html.twig' %}

{% block title %}Gamification{% endblock %}
{% block page_title %}Gamification & Achievements{% endblock %}

{% block content %}

<div class="grid-2" style="gap:20px;margin-bottom:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-trophy" style="color:#f59e0b;margin-right:6px;"></i>Badges & Achievements</span>
            <form method="post" action="{{ path('portal_gamification') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('refresh_badges') }}">
                <input type="hidden" name="action" value="refresh_badges">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            {% for badge in badges %}
            <div style="text-align:center;opacity:{{ badge.earned ? '1' : '0.35' }};">
                <div style="width:56px;height:56px;border-radius:12px;background:{{ badge.earned ? '#f59e0b' : '#e2e8f0' }};display:flex;align-items:center;justify-content:center;color:#fff;font-size:22px;margin:0 auto 6px;">
                    <i class="fa fa-{{ badge.icon }}"></i>
                </div>
                <div style="font-size:11px;color:#475569;font-weight:600;max-width:80px;">{{ badge.name }}</div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-flag-checkered" style="color:#2563eb;margin-right:6px;"></i>Milestones & Challenges</span>
            <form method="post" action="{{ path('portal_gamification') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('refresh_milestones') }}">
                <input type="hidden" name="action" value="refresh_milestones">
                <button class="btn btn-sm btn-outline" type="submit">Refresh</button>
            </form>
        </div>
        {% for milestone in milestones %}
        <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:3px;">
                <span>{{ milestone.title }}</span>
                <span>{{ milestone.progress }}%</span>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:{{ milestone.progress }}%;background:#4361ee;"></div>
            </div>
        </div>
        {% endfor %}

        <div style="font-size:13px;font-weight:700;margin:10px 0 8px 0;">Participate in challenges</div>
        {% for c in challenges %}
        <div style="padding:8px;border:1px solid #e2e8f0;border-radius:6px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;gap:8px;">
            <div>
                <div style="font-size:12px;font-weight:700;">{{ c.name }}</div>
                <div style="font-size:11px;color:#64748b;">Reward: {{ c.reward }}</div>
            </div>
            <form method="post" action="{{ path('portal_gamification') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('join_challenge_'~loop.index) }}">
                <input type="hidden" name="action" value="join_challenge">
                <button class="btn btn-outline btn-sm" type="submit">{{ c.status|capitalize }}</button>
            </form>
        </div>
        {% endfor %}
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-diamond" style="color:#7c3aed;margin-right:6px;"></i>Premium Motivation System</span>
    </div>
    <div class="grid-2" style="gap:20px;">
        <div>
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">Leaderboard (optional)</div>
            <table class="portal-table">
                <thead><tr><th>Rank</th><th>Name</th><th>Points</th></tr></thead>
                <tbody>
                    {% for row in leaderboard %}
                    <tr>
                        <td style="font-size:12px;font-weight:700;">#{{ row.rank }}</td>
                        <td style="font-size:12px;color:#475569;">{{ row.name }}</td>
                        <td><span class="badge badge-primary">{{ row.points }}</span></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            <form method="post" action="{{ path('portal_gamification') }}" style="margin-top:8px;">
                <input type="hidden" name="_token" value="{{ csrf_token('refresh_leaderboard') }}">
                <input type="hidden" name="action" value="refresh_leaderboard">
                <button class="btn btn-outline btn-sm" type="submit">Refresh Leaderboard</button>
            </form>
        </div>

        <div>
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">Reward system (points & levels)</div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:10px;">
                <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:10px;">
                    <div style="font-size:18px;font-weight:800;color:#7c3aed;">{{ rewardProfile.points }}</div>
                    <div style="font-size:10px;color:#64748b;">Points</div>
                </div>
                <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:10px;">
                    <div style="font-size:18px;font-weight:800;color:#16a34a;">{{ rewardProfile.level }}</div>
                    <div style="font-size:10px;color:#64748b;">Level</div>
                </div>
                <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:10px;">
                    <div style="font-size:12px;font-weight:800;color:#0891b2;">{{ rewardProfile.nextLevelAt }}</div>
                    <div style="font-size:10px;color:#64748b;">Next Level</div>
                </div>
            </div>
            <div style="padding:10px;background:#f5f3ff;border-radius:8px;font-size:12px;color:#475569;">{{ rewardProfile.motivation }}</div>
            <div style="display:flex;gap:8px;margin-top:10px;">
                <form method="post" action="{{ path('portal_gamification') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('refresh_rewards') }}">
                    <input type="hidden" name="action" value="refresh_rewards">
                    <button class="btn btn-outline btn-sm" type="submit">Refresh Rewards</button>
                </form>
                <form method="post" action="{{ path('portal_gamification') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('refresh_motivation') }}">
                    <input type="hidden" name="action" value="refresh_motivation">
                    <button class="btn btn-outline btn-sm" type="submit">Motivation Boost</button>
                </form>
            </div>
        </div>
    </div>
</div>

{% endblock %}