{% extends 'portal/base.html.twig' %}

{% block title %}Resources{% endblock %}
{% block page_title %}File & Resource Management{% endblock %}

{% block content %}

<div class="grid-2" style="gap:20px;margin-bottom:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-upload" style="color:#2563eb;margin-right:6px;"></i>Upload & Download Files</span>
        </div>
        <form method="post" action="{{ path('portal_resources') }}" enctype="multipart/form-data" style="margin-bottom:12px;">
            <input type="hidden" name="_token" value="{{ csrf_token('upload_resource_file') }}">
            <input type="hidden" name="action" value="upload_resource_file">
            <div class="grid-2" style="gap:10px;">
                <div class="form-group">
                    <label class="form-label">File title</label>
                    <input class="form-control" type="text" name="title" placeholder="My revision notes">
                </div>
                <div class="form-group">
                    <label class="form-label">Upload</label>
                    <input class="form-control" type="file" name="file">
                </div>
            </div>
            <button class="btn btn-primary" type="submit"><i class="fa fa-send"></i> Upload</button>
        </form>

        <table class="portal-table">
            <thead><tr><th>File</th><th>Subject</th><th>Size</th><th></th></tr></thead>
            <tbody>
                {% for file in resourceFiles %}
                <tr>
                    <td>
                        <div style="font-size:13px;font-weight:700;">{{ file.name }}</div>
                        <div style="font-size:11px;color:#64748b;">Updated {{ file.updated }}</div>
                    </td>
                    <td style="font-size:12px;color:#475569;">{{ file.subject }}</td>
                    <td style="font-size:12px;color:#64748b;">{{ file.size }}</td>
                    <td>
                        <form method="post" action="{{ path('portal_resources') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('download_resource_'~loop.index) }}">
                            <input type="hidden" name="action" value="download_resource_file">
                            <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-download"></i></button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-sticky-note-o" style="color:#16a34a;margin-right:6px;"></i>Organize Notes & Shared Resources</span>
            <form method="post" action="{{ path('portal_resources') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('organize_notes') }}">
                <input type="hidden" name="action" value="organize_notes">
                <button class="btn btn-sm btn-outline" type="submit">Organize</button>
            </form>
        </div>
        {% for note in notesCollection %}
        <div style="padding:8px;border-bottom:1px solid #e2e8f0;">
            <div style="font-size:12px;font-weight:700;">{{ note.title }}</div>
            <div style="font-size:11px;color:#64748b;">{{ note.subject }} &middot; {{ note.tag }}</div>
        </div>
        {% endfor %}

        <div style="font-size:13px;font-weight:700;margin:10px 0 8px 0;">Access shared resources</div>
        {% for item in sharedResources %}
        <div style="font-size:12px;color:#475569;margin-bottom:6px;"><i class="fa fa-share-alt" style="color:#0ea5e9;margin-right:5px;"></i>{{ item.title }} ({{ item.subject }}) by {{ item.owner }}</div>
        {% endfor %}
        <form method="post" action="{{ path('portal_resources') }}" style="margin-top:8px;">
            <input type="hidden" name="_token" value="{{ csrf_token('open_shared_resources') }}">
            <input type="hidden" name="action" value="open_shared_resources">
            <button class="btn btn-outline btn-sm" type="submit">Refresh Shared</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-diamond" style="color:#7c3aed;margin-right:6px;"></i>Premium Resource Tools</span>
    </div>
    <div class="grid-2" style="gap:20px;">
        <div>
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">Cloud integration</div>
            {% for cloud in cloudIntegrations %}
            <div style="padding:8px;border:1px solid #e2e8f0;border-radius:6px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;">
                <span style="font-size:12px;">{{ cloud.name }}</span>
                <form method="post" action="{{ path('portal_resources') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('connect_cloud_'~loop.index) }}">
                    <input type="hidden" name="action" value="connect_cloud">
                    <button class="btn btn-outline btn-sm" type="submit">{{ cloud.connected ? 'Re-sync' : 'Connect' }}</button>
                </form>
            </div>
            {% endfor %}
        </div>

        <div>
            <div style="font-size:13px;font-weight:700;margin-bottom:8px;">Smart search & auto folders</div>
            <form method="post" action="{{ path('portal_resources') }}" style="display:flex;gap:8px;margin-bottom:10px;">
                <input type="hidden" name="_token" value="{{ csrf_token('smart_search_notes') }}">
                <input type="hidden" name="action" value="smart_search_notes">
                <input class="form-control" type="text" name="query" placeholder="Find notes instantly...">
                <button class="btn btn-outline btn-sm" type="submit">Search</button>
            </form>
            {% for folder in subjectFolders %}
            <div style="font-size:12px;color:#475569;margin-bottom:6px;"><i class="fa fa-folder-o" style="color:#f59e0b;margin-right:5px;"></i>{{ folder.subject }} folder ({{ folder.files }} files)</div>
            {% endfor %}
            <form method="post" action="{{ path('portal_resources') }}" style="margin-top:8px;">
                <input type="hidden" name="_token" value="{{ csrf_token('refresh_subject_folders') }}">
                <input type="hidden" name="action" value="refresh_subject_folders">
                <button class="btn btn-outline btn-sm" type="submit">Auto-Organize Folders</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}