{% extends 'base.html.twig' %}

{% block title %}Why City School | Features, Benefits &amp; Pricing{% endblock %}

{% block stylesheets %}
<style>
/* ===== VALUES PAGE ===== */
.val-section     { padding:72px 0; }
.val-section-alt { padding:72px 0; background:#f7f9fc; }
.val-section-dark{ padding:72px 0; background:linear-gradient(135deg,#1a237e 0%,#283593 100%); color:#fff; }
.val-label { display:inline-block; background:#1a237e; color:#fff; font-size:.68rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase; padding:4px 14px; border-radius:20px; margin-bottom:14px; }
.val-label-light { background:rgba(255,255,255,.22); }
.val-title { font-family:'Arvo',serif; font-size:2rem; font-weight:700; color:#1a237e; margin:0 0 10px; line-height:1.2; }
.val-title-light { color:#fff; }
.val-sub { color:#6b7a99; font-size:.97rem; margin:0 0 40px; max-width:620px; line-height:1.7; }
.val-sub-light { color:rgba(255,255,255,.78); }
.val-center { text-align:center; }
.val-center .val-sub { margin-left:auto; margin-right:auto; }

/* ── HERO OVERRIDE ── */
.val-hero-slide .slide-caption h2 { font-size:2.3rem; }

/* ── QUICK ACTIONS BAR ── */
.val-actions-bar { background:linear-gradient(135deg,#1a237e 0%,#283593 60%,#3949ab 100%); padding:40px 0 34px; }
.val-actions-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:18px; }
@media(max-width:900px){ .val-actions-grid { grid-template-columns:repeat(2,1fr); } }
.val-action-card { background:rgba(255,255,255,.1); border:1.5px solid rgba(255,255,255,.18); border-radius:14px; padding:24px 18px; text-align:center; color:#fff; text-decoration:none; transition:background .2s,transform .2s; display:block; }
.val-action-card:hover { background:rgba(255,255,255,.2); transform:translateY(-4px); color:#fff; text-decoration:none; }
.val-action-icon { width:48px; height:48px; background:rgba(255,255,255,.15); border-radius:11px; display:flex; align-items:center; justify-content:center; margin:0 auto 12px; font-size:1.3rem; }
.val-action-card h4 { font-family:'Arvo',serif; font-size:.95rem; margin:0 0 5px; }
.val-action-card p  { font-size:.76rem; opacity:.82; margin:0; line-height:1.5; }

/* ── FEATURES ── */
.features-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
@media(max-width:960px){ .features-grid { grid-template-columns:repeat(2,1fr); } }
@media(max-width:540px){ .features-grid { grid-template-columns:1fr; } }
.feature-card { background:#fff; border-radius:16px; padding:30px 24px; box-shadow:0 4px 24px rgba(26,35,126,.07); border:1.5px solid #eef0fb; transition:transform .2s,box-shadow .2s; }
.feature-card:hover { transform:translateY(-6px); box-shadow:0 14px 40px rgba(26,35,126,.12); }
.feature-icon { width:56px; height:56px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.5rem; margin-bottom:18px; }
.feature-card h3 { font-family:'Arvo',serif; font-size:1rem; color:#1a237e; margin:0 0 8px; }
.feature-card p  { font-size:.83rem; color:#6b7a99; margin:0; line-height:1.6; }
.feature-tag { display:inline-flex; align-items:center; gap:4px; margin-top:14px; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; padding:3px 10px; border-radius:20px; }
.feature-tag.premium { background:#fce4ec; color:#c62828; }
.feature-tag.core    { background:#e8eaf6; color:#1a237e; }

/* ── BENEFITS ── */
.benefits-split { display:grid; grid-template-columns:1fr 1fr; gap:40px; align-items:center; }
@media(max-width:860px){ .benefits-split { grid-template-columns:1fr; } }
.benefit-list { display:flex; flex-direction:column; gap:20px; }
.benefit-item { display:flex; gap:16px; align-items:flex-start; }
.benefit-icon { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0; }
.benefit-item h4 { font-family:'Arvo',serif; font-size:.97rem; color:#1a237e; margin:0 0 4px; }
.benefit-item p  { font-size:.83rem; color:#6b7a99; margin:0; line-height:1.6; }
.benefit-visual { background:linear-gradient(135deg,#1a237e 0%,#3949ab 100%); border-radius:20px; padding:36px 30px; color:#fff; display:flex; flex-direction:column; gap:18px; }
.benefit-visual h3 { font-family:'Arvo',serif; font-size:1.3rem; margin:0 0 6px; }
.benefit-visual p  { font-size:.86rem; opacity:.82; margin:0; line-height:1.6; }
.benefit-stat-row { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; margin-top:8px; }
.benefit-stat { background:rgba(255,255,255,.12); border-radius:12px; padding:16px; text-align:center; }
.benefit-stat .bs-num  { font-size:1.7rem; font-weight:800; font-family:'Arvo',serif; line-height:1; }
.benefit-stat .bs-lbl  { font-size:.72rem; opacity:.78; margin-top:4px; }

/* ── PRICING ── */
.pricing-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; align-items:start; }
@media(max-width:900px){ .pricing-grid { grid-template-columns:1fr 1fr; } }
@media(max-width:560px){ .pricing-grid { grid-template-columns:1fr; } }
.pricing-card { background:#fff; border-radius:20px; padding:34px 28px; box-shadow:0 4px 24px rgba(26,35,126,.08); border:2px solid #eef0fb; position:relative; }
.pricing-card.featured { border-color:#1a237e; box-shadow:0 10px 40px rgba(26,35,126,.18); }
.pricing-badge { position:absolute; top:-14px; left:50%; transform:translateX(-50%); background:#1a237e; color:#fff; font-size:.68rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; padding:4px 18px; border-radius:20px; white-space:nowrap; }
.pricing-tier { font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.12em; color:#8a97b5; margin-bottom:8px; }
.pricing-name { font-family:'Arvo',serif; font-size:1.3rem; color:#1a237e; font-weight:700; margin:0 0 6px; }
.pricing-price { display:flex; align-items:flex-end; gap:4px; margin:14px 0 18px; }
.pricing-price .pp-currency { font-size:1.1rem; font-weight:700; color:#1a237e; padding-bottom:4px; }
.pricing-price .pp-amount   { font-size:2.6rem; font-weight:800; font-family:'Arvo',serif; color:#1a237e; line-height:1; }
.pricing-price .pp-period   { font-size:.78rem; color:#8a97b5; padding-bottom:6px; }
.pricing-desc { font-size:.83rem; color:#6b7a99; margin:0 0 22px; line-height:1.5; }
.pricing-features { list-style:none; padding:0; margin:0 0 26px; display:flex; flex-direction:column; gap:10px; }
.pricing-features li { font-size:.83rem; color:#445; display:flex; align-items:flex-start; gap:10px; }
.pricing-features li i { color:#1a237e; margin-top:1px; flex-shrink:0; }
.pricing-features li i.fa-times { color:#bbb; }
.pricing-features li.disabled { color:#bbb; }
.pricing-btn { display:block; text-align:center; padding:12px; border-radius:10px; font-weight:700; font-size:.88rem; text-decoration:none; transition:opacity .2s; }
.pricing-btn.primary { background:linear-gradient(135deg,#1a237e,#3949ab); color:#fff; }
.pricing-btn.outline { border:2px solid #1a237e; color:#1a237e; background:transparent; }
.pricing-btn:hover { opacity:.85; }
.pricing-note { text-align:center; margin-top:28px; font-size:.82rem; color:#8a97b5; }

/* ── TESTIMONIALS ── */
.testimonials-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:22px; }
@media(max-width:960px){ .testimonials-grid { grid-template-columns:repeat(2,1fr); } }
@media(max-width:540px){ .testimonials-grid { grid-template-columns:1fr; } }
.testi-card { background:#fff; border-radius:16px; padding:28px 24px; box-shadow:0 4px 22px rgba(26,35,126,.08); border:1.5px solid #eef0fb; position:relative; }
.testi-card::before { content:'\201C'; font-size:4rem; color:#e8eaf6; font-family:'Georgia',serif; line-height:1; position:absolute; top:14px; left:20px; }
.testi-stars { color:#f57f17; font-size:.88rem; margin-bottom:12px; }
.testi-text { font-size:.87rem; color:#445; line-height:1.7; margin:0 0 20px; font-style:italic; padding-top:14px; }
.testi-author { display:flex; align-items:center; gap:12px; }
.testi-avatar { width:42px; height:42px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:1rem; color:#fff; font-weight:800; }
.testi-name  { font-size:.87rem; font-weight:700; color:#1a237e; margin:0; }
.testi-role  { font-size:.74rem; color:#8a97b5; margin:0; }

/* ── CASE STUDIES ── */
.case-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:26px; }
@media(max-width:700px){ .case-grid { grid-template-columns:1fr; } }
.case-card { background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(26,35,126,.08); border:1.5px solid #eef0fb; display:flex; flex-direction:column; transition:transform .2s,box-shadow .2s; }
.case-card:hover { transform:translateY(-5px); box-shadow:0 14px 38px rgba(26,35,126,.13); }
.case-banner { height:130px; display:flex; align-items:center; justify-content:center; font-size:2.2rem; }
.case-body { padding:22px 22px 24px; flex:1; display:flex; flex-direction:column; }
.case-cat  { font-size:.66rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; padding:2px 10px; border-radius:20px; background:#e8eaf6; color:#1a237e; margin-bottom:10px; display:inline-block; }
.case-body h3 { font-family:'Arvo',serif; font-size:1rem; color:#1a237e; margin:0 0 8px; line-height:1.4; }
.case-body p  { font-size:.82rem; color:#6b7a99; line-height:1.6; flex:1; }
.case-result { display:flex; gap:16px; margin-top:16px; flex-wrap:wrap; }
.case-stat { text-align:center; }
.case-stat .cs-num { font-size:1.3rem; font-weight:800; font-family:'Arvo',serif; color:#1a237e; display:block; line-height:1; }
.case-stat .cs-lbl { font-size:.68rem; color:#8a97b5; }
.case-read { display:inline-flex; align-items:center; gap:5px; margin-top:16px; font-size:.78rem; font-weight:700; color:#1a237e; text-decoration:none; }
.case-read:hover { text-decoration:underline; }

/* ── COMPARISON ── */
.comparison-wrap { overflow-x:auto; }
.comparison-table { width:100%; border-collapse:collapse; font-size:.85rem; }
.comparison-table thead th { padding:14px 18px; font-family:'Arvo',serif; font-size:.85rem; color:#fff; font-weight:700; text-align:center; }
.comparison-table thead th:first-child { text-align:left; color:#6b7a99; background:#f7f9fc; }
.comparison-table thead th.hl { background:linear-gradient(135deg,#1a237e,#3949ab); border-radius:12px 12px 0 0; }
.comparison-table thead th.hl2 { background:#eef0fb; color:#1a237e; border-radius:12px 12px 0 0; }
.comparison-table tbody tr { border-bottom:1px solid #f0f2fc; }
.comparison-table tbody tr:last-child { border-bottom:none; }
.comparison-table tbody td { padding:13px 18px; color:#445; vertical-align:middle; }
.comparison-table tbody td:first-child { font-weight:600; color:#1a237e; }
.comparison-table tbody td { text-align:center; }
.comparison-table tbody td:first-child { text-align:left; }
.ct-yes  { color:#2e7d32; font-size:1.1rem; }
.ct-no   { color:#bbb; font-size:1.1rem; }
.ct-part { color:#f57f17; font-size:.8rem; font-weight:600; }
.ct-hl { background:#f0f2fc; }

/* ── CTA ── */
.val-cta-btn { display:inline-flex; align-items:center; gap:8px; background:#fff; color:#1a237e; padding:12px 28px; border-radius:10px; font-weight:800; font-size:.9rem; text-decoration:none; transition:opacity .2s; }
.val-cta-btn:hover { opacity:.9; color:#1a237e; }
.val-cta-btn.outline { background:transparent; border:2px solid rgba(255,255,255,.5); color:#fff; }
.val-cta-btn.outline:hover { background:rgba(255,255,255,.1); color:#fff; }
</style>
{% endblock %}

{% block body %}
<div id="site-content">

    <!-- ===== HEADER / NAV ===== -->
    <header class="site-header">
        <div class="primary-header">
            <div class="container">
                <a href="{{ path('index') }}" id="branding">
                    <img src="/images/logo.png" alt="City School">
                    <div>
                        <h1 class="site-title">City School</h1>
                        <span class="site-subtitle">Premium Learning Institution</span>
                    </div>
                </a>
                <div class="main-navigation">
                    <ul class="home-main-menu home-nav-v2">
                        <li class="home-nav-item"><a class="home-nav-link" href="{{ path('index') }}">Home</a></li>
                        <li class="home-nav-item"><a class="home-nav-link" href="{{ path('courses') }}">Courses</a></li>
                        <li class="home-nav-item current-menu-item"><a class="home-nav-link" href="{{ path('values') }}">Values</a></li>
                        <li class="home-nav-item"><a class="home-nav-link" href="{{ path('events') }}">Events</a></li>
                        <li class="home-nav-item"><a class="home-nav-link" href="{{ path('admissions') }}">Admissions</a></li>
                        <li class="home-nav-item"><a class="home-nav-link" href="{{ path('pricing') }}">Pricing</a></li>
                        <li class="home-nav-item"><a class="home-nav-link" href="{{ path('contact') }}">Contact</a></li>
                        <li class="home-nav-item nav-dropdown">
                            <a class="home-nav-link" href="#"><i class="fa fa-sign-in home-nav-login-icon"></i> Login <span class="arrow">&#9660;</span></a>
                            <ul class="dropdown-menu">
                                <li><a href="{{ path('portal_login') }}"><span class="dm-icon"><i class="fa fa-book"></i></span> Student Portal</a></li>
                                <li><a href="{{ path('teacher_login') }}"><span class="dm-icon"><i class="fa fa-sitemap"></i></span> Teacher Portal</a></li>
                                <li><a href="{{ path('parent_login') }}"><span class="dm-icon"><i class="fa fa-home"></i></span> Parent Portal</a></li>
                                <li><a href="{{ path('admin_login') }}"><span class="dm-icon"><i class="fa fa-cogs"></i></span> Admin Portal</a></li>
                                <li class="dropdown-divider"></li>
                                <li><a href="{{ path('super_admin_login') }}"><span class="dm-icon"><i class="fa fa-shield"></i></span> Super Admin</a></li>
                            </ul>
                        </li>
                        <li class="home-nav-item nav-lang-switcher">
                            <button class="lang-btn active" data-lang="en" onclick="switchLang('en')">EN</button>
                            <button class="lang-btn" data-lang="fr" onclick="switchLang('fr')">FR</button>
                            <button class="lang-btn" data-lang="es" onclick="switchLang('es')">ES</button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- HERO -->
        <div class="home-slider val-hero-slide">
            <div class="container">
                <div class="slide-caption">
                    <h2 class="slide-title">Everything a Great School<br>Should Offer — We Do</h2>
                    <p>Explore the features that make City School exceptional, the real benefits families experience, transparent pricing, and stories of lives changed through quality education.</p>
                    <div class="hero-cta-row">
                        <a href="#features" class="button large hero-btn hero-btn-programs"><i class="fa fa-star"></i> See Our Features</a>
                        <a href="#pricing" class="button large hero-btn hero-btn-consult"><i class="fa fa-tags"></i> View Pricing</a>
                    </div>
                </div>
                <div class="slider-img">
                    <img src="/dummy/kid.png" alt="Student at City School">
                </div>
            </div>
        </div>
    </header>
</div>

<main>

    <!-- ===== QUICK ACTION BAR ===== -->
    <div class="val-actions-bar">
        <div class="container">
            <div class="val-actions-grid">
                <a href="#features" class="val-action-card">
                    <div class="val-action-icon"><i class="fa fa-star"></i></div>
                    <h4>Features</h4>
                    <p>Discover every tool and capability the school offers.</p>
                </a>
                <a href="#benefits" class="val-action-card">
                    <div class="val-action-icon"><i class="fa fa-heart"></i></div>
                    <h4>Benefits</h4>
                    <p>Why parents and students choose — and stay with — us.</p>
                </a>
                <a href="#pricing" class="val-action-card">
                    <div class="val-action-icon"><i class="fa fa-tags"></i></div>
                    <h4>Pricing</h4>
                    <p>Clear, transparent tuition plans for every family.</p>
                </a>
                <a href="#testimonials" class="val-action-card">
                    <div class="val-action-icon"><i class="fa fa-quote-left"></i></div>
                    <h4>Success Stories</h4>
                    <p>Real results and testimonials from our community.</p>
                </a>
            </div>
        </div>
    </div>

    <!-- ===== SECTION 1: FEATURES ===== -->
    <section class="val-section" id="features">
        <div class="container">
            <div class="val-center">
                <span class="val-label">What We Offer</span>
                <h2 class="val-title">A Complete School Management &amp; Learning System</h2>
                <p class="val-sub">From the moment a student walks through our doors, every touchpoint — academic, pastoral, digital — is carefully designed for excellence.</p>
            </div>
            <div class="features-grid">

                <div class="feature-card">
                    <div class="feature-icon" style="background:#e8eaf6;color:#1a237e;"><i class="fa fa-laptop"></i></div>
                    <h3>Student &amp; Parent Portals</h3>
                    <p>Dedicated digital portals give students access to timetables, grades, assignments, and resources — while parents track attendance, fees, and academic progress in real time.</p>
                    <span class="feature-tag core"><i class="fa fa-check"></i> Core Feature</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#e8f5e9;color:#2e7d32;"><i class="fa fa-book"></i></div>
                    <h3>Structured Curriculum (Gr. 1–12)</h3>
                    <p>A full 12-grade curriculum mapped to international standards, with subject streams, electives, and specialisation tracks across STEM, Arts, Business, and Humanities.</p>
                    <span class="feature-tag core"><i class="fa fa-check"></i> Core Feature</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#fce4ec;color:#c62828;"><i class="fa fa-bar-chart"></i></div>
                    <h3>Real-Time Grade &amp; Progress Tracking</h3>
                    <p>Automated grade computation, progress reports, and personalised learning insights delivered instantly — no waiting for end-of-term reports.</p>
                    <span class="feature-tag core"><i class="fa fa-check"></i> Core Feature</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#fff9c4;color:#e65100;"><i class="fa fa-calendar-check-o"></i></div>
                    <h3>Digital Attendance System</h3>
                    <p>Teacher-facing attendance registration with automatic parent notification for absences, late arrivals, and early dismissals. Full audit trail for administration.</p>
                    <span class="feature-tag core"><i class="fa fa-check"></i> Core Feature</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#e8eaf6;color:#3949ab;"><i class="fa fa-credit-card"></i></div>
                    <h3>Online Fee Payment &amp; Invoicing</h3>
                    <p>Secure online payment gateway for tuition, transport, and extra-curricular fees. Automated receipts, outstanding balance alerts, and full payment history per student.</p>
                    <span class="feature-tag core"><i class="fa fa-check"></i> Core Feature</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#f3e8ff;color:#7c3aed;"><i class="fa fa-comments"></i></div>
                    <h3>Teacher–Parent Communication Hub</h3>
                    <p>In-portal messaging, meeting scheduling, and announcements keep parents and teachers aligned throughout the academic year.</p>
                    <span class="feature-tag core"><i class="fa fa-check"></i> Core Feature</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#e0f7fa;color:#00838f;"><i class="fa fa-book"></i></div>
                    <h3>Smart Admissions Wizard</h3>
                    <p>Online application portal with step-by-step wizard, document uploads, application status tracking, and instant email confirmations — applying made simple.</p>
                    <span class="feature-tag premium"><i class="fa fa-bolt"></i> Premium</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#fff3e0;color:#e65100;"><i class="fa fa-cogs"></i></div>
                    <h3>Admin &amp; Super-Admin Dashboards</h3>
                    <p>Full school-management dashboards for administrators: staff management, class timetabling, budget overview, audit logs, branding control, and system integrations.</p>
                    <span class="feature-tag premium"><i class="fa fa-bolt"></i> Premium</span>
                </div>

                <div class="feature-card">
                    <div class="feature-icon" style="background:#e8f5e9;color:#2e7d32;"><i class="fa fa-calendar"></i></div>
                    <h3>Academic Calendar &amp; Event RSVP</h3>
                    <p>Interactive school calendar with exportable events (Google/Outlook), push notification alerts, and RSVP management for school events and open days.</p>
                    <span class="feature-tag premium"><i class="fa fa-bolt"></i> Premium</span>
                </div>

            </div>
        </div>
    </section>

    <!-- ===== SECTION 2: BENEFITS ===== -->
    <section class="val-section-alt" id="benefits">
        <div class="container">
            <div class="val-center">
                <span class="val-label">Why It Matters</span>
                <h2 class="val-title">The Real Benefits Families Experience</h2>
                <p class="val-sub">Features are what we build. Benefits are what you live. Here is what City School families consistently tell us changes the most.</p>
            </div>

            <!-- FOR PARENTS -->
            <div class="benefits-split" style="margin-bottom:60px;">
                <div class="benefit-list">
                    <div style="margin-bottom:6px;">
                        <span class="val-label">For Parents</span>
                        <h3 class="val-title" style="margin-top:8px;">Total Visibility Into Your Child's Education</h3>
                        <p style="color:#6b7a99;font-size:.9rem;line-height:1.7;margin-bottom:24px;">No more guessing. Parents at City School are active participants — not just spectators — in their child's academic journey.</p>
                    </div>
                    <div class="benefit-item">
                        <div class="benefit-icon" style="background:#e8eaf6;color:#1a237e;"><i class="fa fa-eye"></i></div>
                        <div>
                            <h4>Transparent Progress Reports</h4>
                            <p>Live access to grades, attendance, and teacher feedback — available 24/7 on the parent portal, not just at parent-teacher evenings.</p>
                        </div>
                    </div>
                    <div class="benefit-item">
                        <div class="benefit-icon" style="background:#e8f5e9;color:#2e7d32;"><i class="fa fa-bell"></i></div>
                        <div>
                            <h4>Instant Absence &amp; Fee Alerts</h4>
                            <p>Get notified the moment your child is marked absent or a fee becomes due — so there are no surprises at the end of term.</p>
                        </div>
                    </div>
                    <div class="benefit-item">
                        <div class="benefit-icon" style="background:#fff9c4;color:#e65100;"><i class="fa fa-comments"></i></div>
