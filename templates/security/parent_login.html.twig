<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Parent Portal – City School</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Arvo:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('fonts/font-awesome.min.css') }}">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Arvo',Georgia,serif;min-height:100vh;background:linear-gradient(135deg,#052e16 0%,#166534 50%,#15803d 100%);display:flex;align-items:center;justify-content:center;padding:20px;}
.login-card{background:#fff;border-radius:20px;padding:44px 40px;width:100%;max-width:420px;box-shadow:0 24px 80px rgba(5,46,22,.45);}
.login-brand{text-align:center;margin-bottom:32px;}
.login-icon{width:64px;height:64px;background:#dcfce7;border-radius:16px;display:inline-flex;align-items:center;justify-content:center;font-size:28px;color:#16a34a;margin-bottom:14px;}
.login-brand h1{font-size:22px;font-weight:900;color:#1e293b;margin-bottom:4px;}
.login-brand-sub{font-size:12px;color:#16a34a;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
.error-box{background:#fee2e2;color:#ef4444;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:18px;display:flex;align-items:center;gap:8px;}
.form-group{margin-bottom:18px;}
.form-label{display:block;font-size:12px;font-weight:700;color:#475569;margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em;}
.form-control{width:100%;padding:11px 14px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:14px;outline:none;transition:border .2s;}
.form-control:focus{border-color:#16a34a;}
.btn-login{width:100%;padding:13px;background:#16a34a;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;transition:background .2s;margin-top:4px;}
.btn-login:hover{background:#15803d;}
.login-demo{margin-top:20px;padding:12px 14px;background:#f0fdf4;border-radius:10px;font-size:12px;color:#16a34a;text-align:center;border:1px dashed #86efac;}
.portal-links{display:flex;justify-content:center;gap:16px;margin-top:22px;font-size:12px;}
.portal-links a{color:#64748b;text-decoration:none;transition:color .2s;}
.portal-links a:hover{color:#16a34a;}
</style>
</head>
<body>
<div class="login-card">
    <div class="login-brand">
        <div class="login-icon"><i class="fa fa-leaf"></i></div>
        <h1>City School</h1>
        <div class="login-brand-sub">Parent Portal</div>
    </div>

    {% if error %}
    <div class="error-box"><i class="fa fa-exclamation-circle"></i> {{ error.messageKey|trans(error.messageData,'security') }}</div>
    {% endif %}

    {% for msg in app.flashes('success') %}
    <div style="background:#dcfce7;color:#166534;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:18px;display:flex;align-items:center;gap:8px;"><i class="fa fa-check-circle"></i> {{ msg }}</div>
    {% endfor %}

    <form method="post" action="{{ path('parent_login') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <div class="form-group">
            <label class="form-label">Username</label>
            <input type="text" class="form-control" name="_username" value="{{ last_username }}" autocomplete="username" autofocus>
        </div>
        <div class="form-group">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" name="_password" autocomplete="current-password">
        </div>
        <button type="submit" class="btn-login"><i class="fa fa-sign-in"></i>&nbsp; Sign In to Parent Portal</button>
    </form>

    <div class="login-demo">
        <strong>Demo:</strong>&nbsp; parent / student123 &nbsp;|&nbsp; mrsjones / student123
    </div>

    <div class="portal-links">
        <a href="{{ path('portal_login') }}"><i class="fa fa-user-o"></i> Student Portal</a>
        <a href="{{ path('teacher_login') }}"><i class="fa fa-chalkboard-teacher"></i> Teacher Portal</a>
        <a href="{{ path('admin_login') }}"><i class="fa fa-shield"></i> Admin</a>
        <a href="{{ path('parent_register') }}"><i class="fa fa-user-plus"></i> Register</a>
        <a href="{{ path('home') }}"><i class="fa fa-home"></i> Home</a>
    </div>
</div>
</body>
</html>
