<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Parent Registration – City School</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Arvo:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('fonts/font-awesome.min.css') }}">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Arvo',Georgia,serif;min-height:100vh;background:linear-gradient(135deg,#052e16 0%,#166534 50%,#15803d 100%);display:flex;align-items:center;justify-content:center;padding:20px;}
.login-card{background:#fff;border-radius:20px;padding:34px 30px;width:100%;max-width:580px;box-shadow:0 24px 80px rgba(5,46,22,.45);}
.login-brand{text-align:center;margin-bottom:24px;}
.login-icon{width:64px;height:64px;background:#dcfce7;border-radius:16px;display:inline-flex;align-items:center;justify-content:center;font-size:28px;color:#16a34a;margin-bottom:14px;}
.login-brand h1{font-size:22px;font-weight:900;color:#1e293b;margin-bottom:4px;}
.login-brand-sub{font-size:12px;color:#16a34a;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
.error-box{background:#fee2e2;color:#ef4444;border-radius:8px;padding:10px 14px;font-size:13px;margin-bottom:18px;display:flex;align-items:center;gap:8px;}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.form-group{margin-bottom:14px;}
.form-label{display:block;font-size:12px;font-weight:700;color:#475569;margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em;}
.form-control{width:100%;padding:11px 14px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:14px;outline:none;transition:border .2s;}
.form-control:focus{border-color:#16a34a;}
.field-error{font-size:12px;color:#ef4444;margin-top:4px;}
.btn-login{width:100%;padding:13px;background:#16a34a;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;transition:background .2s;margin-top:4px;}
.btn-login:hover{background:#15803d;}
.portal-links{display:flex;justify-content:center;gap:16px;margin-top:18px;font-size:12px;}
.portal-links a{color:#64748b;text-decoration:none;transition:color .2s;}
.portal-links a:hover{color:#16a34a;}
</style>
</head>
<body>
<div class="login-card">
    <div class="login-brand">
        <div class="login-icon"><i class="fa fa-leaf"></i></div>
        <h1>Parent Registration</h1>
        <div class="login-brand-sub">Request Parent Portal Access</div>
    </div>

    {% if errors is not empty %}
    <div class="error-box"><i class="fa fa-exclamation-circle"></i> Please correct the highlighted fields.</div>
    {% endif %}

    <form method="post" action="{{ path('parent_register') }}">
        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" class="form-control" name="full_name" value="{{ data.full_name }}" required>
                {% if errors.full_name is defined %}<div class="field-error">{{ errors.full_name }}</div>{% endif %}
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" name="email" value="{{ data.email }}" required>
                {% if errors.email is defined %}<div class="field-error">{{ errors.email }}</div>{% endif %}
            </div>
            <div class="form-group">
                <label class="form-label">Username</label>
                <input type="text" class="form-control" name="username" value="{{ data.username }}" required>
                {% if errors.username is defined %}<div class="field-error">{{ errors.username }}</div>{% endif %}
            </div>
            <div class="form-group">
                <label class="form-label">Child Name</label>
                <input type="text" class="form-control" name="child_name" value="{{ data.child_name }}" required>
                {% if errors.child_name is defined %}<div class="field-error">{{ errors.child_name }}</div>{% endif %}
            </div>
            <div class="form-group">
                <label class="form-label">Child Class</label>
                <input type="text" class="form-control" name="child_class" placeholder="e.g. Grade 8-B" value="{{ data.child_class }}" required>
                {% if errors.child_class is defined %}<div class="field-error">{{ errors.child_class }}</div>{% endif %}
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" name="password" required>
                {% if errors.password is defined %}<div class="field-error">{{ errors.password }}</div>{% endif %}
            </div>
            <div class="form-group" style="grid-column:1 / -1;">
                <label class="form-label">Confirm Password</label>
                <input type="password" class="form-control" name="password_confirm" required>
                {% if errors.password_confirm is defined %}<div class="field-error">{{ errors.password_confirm }}</div>{% endif %}
            </div>
        </div>

        <button type="submit" class="btn-login"><i class="fa fa-send"></i>&nbsp; Submit Registration Request</button>
    </form>

    <div class="portal-links">
        <a href="{{ path('parent_login') }}"><i class="fa fa-sign-in"></i> Back to Parent Login</a>
        <a href="{{ path('home') }}"><i class="fa fa-home"></i> Home</a>
    </div>
</div>
</body>
</html>
