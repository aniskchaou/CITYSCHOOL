{% extends 'base.html.twig' %}

{% block title %}Student Registration – City School{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="/css/portal.css">
{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-card" style="max-width:520px;">
        <div class="login-logo">
            <div class="logo-circle"><i class="fa fa-book"></i></div>
            <h1>Student Registration</h1>
            <p>Submit your request for admin approval</p>
        </div>

        {% if errors is not empty %}
        <div class="alert alert-danger">
            <i class="fa fa-exclamation-circle"></i>
            Please fix the highlighted fields and submit again.
        </div>
        {% endif %}

        <form method="post" action="{{ path('portal_register') }}">
            <div class="grid-2" style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <div class="form-group" style="grid-column:1 / -1;">
                    <label class="form-label">Full Name</label>
                    <input type="text" name="full_name" class="form-control" value="{{ data.full_name }}" required>
                    {% if errors.full_name is defined %}<div style="font-size:12px;color:#dc2626;margin-top:4px;">{{ errors.full_name }}</div>{% endif %}
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" value="{{ data.email }}" required>
                    {% if errors.email is defined %}<div style="font-size:12px;color:#dc2626;margin-top:4px;">{{ errors.email }}</div>{% endif %}
                </div>
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input type="text" name="username" class="form-control" value="{{ data.username }}" required>
                    {% if errors.username is defined %}<div style="font-size:12px;color:#dc2626;margin-top:4px;">{{ errors.username }}</div>{% endif %}
                </div>
                <div class="form-group">
                    <label class="form-label">Class Level</label>
                    <input type="text" name="class_level" class="form-control" placeholder="e.g. Grade 10-A" value="{{ data.class_level }}" required>
                    {% if errors.class_level is defined %}<div style="font-size:12px;color:#dc2626;margin-top:4px;">{{ errors.class_level }}</div>{% endif %}
                </div>
                <div class="form-group">
                    <label class="form-label">Guardian Email (optional)</label>
                    <input type="email" name="guardian_email" class="form-control" value="{{ data.guardian_email }}">
                    {% if errors.guardian_email is defined %}<div style="font-size:12px;color:#dc2626;margin-top:4px;">{{ errors.guardian_email }}</div>{% endif %}
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" required>
                    {% if errors.password is defined %}<div style="font-size:12px;color:#dc2626;margin-top:4px;">{{ errors.password }}</div>{% endif %}
                </div>
                <div class="form-group">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" name="password_confirm" class="form-control" required>
                    {% if errors.password_confirm is defined %}<div style="font-size:12px;color:#dc2626;margin-top:4px;">{{ errors.password_confirm }}</div>{% endif %}
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-full" style="margin-top:8px;justify-content:center;padding:12px;">
                <i class="fa fa-send"></i> Submit Registration Request
            </button>
        </form>

        <p style="text-align:center;margin-top:14px;">
            <a href="{{ path('portal_login') }}" style="font-size:13px;color:#4361ee;text-decoration:none;font-weight:600;">
                <i class="fa fa-sign-in"></i> Back to Student Login
            </a>
        </p>
    </div>
</div>
{% endblock %}
