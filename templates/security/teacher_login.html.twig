<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Login – City School</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="/fonts/font-awesome.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/portal.css">
    <link rel="stylesheet" href="/css/teacher-portal.css">
</head>
<body class="portal-body teacher-portal-body">
<div class="login-page">
    <div class="login-card">
        <div class="login-brand">
            <div class="login-brand-icon" style="background:#0891b2;">
                <i class="fa fa-pencil"></i>
            </div>
            <div class="login-brand-name">City School</div>
            <div class="login-brand-sub">Teacher Portal</div>
        </div>

        {% if error %}
        <div class="alert alert-danger">
            <i class="fa fa-exclamation-circle"></i> {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
        {% endif %}

        <form method="post" action="{{ path('teacher_login') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label class="form-label">Username</label>
                <input type="text" name="_username" class="form-control" value="{{ last_username }}"
                       autocomplete="username" placeholder="e.g. teacher" required autofocus>
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" name="_password" class="form-control"
                       autocomplete="current-password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="btn btn-primary w-full" style="background:#0891b2;justify-content:center;">
                <i class="fa fa-sign-in"></i> Sign In as Teacher
            </button>
        </form>

        <div class="login-hint">
            <i class="fa fa-info-circle"></i>
            Demo credentials: <strong>teacher</strong> / <strong>student123</strong><br>
            or <strong>mrsmith</strong> / <strong>student123</strong>
        </div>

        <div style="text-align:center;margin-top:14px;">
            <a href="{{ path('home') }}" style="font-size:13px;color:#0891b2;font-weight:600;text-decoration:none;">
                <i class="fa fa-home"></i> Return to Homepage
            </a>
        </div>

        <div style="text-align:center;margin-top:16px;font-size:13px;color:#64748b;">
            Are you a student? <a href="{{ path('portal_login') }}" style="color:#0891b2;font-weight:600;">Student login →</a>
        </div>
    </div>
</div>
</body>
</html>
