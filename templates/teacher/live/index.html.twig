{% extends 'teacher/base.html.twig' %}
{% block title %}Live Classes{% endblock %}
{% block page_title %}Live Classes{% endblock %}

{% block content %}

{% set live = sessions|filter(s => s.status == 'live') %}
{% set upcoming = sessions|filter(s => s.status == 'upcoming') %}
{% set recorded = sessions|filter(s => s.status == 'recorded') %}

{# ── Active Live Session Control Panel ── #}
{% if live|length > 0 %}
{% for s in live %}
<div class="live-control-panel" style="margin-bottom:24px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
        <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
                <span class="live-badge"><span class="dot"></span> LIVE NOW</span>
                <span style="font-size:13px;color:#94a3b8;">{{ s.course }}</span>
            </div>
            <div style="font-size:22px;font-weight:800;margin-bottom:4px;">{{ s.topic }}</div>
            <div style="font-size:13px;color:#94a3b8;"><i class="fa fa-link" style="margin-right:5px;"></i>{{ s.link }}</div>
        </div>
        <div style="display:flex;gap:10px;">
            <button class="btn-start-live" onclick="alert('Screen sharing started!')">
                <i class="fa fa-desktop"></i> Share Screen
            </button>
            <button class="btn-end-live" onclick="if(confirm('End this live class?')){}">
                <i class="fa fa-stop-circle"></i> End Class
            </button>
        </div>
    </div>
    <div class="live-stats">
        <div class="live-stat"><div class="live-stat-val">{{ s.participants }}</div><div class="live-stat-label">Joined</div></div>
        <div class="live-stat"><div class="live-stat-val">{{ s.duration }}</div><div class="live-stat-label">Min Planned</div></div>
        <div class="live-stat"><div class="live-stat-val">42</div><div class="live-stat-label">Min Elapsed</div></div>
        <div class="live-stat"><div class="live-stat-val">3</div><div class="live-stat-label">Hands Raised</div></div>
        <div class="live-stat"><div class="live-stat-val">94%</div><div class="live-stat-label">Engagement</div></div>
    </div>
</div>
{% endfor %}
{% else %}

{# ── Start New Class Form ── #}
<div class="card" style="margin-bottom:24px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-video-camera t-accent" style="margin-right:6px;"></i>Start a Live Class</span>
    </div>
    <form method="post" action="{{ path('teacher_live') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('live_start') }}">
        <div class="grid-2" style="gap:14px;">
            <div class="form-group">
                <label class="form-label">Course</label>
                <select name="course_id" class="form-control">
                    {% for c in courses %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Topic / Session Title</label>
                <input type="text" name="topic" class="form-control" placeholder="e.g. Solving Quadratic Equations">
            </div>
        </div>
        <div style="display:flex;gap:10px;">
            <button type="submit" class="btn-start-live">
                <i class="fa fa-play-circle"></i> Start Live Class Now
            </button>
            <button type="button" class="btn btn-outline" onclick="openModal('modal-schedule-live')">
                <i class="fa fa-calendar-plus-o"></i> Schedule for Later
            </button>
        </div>
    </form>
</div>
{% endif %}

{# ── Upcoming ── #}
<div class="card" style="margin-bottom:24px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-clock-o" style="color:#f59e0b;margin-right:6px;"></i>Upcoming Sessions</span>
        <button class="btn-teal" style="font-size:12px;padding:6px 12px;" onclick="openModal('modal-schedule-live')">
            <i class="fa fa-calendar-plus-o"></i> Schedule
        </button>
    </div>
    {% if upcoming|length == 0 %}
    <div style="text-align:center;padding:20px;color:#64748b;font-size:13px;">No upcoming sessions scheduled.</div>
    {% else %}
    <table class="portal-table">
        <thead><tr><th>Course</th><th>Topic</th><th>Date</th><th>Time</th><th>Duration</th><th>Actions</th></tr></thead>
        <tbody>
        {% for s in upcoming %}
        <tr>
            <td style="font-weight:700;font-size:13px;">{{ s.course }}</td>
            <td style="font-size:13px;">{{ s.topic }}</td>
            <td style="font-size:13px;">{{ s.date }}</td>
            <td style="font-size:13px;">{{ s.time }}</td>
            <td style="font-size:13px;">{{ s.duration }} min</td>
            <td>
                <button class="btn-teal" style="font-size:11px;padding:5px 10px;" onclick="alert('Starting early: {{ s.topic }}')">
                    <i class="fa fa-play"></i> Start Early
                </button>
                <button class="btn btn-outline btn-sm" style="font-size:11px;" onclick="alert('Edit session')">
                    <i class="fa fa-pencil"></i>
                </button>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

{# ── Recordings ── #}
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-play-circle" style="color:#7c3aed;margin-right:6px;"></i>Recorded Sessions</span>
    </div>
    <div class="grid-auto">
        {% for s in recorded %}
        <div style="background:#f8fafc;border-radius:10px;padding:16px;border:1px solid #e2e8f0;">
            <div style="font-size:14px;font-weight:700;margin-bottom:4px;">{{ s.course }}</div>
            <div style="font-size:13px;color:#64748b;margin-bottom:6px;">{{ s.topic }}</div>
            <div style="font-size:12px;color:#94a3b8;margin-bottom:12px;">
                <i class="fa fa-calendar"></i> {{ s.date }} &middot;
                <i class="fa fa-clock-o"></i> {{ s.duration }} min &middot;
                <i class="fa fa-users"></i> {{ s.participants }} attendees
            </div>
            <div style="display:flex;gap:6px;">
                <a href="{{ s.link }}" class="btn btn-outline btn-sm" style="flex:1;justify-content:center;font-size:12px;" onclick="return false;">
                    <i class="fa fa-play"></i> Watch
                </a>
                <button class="btn btn-outline btn-sm" style="font-size:11px;" onclick="alert('Share recording link')">
                    <i class="fa fa-share-alt"></i>
                </button>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

{# ── Schedule Modal ── #}
<div class="t-modal-overlay" id="modal-schedule-live">
    <div class="t-modal">
        <div class="t-modal-header">
            <div class="t-modal-title">Schedule Live Session</div>
            <button class="t-modal-close" onclick="closeModal('modal-schedule-live')">&times;</button>
        </div>
        <form method="post" action="{{ path('teacher_live') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('live_schedule') }}">
            <input type="hidden" name="scheduled" value="1">
            <div class="form-group">
                <label class="form-label">Course</label>
                <select name="course_id" class="form-control">
                    {% for c in courses %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Session Topic *</label>
                <input type="text" name="topic" class="form-control" placeholder="e.g. Derivatives Review" required>
            </div>
            <div class="grid-2" style="gap:12px;">
                <div class="form-group">
                    <label class="form-label">Date *</label>
                    <input type="date" name="date" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Start Time *</label>
                    <input type="time" name="time" class="form-control" required>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Duration (minutes)</label>
                <input type="number" name="duration" class="form-control" value="60" min="15">
            </div>
            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn-teal"><i class="fa fa-calendar-check-o"></i> Schedule Session</button>
                <button type="button" class="btn btn-outline" onclick="closeModal('modal-schedule-live')">Cancel</button>
            </div>
        </form>
    </div>
</div>

{% endblock %}
