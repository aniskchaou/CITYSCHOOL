{% extends 'teacher/base.html.twig' %}
{% block title %}Reports & Insights{% endblock %}
{% block page_title %}Reports & Insights{% endblock %}

{% block content %}
<div class="stats-grid" style="margin-bottom:24px;">
    <div class="stat-card">
        <div class="stat-icon" style="background:#e0f2fe;color:#0891b2;"><i class="fa fa-file-pdf-o"></i></div>
        <div><div class="stat-value">{{ reportCards|length }}</div><div class="stat-label">Report Cards</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-list-alt"></i></div>
        <div><div class="stat-value">{{ termSummaries|length }}</div><div class="stat-label">Term Summaries</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-line-chart"></i></div>
        <div><div class="stat-value">{{ progress|length }}</div><div class="stat-label">Progress Points</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fee2e2;color:#ef4444;"><i class="fa fa-magic"></i></div>
        <div><div class="stat-value">{{ aiSummaries|length }}</div><div class="stat-label">AI Summaries</div></div>
    </div>
</div>

<div class="grid-2" style="gap:18px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-download t-accent" style="margin-right:6px;"></i>Download Report Cards</span>
        </div>
        {% for card in reportCards %}
        <div style="padding:10px;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:8px;display:flex;justify-content:space-between;gap:10px;align-items:center;">
            <div>
                <div style="font-size:13px;font-weight:700;">{{ card.student }}</div>
                <div style="font-size:11px;color:#94a3b8;">{{ card.term }} · GPA {{ card.gpa }} · {{ card.file }}</div>
            </div>
            <form method="post" action="{{ path('teacher_reports') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('teacher_reports_card_' ~ loop.index) }}">
                <input type="hidden" name="action" value="download_report_card">
                <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-download"></i></button>
            </form>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-book t-accent" style="margin-right:6px;"></i>View Term Summaries</span>
            <form method="post" action="{{ path('teacher_reports') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('teacher_reports_terms') }}">
                <input type="hidden" name="action" value="view_term_summaries">
                <button class="btn btn-outline btn-sm" type="submit">Refresh</button>
            </form>
        </div>
        {% for item in termSummaries %}
        <div style="padding:10px 0;border-bottom:1px solid #f1f5f9;">
            <div style="display:flex;justify-content:space-between;gap:8px;">
                <div style="font-size:13px;font-weight:700;">{{ item.student }}</div>
                <div style="font-size:11px;color:#94a3b8;">{{ item.term }}</div>
            </div>
            <div style="font-size:12px;color:#475569;margin-top:4px;">{{ item.summary }}</div>
            <div style="font-size:11px;color:#64748b;margin-top:4px;">Attendance: {{ item.attendance }}%</div>
        </div>
        {% endfor %}
    </div>
</div>

<div class="grid-2" style="gap:18px;margin-top:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-line-chart t-accent" style="margin-right:6px;"></i>Track Long-term Progress</span>
            <form method="post" action="{{ path('teacher_reports') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('teacher_reports_progress') }}">
                <input type="hidden" name="action" value="track_long_term_progress">
                <button class="btn btn-outline btn-sm" type="submit">Refresh Progress</button>
            </form>
        </div>
        {% for point in progress %}
        <div style="display:grid;grid-template-columns:140px 1fr 55px;gap:8px;align-items:center;margin-bottom:8px;">
            <div style="font-size:12px;color:#475569;">{{ point.student }} · {{ point.period }}</div>
            <div class="progress-bar-wrap" style="height:10px;">
                <div class="progress-bar-fill" style="height:10px;border-radius:6px;background:#0891b2;width:{{ point.score }}%;"></div>
            </div>
            <div style="font-size:12px;font-weight:800;color:#0f766e;">{{ point.score }}%</div>
        </div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-diamond t-accent" style="margin-right:6px;"></i>Premium: AI-generated Summaries</span>
            <form method="post" action="{{ path('teacher_reports') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('teacher_reports_ai') }}">
                <input type="hidden" name="action" value="generate_ai_summary">
                <button class="btn btn-outline btn-sm" type="submit">Generate</button>
            </form>
        </div>
        {% for item in aiSummaries %}
        <div style="padding:10px;border-left:4px solid #7c3aed;background:#f5f3ff;border-radius:6px;margin-bottom:8px;">
            <div style="font-size:13px;font-weight:700;">{{ item.student }}</div>
            <div style="font-size:12px;color:#475569;margin-top:4px;">{{ item.summary }}</div>
        </div>
        {% endfor %}
    </div>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-calendar-o t-accent" style="margin-right:6px;"></i>Premium: Monthly Performance Reports</span>
        <form method="post" action="{{ path('teacher_reports') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('teacher_reports_monthly') }}">
            <input type="hidden" name="action" value="open_monthly_reports">
            <button class="btn btn-outline btn-sm" type="submit">Open Reports</button>
        </form>
    </div>
    {% for report in monthlyReports %}
    <div style="padding:10px;border-bottom:1px solid #f1f5f9;">
        <div style="display:flex;justify-content:space-between;gap:8px;">
            <div style="font-size:13px;font-weight:700;">{{ report.month }}</div>
            <div style="font-size:11px;color:#94a3b8;">{{ report.studentsFlagged }} flagged students</div>
        </div>
        <div style="font-size:12px;color:#475569;margin-top:4px;">Focus: {{ report.focus }}</div>
    </div>
    {% endfor %}
</div>
{% endblock %}
