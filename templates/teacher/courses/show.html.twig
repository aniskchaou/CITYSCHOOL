{% extends 'teacher/base.html.twig' %}
{% block title %}{{ course.name }}{% endblock %}
{% block page_title %}{{ course.name }}{% endblock %}

{% block content %}

{# ── Course Header ── #}
<div class="card" style="border-top:5px solid {{ course.color }};margin-bottom:20px;">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
        <div>
            <div style="font-size:22px;font-weight:800;">{{ course.name }}</div>
            <div style="font-size:13px;color:#64748b;margin-top:4px;">
                <span class="badge badge-primary" style="background:{{ course.color }};color:#fff;margin-right:8px;">{{ course.code }}</span>
                {{ course.grade }} · {{ course.schedule }} · {{ course.room }}
            </div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <a href="{{ path('teacher_assignments') }}" class="btn btn-outline btn-sm"><i class="fa fa-tasks"></i> Assignments</a>
            <a href="{{ path('teacher_grading') }}" class="btn btn-outline btn-sm"><i class="fa fa-check-square-o"></i> Grading</a>
            <button class="btn-teal btn-sm" onclick="openModal('modal-upload')"><i class="fa fa-upload"></i> Upload Material</button>
        </div>
    </div>
    <div style="display:flex;gap:24px;margin-top:18px;padding-top:16px;border-top:1px solid #e2e8f0;flex-wrap:wrap;">
        <div style="text-align:center;"><div style="font-size:20px;font-weight:800;color:{{ course.color }};">{{ course.students }}</div><div style="font-size:11px;color:#64748b;">Students</div></div>
        <div style="text-align:center;"><div style="font-size:20px;font-weight:800;color:{{ course.color }};">{{ course.avg }}%</div><div style="font-size:11px;color:#64748b;">Avg Score</div></div>
        <div style="text-align:center;"><div style="font-size:20px;font-weight:800;color:{{ course.color }};">{{ materials|length }}</div><div style="font-size:11px;color:#64748b;">Materials</div></div>
        <div style="text-align:center;"><div style="font-size:20px;font-weight:800;color:{{ course.color }};">{{ assignments|length }}</div><div style="font-size:11px;color:#64748b;">Assignments</div></div>
    </div>
</div>

<div class="grid-2" style="gap:20px;margin-bottom:20px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-book t-accent" style="margin-right:6px;"></i>Lessons & Completion</span>
            <form method="post" action="{{ path('teacher_course_show', {id: course.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('teacher_course_completion_' ~ course.id) }}">
                <input type="hidden" name="action" value="refresh_completion">
                <button class="btn btn-outline btn-sm" type="submit">Refresh</button>
            </form>
        </div>
        {% for lesson in lessons %}
        <div style="padding:10px 0;border-bottom:1px solid #f1f5f9;">
            <div style="display:flex;justify-content:space-between;gap:8px;align-items:center;">
                <div style="font-size:13px;font-weight:700;">{{ lesson.title }}</div>
                <span class="badge badge-{{ lesson.bookmarked ? 'primary' : 'success' }}">{{ lesson.type|upper }}</span>
            </div>
            <div class="progress-bar-wrap" style="margin:8px 0 4px 0;">
                <div class="progress-bar-fill" style="width:{{ lesson.completion }}%;background:{{ course.color }};height:6px;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <div style="font-size:11px;color:#64748b;">Completion: {{ lesson.completion }}%</div>
                <form method="post" action="{{ path('teacher_course_show', {id: course.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('teacher_course_bookmark_' ~ course.id ~ '_' ~ loop.index) }}">
                    <input type="hidden" name="action" value="bookmark_resource">
                    <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-bookmark"></i> {{ lesson.bookmarked ? 'Bookmarked' : 'Bookmark' }}</button>
                </form>
            </div>
        </div>
        {% else %}
        <div style="font-size:12px;color:#64748b;">No lesson modules available yet.</div>
        {% endfor %}
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-diamond t-accent" style="margin-right:6px;"></i>Premium Learning Guidance</span>
        </div>
        <div style="margin-bottom:14px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <div style="font-size:13px;font-weight:700;">Structured learning path</div>
                <form method="post" action="{{ path('teacher_course_show', {id: course.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('teacher_course_path_' ~ course.id) }}">
                    <input type="hidden" name="action" value="open_learning_path">
                    <button class="btn btn-outline btn-sm" type="submit">Open Path</button>
                </form>
            </div>
            {% for step in learningPath %}
            <div style="padding:8px;border-left:4px solid {{ step.status == 'done' ? '#16a34a' : (step.status == 'current' ? '#0891b2' : '#cbd5e1') }};background:#f8fafc;border-radius:6px;margin-bottom:7px;">
                <div style="font-size:12px;font-weight:700;">{{ step.step }}</div>
                <div style="font-size:11px;color:#64748b;margin-top:3px;">{{ step.status|capitalize }}</div>
            </div>
            {% else %}
            <div style="font-size:12px;color:#64748b;">No structured learning path published yet.</div>
            {% endfor %}
        </div>

        <div style="padding-top:10px;border-top:1px solid #e2e8f0;margin-bottom:12px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <div style="font-size:13px;font-weight:700;">Resume where you left off</div>
                <form method="post" action="{{ path('teacher_course_show', {id: course.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('teacher_course_resume_' ~ course.id) }}">
                    <input type="hidden" name="action" value="resume_learning">
                    <button class="btn btn-outline btn-sm" type="submit">Resume</button>
                </form>
            </div>
            <div style="padding:10px;background:#eff6ff;border-radius:8px;">
                <div style="font-size:12px;font-weight:700;color:#1d4ed8;">{{ resumeState.item }}</div>
                <div style="font-size:11px;color:#475569;margin-top:4px;">{{ resumeState.detail }}</div>
            </div>
        </div>

        <div style="padding-top:10px;border-top:1px solid #e2e8f0;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <div style="font-size:13px;font-weight:700;">Smart recommendations</div>
                <form method="post" action="{{ path('teacher_course_show', {id: course.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('teacher_course_recommendations_' ~ course.id) }}">
                    <input type="hidden" name="action" value="refresh_recommendations">
                    <button class="btn btn-outline btn-sm" type="submit">Refresh</button>
                </form>
            </div>
            {% for item in recommendations %}
            <div style="font-size:12px;color:#475569;margin-bottom:6px;"><i class="fa fa-lightbulb-o" style="color:#f59e0b;margin-right:5px;"></i>{{ item }}</div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="grid-2" style="gap:20px;">

    {# ── Materials ── #}
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-paperclip t-accent" style="margin-right:6px;"></i>Course Materials</span>
            <button class="btn-teal" style="font-size:12px;padding:6px 12px;" onclick="openModal('modal-upload')">
                <i class="fa fa-upload"></i> Upload
            </button>
        </div>
        <table class="portal-table">
            <thead><tr><th>Title</th><th>Type</th><th>Size</th><th style="text-align:center;">Downloads</th><th>Action</th></tr></thead>
            <tbody>
            {% for m in materials %}
            <tr>
                <td style="font-size:13px;font-weight:600;">
                    <i class="fa fa-{% if m.type=='pdf' %}file-pdf-o{% elseif m.type=='video' %}film{% elseif m.type=='ppt' %}file-powerpoint-o{% else %}link{% endif %}" style="color:{% if m.type=='pdf' %}#ef4444{% elseif m.type=='video' %}#7c3aed{% elseif m.type=='ppt' %}#f59e0b{% else %}#0891b2{% endif %};margin-right:6px;"></i>
                    {{ m.title }}
                </td>
                <td><span class="badge badge-{% if m.type=='pdf' %}danger{% elseif m.type=='video' %}primary{% else %}warning{% endif %}" style="font-size:10px;">{{ m.type|upper }}</span></td>
                <td style="font-size:12px;color:#64748b;">{{ m.size }}</td>
                <td style="text-align:center;font-size:13px;">{{ m.downloads }}</td>
                <td>
                    <a href="#" class="btn btn-outline btn-sm" style="font-size:11px;" onclick="return false;"><i class="fa fa-download"></i></a>
                    <button class="btn btn-outline btn-sm" style="font-size:11px;color:#ef4444;" onclick="if(confirm('Delete this material?')){}"><i class="fa fa-trash-o"></i></button>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── Assignments ── #}
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-tasks t-accent" style="margin-right:6px;"></i>Assignments</span>
            <a href="{{ path('teacher_assignments') }}" class="btn-teal" style="font-size:12px;padding:6px 12px;">
                <i class="fa fa-plus"></i> New
            </a>
        </div>
        {% if assignments|length == 0 %}
        <div style="text-align:center;padding:24px;color:#64748b;font-size:13px;">No assignments yet for this course.</div>
        {% else %}
        {% for a in assignments %}
        <div style="padding:12px 0;border-bottom:1px solid #f1f5f9;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
                <div style="font-size:13px;font-weight:700;">{{ a.title }}</div>
                <span class="badge badge-{{ a.status=='graded' ? 'success' : 'warning' }}">{{ a.status|capitalize }}</span>
            </div>
            <div style="font-size:12px;color:#64748b;margin-bottom:6px;">
                Due: {{ a.deadline }} · {{ a.points }} pts
            </div>
            <div class="progress-bar-wrap" style="margin-bottom:4px;">
                <div class="progress-bar-fill" style="width:{{ (a.submitted/a.total*100)|round }}%;background:{{ course.color }};height:6px;"></div>
            </div>
            <div style="font-size:11px;color:#64748b;">{{ a.submitted }}/{{ a.total }} submitted · {{ a.graded }} graded</div>
        </div>
        {% endfor %}
        {% endif %}
    </div>
</div>

{# ── Enrolled Students ── #}
<div class="card" style="margin-top:20px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-users t-accent" style="margin-right:6px;"></i>Enrolled Students ({{ enrolled|length }})</span>
        <a href="{{ path('teacher_analytics') }}" class="btn btn-outline btn-sm">View Analytics</a>
    </div>
    <table class="portal-table">
        <thead><tr><th>Student</th><th>Grade</th><th>Avg Score</th><th>Attendance</th><th>Status</th><th>Action</th></tr></thead>
        <tbody>
        {% for s in enrolled %}
        <tr>
            <td>
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:32px;height:32px;border-radius:50%;background:{{ course.color }}20;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;color:{{ course.color }};">
                        {{ s.name|split(' ')|first|slice(0,1) }}{{ s.name|split(' ')|last|slice(0,1) }}
                    </div>
                    <span style="font-size:13px;font-weight:600;">{{ s.name }}</span>
                </div>
            </td>
            <td style="font-size:13px;">{{ s.grade }}</td>
            <td>
                <div style="display:flex;align-items:center;gap:8px;">
                    <div class="perf-bar" style="width:60px;"><div class="perf-bar-fill" style="width:{{ s.avg_score }}%;background:{{ s.avg_score>=80 ? '#22c55e' : (s.avg_score>=70 ? '#4361ee' : '#f59e0b') }};"></div></div>
                    <span style="font-size:12px;">{{ s.avg_score }}%</span>
                </div>
            </td>
            <td style="font-size:13px;">{{ s.attendance }}%</td>
            <td>
                <span class="badge badge-{% if s.status=='excellent' %}success{% elseif s.status=='good' %}primary{% else %}danger{% endif %}">
                    {{ s.status|replace({'_':' '})|title }}
                </span>
            </td>
            <td>
                <a href="{{ path('teacher_messages') }}" class="btn btn-outline btn-sm" style="font-size:11px;">
                    <i class="fa fa-envelope-o"></i>
                </a>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{# ── Upload Material Modal ── #}
<div class="t-modal-overlay" id="modal-upload">
    <div class="t-modal">
        <div class="t-modal-header">
            <div class="t-modal-title">Upload Course Material</div>
            <button class="t-modal-close" onclick="closeModal('modal-upload')">&times;</button>
        </div>
        <form method="post" action="{{ path('teacher_course_show', {id: course.id}) }}" enctype="multipart/form-data">
            <input type="hidden" name="_token" value="{{ csrf_token('material_upload') }}">
            <input type="hidden" name="action" value="upload_material">
            <div class="form-group">
                <label class="form-label">Title *</label>
                <input type="text" name="title" class="form-control" placeholder="e.g. Chapter 5 Notes" required>
            </div>
            <div class="form-group">
                <label class="form-label">Type</label>
                <select name="type" class="form-control">
                    <option value="pdf">PDF Document</option>
                    <option value="video">Video</option>
                    <option value="ppt">Presentation</option>
                    <option value="link">External Link</option>
                </select>
            </div>
            <div class="form-group" id="file-group">
                <label class="form-label">File</label>
                <input type="file" name="file" class="form-control" accept=".pdf,.ppt,.pptx,.mp4">
            </div>
            <div class="form-group" id="link-group" style="display:none;">
                <label class="form-label">URL</label>
                <input type="url" name="link_url" class="form-control" placeholder="https://...">
            </div>
            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn-teal"><i class="fa fa-upload"></i> Upload</button>
                <button type="button" class="btn btn-outline" onclick="closeModal('modal-upload')">Cancel</button>
            </div>
        </form>
    </div>
</div>

{% block javascripts %}
<script>
document.querySelector('[name=type]').addEventListener('change', function(){
    document.getElementById('file-group').style.display = this.value === 'link' ? 'none' : '';
    document.getElementById('link-group').style.display = this.value === 'link' ? '' : 'none';
});
</script>
{% endblock %}

{% endblock %}
