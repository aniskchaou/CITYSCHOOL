{% extends 'teacher/base.html.twig' %}
{% block title %}My Profile{% endblock %}
{% block page_title %}My Profile{% endblock %}

{% block content %}

<div class="grid-2">

    {# ── Profile Summary ── #}
    <div class="card" style="text-align:center;">
        <div style="position:relative;display:inline-block;margin-bottom:16px;">
            <img src="{{ teacher.avatar }}" alt="Avatar"
                 style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:4px solid #0891b2;">
            <button onclick="alert('Photo upload coming soon!')" style="position:absolute;bottom:0;right:0;width:28px;height:28px;border-radius:50%;background:#0891b2;border:none;color:#fff;cursor:pointer;font-size:12px;">
                <i class="fa fa-camera"></i>
            </button>
        </div>
        <div style="font-size:20px;font-weight:800;">{{ teacher.name }}</div>
        <div style="font-size:13px;color:#64748b;margin-bottom:4px;">{{ teacher.department }}</div>
        <div style="font-size:13px;color:#0891b2;margin-bottom:6px;">{{ teacher.email }}</div>
        <div style="font-size:12px;color:#64748b;margin-bottom:16px;">
            <i class="fa fa-calendar"></i> Joined {{ teacher.joined }} &nbsp;·&nbsp;
            <i class="fa fa-briefcase"></i> {{ teacher.experience }}
        </div>

        <div style="display:flex;justify-content:space-around;padding:14px 0;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;margin-bottom:16px;">
            <div><div style="font-size:20px;font-weight:800;color:#0891b2;">{{ courses|length }}</div><div style="font-size:11px;color:#64748b;">Courses</div></div>
            <div><div style="font-size:20px;font-weight:800;color:#22c55e;">93</div><div style="font-size:11px;color:#64748b;">Students</div></div>
            <div><div style="font-size:20px;font-weight:800;color:#f59e0b;">4.8</div><div style="font-size:11px;color:#64748b;">Rating</div></div>
        </div>

        <div style="text-align:left;font-size:13px;color:#475569;">
            <div style="padding:6px 0;border-bottom:1px solid #f1f5f9;"><i class="fa fa-envelope-o" style="width:18px;color:#0891b2;margin-right:6px;"></i>{{ teacher.email }}</div>
            <div style="padding:6px 0;border-bottom:1px solid #f1f5f9;"><i class="fa fa-phone" style="width:18px;color:#0891b2;margin-right:6px;"></i>{{ teacher.phone }}</div>
            <div style="padding:6px 0;border-bottom:1px solid #f1f5f9;"><i class="fa fa-building" style="width:18px;color:#0891b2;margin-right:6px;"></i>{{ teacher.department }}</div>
            <div style="padding:6px 0;margin-bottom:8px;"><i class="fa fa-briefcase" style="width:18px;color:#0891b2;margin-right:6px;"></i>{{ teacher.experience }} experience</div>
        </div>

        <div style="text-align:left;">
            <div style="font-size:12px;font-weight:700;color:#64748b;margin-bottom:8px;">TEACHING SUBJECTS</div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                {% for sub in teacher.subjects %}
                <span class="badge badge-primary" style="background:#e0f2fe;color:#0891b2;font-size:11px;">{{ sub }}</span>
                {% endfor %}
            </div>
        </div>
    </div>

    {# ── Edit Form ── #}
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-edit t-accent" style="margin-right:6px;"></i>Edit Profile</span></div>
        <form method="post" action="{{ path('teacher_profile') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('teacher_profile_update') }}">
            <div class="grid-2" style="gap:14px;">
                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input type="text" class="form-control" value="James" name="first_name">
                </div>
                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input type="text" class="form-control" value="Smith" name="last_name">
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Email Address</label>
                <input type="email" class="form-control" value="{{ teacher.email }}" name="email">
            </div>
            <div class="form-group">
                <label class="form-label">Phone Number</label>
                <input type="tel" class="form-control" value="{{ teacher.phone }}" name="phone">
            </div>
            <div class="form-group">
                <label class="form-label">Department</label>
                <input type="text" class="form-control" value="{{ teacher.department }}" name="department">
            </div>
            <div class="form-group">
                <label class="form-label">Bio</label>
                <textarea class="form-control" rows="3" name="bio" style="resize:vertical;">{{ teacher.bio }}</textarea>
            </div>

            <div style="padding-top:14px;border-top:1px solid #e2e8f0;margin-bottom:14px;">
                <div style="font-size:14px;font-weight:800;margin-bottom:12px;color:#ef4444;">
                    <i class="fa fa-lock" style="margin-right:6px;"></i>Change Password
                </div>
                <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <input type="password" class="form-control" name="current_password" placeholder="Enter current password">
                </div>
                <div class="grid-2" style="gap:14px;">
                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <input type="password" class="form-control" name="new_password" placeholder="Min 8 characters">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" name="confirm_password">
                    </div>
                </div>
            </div>

            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn-teal"><i class="fa fa-save"></i> Save Changes</button>
                <a href="{{ path('teacher_dashboard') }}" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

{% endblock %}
