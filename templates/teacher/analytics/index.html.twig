{% extends 'teacher/base.html.twig' %}
{% block title %}Analytics{% endblock %}
{% block page_title %}Class Analytics{% endblock %}

{% block content %}

{# ── Class Summary ── #}
<div class="stats-grid" style="margin-bottom:24px;">
    {% set all_avgs = courses|map(c => c.avg) %}
    {% set overall_avg = (all_avgs|reduce((s,v) => s+v, 0) / all_avgs|length)|round %}
    <div class="stat-card">
        <div class="stat-icon" style="background:#e0f2fe;color:#0891b2;"><i class="fa fa-bar-chart"></i></div>
        <div><div class="stat-value">{{ overall_avg }}%</div><div class="stat-label">Overall Avg</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-arrow-up"></i></div>
        <div><div class="stat-value">+13%</div><div class="stat-label">vs Last Month</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fef9c3;color:#a16207;"><i class="fa fa-exclamation-triangle"></i></div>
        <div><div class="stat-value">{{ students|filter(s => s.status=='at_risk')|length }}</div><div class="stat-label">At Risk</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-trophy"></i></div>
        <div><div class="stat-value">{{ students|filter(s => s.status=='excellent')|length }}</div><div class="stat-label">Top Performers</div></div>
    </div>
</div>

{# ── Weekly Trend Chart ── #}
<div class="card" style="margin-bottom:24px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-line-chart t-accent" style="margin-right:6px;"></i>Weekly Class Average (All Courses)</span>
    </div>
    <div class="bar-chart">
        {% for w in weekly %}
        <div class="bar-wrap">
            <div class="bar" data-val="{{ w.avg }}"
                 style="height:{{ w.avg }}%;background:{% if w.avg>=80 %}#0891b2{% elseif w.avg>=70 %}#7c3aed{% else %}#f59e0b{% endif %};">
            </div>
            <div class="bar-label">{{ w.week }}</div>
        </div>
        {% endfor %}
    </div>
</div>

<div class="grid-2" style="gap:20px;margin-bottom:24px;">

    {# ── Per-Course Performance ── #}
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-book t-accent" style="margin-right:6px;"></i>Per-Course Averages</span>
        </div>
        {% for course in courses %}
        <div style="margin-bottom:14px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
                <span style="font-size:13px;font-weight:600;">{{ course.name }}</span>
                <div style="display:flex;align-items:center;gap:8px;">
                    <span style="font-size:12px;color:#64748b;">{{ course.students }} students</span>
                    <span style="font-size:14px;font-weight:800;color:{{ course.avg>=80 ? '#16a34a' : (course.avg>=70 ? '#0891b2' : '#f59e0b') }};">{{ course.avg }}%</span>
                </div>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:{{ course.avg }}%;background:{{ course.color }};height:10px;"></div>
            </div>
        </div>
        {% endfor %}
    </div>

    {# ── Score Distribution ── #}
    <div class="card">
        <div class="card-header">
            <span class="card-title"><i class="fa fa-pie-chart t-accent" style="margin-right:6px;"></i>Score Distribution</span>
        </div>
        {% set buckets = [
            {label: 'A (90–100%)', count: 2, color: '#22c55e'},
            {label: 'B (80–89%)',  count: 3, color: '#0891b2'},
            {label: 'C (70–79%)',  count: 2, color: '#7c3aed'},
            {label: 'D (60–69%)',  count: 1, color: '#f59e0b'},
            {label: 'F (< 60%)',   count: 0, color: '#ef4444'},
        ] %}
        {% set total = 8 %}
        {% for b in buckets %}
        <div style="margin-bottom:12px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                <span style="font-size:13px;font-weight:600;">{{ b.label }}</span>
                <span style="font-size:12px;color:#64748b;">{{ b.count }} students</span>
            </div>
            <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width:{{ total > 0 ? (b.count/total*100)|round : 0 }}%;background:{{ b.color }};height:10px;"></div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

{# ── Student Performance Table ── #}
<div class="card" style="margin-bottom:24px;">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-users t-accent" style="margin-right:6px;"></i>Student Performance Overview</span>
        <a href="{{ path('teacher_messages') }}" class="btn-teal" style="font-size:12px;padding:6px 12px;">
            <i class="fa fa-envelope-o"></i> Message At-Risk
        </a>
    </div>
    <table class="portal-table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Grade</th>
                <th>Avg Score</th>
                <th>Attendance</th>
                <th>GPA</th>
                <th>Trend</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        {% for s in students %}
        <tr>
            <td>
                <div style="display:flex;align-items:center;gap:8px;">
                    <div style="width:32px;height:32px;border-radius:50%;background:{% if s.status=='excellent' %}#dcfce7{% elseif s.status=='at_risk' %}#fee2e2{% else %}#e0f2fe{% endif %};display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;color:{% if s.status=='excellent' %}#16a34a{% elseif s.status=='at_risk' %}#b91c1c{% else %}#0891b2{% endif %};">
                        {{ s.name|split(' ')|first|slice(0,1) }}{{ s.name|split(' ')|last|slice(0,1) }}
                    </div>
                    <span style="font-size:13px;font-weight:600;">{{ s.name }}</span>
                </div>
            </td>
            <td style="font-size:13px;">{{ s.grade }}</td>
            <td>
                <div style="display:flex;align-items:center;gap:8px;">
                    <div class="perf-bar"><div class="perf-bar-fill" style="width:{{ s.avg_score }}%;background:{% if s.avg_score>=80 %}#22c55e{% elseif s.avg_score>=70 %}#0891b2{% else %}#f59e0b{% endif %};"></div></div>
                    <span style="font-size:13px;font-weight:700;">{{ s.avg_score }}%</span>
                </div>
            </td>
            <td>
                <span style="font-size:13px;{% if s.attendance < 80 %}color:#ef4444;font-weight:700;{% endif %}">{{ s.attendance }}%</span>
            </td>
            <td style="font-size:13px;font-weight:700;">{{ s.gpa }}</td>
            <td style="font-size:16px;">
                {% if s.status == 'excellent' %}<i class="fa fa-arrow-up" style="color:#22c55e;"></i>
                {% elseif s.status == 'at_risk' %}<i class="fa fa-arrow-down" style="color:#ef4444;"></i>
                {% else %}<i class="fa fa-minus" style="color:#94a3b8;"></i>{% endif %}
            </td>
            <td>
                <span class="badge badge-{% if s.status=='excellent' %}success{% elseif s.status=='at_risk' %}danger{% else %}primary{% endif %}">
                    {{ s.status|replace({'_':' '})|title }}
                </span>
            </td>
            <td>
                <a href="{{ path('teacher_messages') }}" class="btn btn-outline btn-sm" title="Message student" style="font-size:11px;">
                    <i class="fa fa-envelope-o"></i>
                </a>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{# ── Reusable Content Templates Section ── #}
<div class="card">
    <div class="card-header">
        <span class="card-title"><i class="fa fa-copy t-accent" style="margin-right:6px;"></i>Reusable Templates</span>
        <button class="btn-teal" style="font-size:12px;padding:6px 12px;" onclick="alert('Template library coming soon!')">
            <i class="fa fa-plus"></i> Save Template
        </button>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap;padding:8px 0;">
        {% for tpl in [
            {name: 'Weekly Quiz Template', type: 'quiz', icon: 'pencil-square-o', color: '#7c3aed'},
            {name: 'Lab Report Rubric', type: 'rubric', icon: 'list-alt', color: '#059669'},
            {name: 'Mid-Term Assignment', type: 'assignment', icon: 'tasks', color: '#d97706'},
            {name: 'Announcement Template', type: 'announce', icon: 'bullhorn', color: '#0891b2'},
        ] %}
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:14px 18px;display:flex;align-items:center;gap:10px;cursor:pointer;min-width:200px;" onclick="alert('Load template: {{ tpl.name }}')">
            <div style="width:36px;height:36px;border-radius:8px;background:{{ tpl.color }}20;display:flex;align-items:center;justify-content:center;color:{{ tpl.color }};font-size:16px;">
                <i class="fa fa-{{ tpl.icon }}"></i>
            </div>
            <div>
                <div style="font-size:13px;font-weight:700;">{{ tpl.name }}</div>
                <div style="font-size:11px;color:#64748b;text-transform:capitalize;">{{ tpl.type }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

{% endblock %}
