{% extends 'admin/base.html.twig' %}
{% block title %}Issue Handling & Moderation{% endblock %}
{% block page_title %}Issue Handling & Moderation{% endblock %}

{% block content %}

<div class="stats-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px;">
    <div class="stat-card"><div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-flag"></i></div><div class="stat-body"><div class="stat-value">{{ tickets|length }}</div><div class="stat-label">Complaints & Reports</div></div></div>
    <div class="stat-card amber"><div class="stat-icon" style="background:#fef9c3;color:#b45309;"><i class="fa fa-comments"></i></div><div class="stat-body"><div class="stat-value">{{ moderation_queue|length }}</div><div class="stat-label">Moderation Queue</div></div></div>
    <div class="stat-card teal"><div class="stat-icon" style="background:#e0f2fe;color:#0891b2;"><i class="fa fa-exchange"></i></div><div class="stat-body"><div class="stat-value">2</div><div class="stat-label">Conflicts In Review</div></div></div>
    <div class="stat-card red"><div class="stat-icon" style="background:#fee2e2;color:#ef4444;"><i class="fa fa-level-up"></i></div><div class="stat-body"><div class="stat-value">{{ escalations|length }}</div><div class="stat-label">Escalations</div></div></div>
    <div class="stat-card green"><div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-file-text-o"></i></div><div class="stat-body"><div class="stat-value">{{ incidents|length }}</div><div class="stat-label">Incident Logs</div></div></div>
</div>

<div class="card" style="margin-bottom:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-inbox a-accent" style="margin-right:6px;"></i>Handle Complaints/Reports</span></div>
    <table class="portal-table">
        <thead><tr><th>ID</th><th>Issue</th><th>Reporter</th><th>Type</th><th>Priority</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        {% for t in tickets %}
        <tr>
            <td style="font-weight:700;">{{ t.id }}</td>
            <td>{{ t.title }}</td>
            <td>{{ t.reporter }}</td>
            <td>{{ t.type }}</td>
            <td><span class="role-badge {{ t.priority == 'high' ? 'status-overdue' : 'status-pending' }}">{{ t.priority }}</span></td>
            <td><span class="role-badge {{ t.status == 'open' ? 'status-pending' : 'status-active' }}">{{ t.status }}</span></td>
            <td style="display:flex;gap:6px;">
                <form method="post" action="{{ path('admin_issues') }}" style="display:inline;"><input type="hidden" name="action" value="handle_complaint"><button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-wrench"></i></button></form>
                <form method="post" action="{{ path('admin_issues') }}" style="display:inline;"><input type="hidden" name="action" value="escalate_super_admin"><button class="btn-danger-sm" type="submit"><i class="fa fa-level-up"></i></button></form>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-comments-o a-accent" style="margin-right:6px;"></i>Moderate Discussions/Content</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Channel</th><th>Flagged Content</th><th>Owner</th><th>Status</th></tr></thead>
            <tbody>
            {% for m in moderation_queue %}
            <tr>
                <td style="font-weight:700;">{{ m.channel }}</td>
                <td>{{ m.content }}</td>
                <td>{{ m.owner }}</td>
                <td><span class="role-badge status-pending">{{ m.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_issues') }}"><input type="hidden" name="action" value="moderate_content"><button class="btn-purple" type="submit"><i class="fa fa-gavel"></i> Apply Moderation Action</button></form>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-handshake-o a-accent" style="margin-right:6px;"></i>Resolve Student/Teacher Conflicts</span></div>
        <div style="font-size:13px;color:#475569;margin-bottom:12px;">Record mediation outcomes and resolve active student-teacher disputes.</div>
        <form method="post" action="{{ path('admin_issues') }}">
            <input type="hidden" name="action" value="resolve_conflict">
            <div class="form-group"><label class="form-label">Conflict Case</label><select class="form-control" name="case"><option>CF-2113 - Teacher-student scheduling conflict</option><option>CMP-2104 - Grade dispute in Grade 10-B</option></select></div>
            <div class="form-group"><label class="form-label">Resolution Note</label><textarea class="form-control" rows="3" name="resolution_note" placeholder="Summary of agreed resolution..."></textarea></div>
            <button class="btn-purple" type="submit"><i class="fa fa-check"></i> Mark Conflict Resolved</button>
        </form>
    </div>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-level-up a-accent" style="margin-right:6px;"></i>Escalate to Super Admin</span></div>
    <table class="portal-table">
        <thead><tr><th>Ticket</th><th>Reason</th><th>Target</th><th>Status</th></tr></thead>
        <tbody>
        {% for e in escalations %}
        <tr>
            <td style="font-weight:700;">{{ e.ticket }}</td>
            <td>{{ e.reason }}</td>
            <td>{{ e.target }}</td>
            <td><span class="role-badge status-pending">{{ e.status }}</span></td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
    <form method="post" action="{{ path('admin_issues') }}" style="margin-top:10px;"><input type="hidden" name="action" value="escalate_super_admin"><button class="btn-danger-sm" type="submit"><i class="fa fa-level-up"></i> Escalate Selected Issue</button></form>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-star a-accent" style="margin-right:6px;"></i>Premium Support Operations</span></div>
    <div class="grid-2" style="gap:20px;">
        <div style="border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;padding:12px;">
            <div style="font-size:13px;font-weight:800;color:#4c1d95;margin-bottom:8px;">Ticketing System (Internal Support)</div>
            <div style="font-size:12px;color:#6d28d9;margin-bottom:10px;">Create and route tickets to Admin, Counselor, IT, or Super Admin teams.</div>
            <form method="post" action="{{ path('admin_issues') }}"><input type="hidden" name="action" value="create_ticket"><button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-ticket"></i> Create Internal Ticket</button></form>
        </div>

        <div style="border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;padding:12px;">
            <div style="font-size:13px;font-weight:800;color:#4c1d95;margin-bottom:8px;">Incident Tracking Logs</div>
            <table class="portal-table" style="margin-bottom:10px;">
                <thead><tr><th>Incident</th><th>Category</th><th>Opened</th><th>Owner</th><th>Status</th></tr></thead>
                <tbody>
                {% for i in incidents %}
                <tr>
                    <td style="font-weight:700;">{{ i.incident }}</td>
                    <td>{{ i.category }}</td>
                    <td>{{ i.opened }}</td>
                    <td>{{ i.owner }}</td>
                    <td><span class="role-badge {{ i.status == 'mitigated' ? 'status-active' : 'status-pending' }}">{{ i.status }}</span></td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
            <form method="post" action="{{ path('admin_issues') }}"><input type="hidden" name="action" value="update_incident_log"><button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-save"></i> Update Incident Log</button></form>
        </div>
    </div>
</div>

{% endblock %}
