{% extends 'admin/base.html.twig' %}
{% block title %}School Branding & Customization{% endblock %}
{% block page_title %}School Branding & Customization{% endblock %}

{% block content %}

<div class="stats-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px;">
    <div class="stat-card"><div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-image"></i></div><div class="stat-body"><div class="stat-value">{{ brand_assets|length }}</div><div class="stat-label">Brand Assets</div></div></div>
    <div class="stat-card teal"><div class="stat-icon" style="background:#e0f2fe;color:#0891b2;"><i class="fa fa-paint-brush"></i></div><div class="stat-body"><div class="stat-value">{{ theme_options|length }}</div><div class="stat-label">Theme Profiles</div></div></div>
    <div class="stat-card amber"><div class="stat-icon" style="background:#fef9c3;color:#b45309;"><i class="fa fa-envelope"></i></div><div class="stat-body"><div class="stat-value">{{ email_templates|length }}</div><div class="stat-label">Email Templates</div></div></div>
    <div class="stat-card green"><div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-file-text-o"></i></div><div class="stat-body"><div class="stat-value">{{ report_card_designs|length }}</div><div class="stat-label">Report Card Designs</div></div></div>
    <div class="stat-card red"><div class="stat-icon" style="background:#fee2e2;color:#ef4444;"><i class="fa fa-dashboard"></i></div><div class="stat-body"><div class="stat-value">{{ role_dashboards|length }}</div><div class="stat-label">Role Dashboards</div></div></div>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-upload a-accent" style="margin-right:6px;"></i>Upload School Logo</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Asset Type</th><th>File</th><th>Status</th></tr></thead>
            <tbody>
            {% for a in brand_assets %}
            <tr><td style="font-weight:700;">{{ a.type }}</td><td>{{ a.file }}</td><td><span class="role-badge status-active">{{ a.status }}</span></td></tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_branding') }}">
            <input type="hidden" name="action" value="upload_logo">
            <div class="form-group"><label class="form-label">Logo File</label><input type="file" class="form-control" accept=".png,.jpg,.jpeg,.svg"></div>
            <button class="btn-purple" type="submit"><i class="fa fa-save"></i> Save Logo</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-paint-brush a-accent" style="margin-right:6px;"></i>Customize Colors/Theme</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Theme</th><th>Primary</th><th>Accent</th><th>Status</th></tr></thead>
            <tbody>
            {% for t in theme_options %}
            <tr>
                <td style="font-weight:700;">{{ t.name }}</td>
                <td><span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:{{ t.primary }};margin-right:6px;border:1px solid #e2e8f0;"></span>{{ t.primary }}</td>
                <td><span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:{{ t.accent }};margin-right:6px;border:1px solid #e2e8f0;"></span>{{ t.accent }}</td>
                <td><span class="role-badge {{ t.status == 'active' ? 'status-active' : 'status-pending' }}">{{ t.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_branding') }}" style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;">
            <input type="hidden" name="action" value="save_theme">
            <div class="form-group" style="margin-bottom:0;"><label class="form-label">Primary Color</label><input class="form-control" name="primary" value="#7c3aed"></div>
            <div class="form-group" style="margin-bottom:0;"><label class="form-label">Accent Color</label><input class="form-control" name="accent" value="#0891b2"></div>
            <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-save"></i> Save Theme</button>
        </form>
    </div>
</div>

<div class="grid-2" style="gap:20px;margin-top:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-envelope-o a-accent" style="margin-right:6px;"></i>Configure Email Templates</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Template</th><th>Subject</th><th>Status</th></tr></thead>
            <tbody>
            {% for e in email_templates %}
            <tr><td style="font-weight:700;">{{ e.name }}</td><td>{{ e.subject }}</td><td><span class="role-badge status-active">{{ e.status }}</span></td></tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_branding') }}">
            <input type="hidden" name="action" value="save_email_template">
            <button class="btn-purple" type="submit"><i class="fa fa-save"></i> Save Email Templates</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-id-card a-accent" style="margin-right:6px;"></i>Set Report Card Design</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Design</th><th>Layout</th><th>Status</th></tr></thead>
            <tbody>
            {% for r in report_card_designs %}
            <tr><td style="font-weight:700;">{{ r.name }}</td><td>{{ r.layout }}</td><td><span class="role-badge {{ r.status == 'active' ? 'status-active' : 'status-pending' }}">{{ r.status }}</span></td></tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_branding') }}">
            <input type="hidden" name="action" value="save_report_card_design">
            <button class="btn-purple" type="submit"><i class="fa fa-save"></i> Save Report Card Design</button>
        </form>
    </div>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-star a-accent" style="margin-right:6px;"></i>Premium Branding</span></div>
    <div class="grid-2" style="gap:20px;">
        <div style="border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;padding:12px;">
            <div style="font-size:13px;font-weight:800;color:#4c1d95;margin-bottom:8px;">Fully Branded Portal (White-Label Feel)</div>
            <div style="font-size:12px;color:#6d28d9;margin-bottom:10px;">Apply institution identity across login pages, portals, and generated documents.</div>
            <form method="post" action="{{ path('admin_branding') }}"><input type="hidden" name="action" value="apply_white_label"><button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-magic"></i> Apply White-Label</button></form>
        </div>

        <div style="border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;padding:12px;">
            <div style="font-size:13px;font-weight:800;color:#4c1d95;margin-bottom:8px;">Custom Dashboards Per Role</div>
            <table class="portal-table" style="margin-bottom:10px;">
                <thead><tr><th>Role</th><th>Widgets</th><th>Status</th></tr></thead>
                <tbody>
                {% for d in role_dashboards %}
                <tr>
                    <td style="font-weight:700;">{{ d.role }}</td>
                    <td>{{ d.widgets }}</td>
                    <td><span class="role-badge status-active">{{ d.status }}</span></td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
            <form method="post" action="{{ path('admin_branding') }}"><input type="hidden" name="action" value="save_role_dashboard"><button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-save"></i> Save Role Dashboards</button></form>
        </div>
    </div>
</div>

{% endblock %}
