{% extends 'admin/base.html.twig' %}
{% block title %}Permissions & Access Control{% endblock %}
{% block page_title %}Permissions & Access Control{% endblock %}

{% block content %}

<div class="stats-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px;">
    <div class="stat-card"><div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-shield"></i></div><div class="stat-body"><div class="stat-value">{{ permission_matrix|length }}</div><div class="stat-label">Role Profiles</div></div></div>
    <div class="stat-card amber"><div class="stat-icon" style="background:#fef9c3;color:#b45309;"><i class="fa fa-lock"></i></div><div class="stat-body"><div class="stat-value">{{ sensitive_policies|length }}</div><div class="stat-label">Sensitive Data Rules</div></div></div>
    <div class="stat-card teal"><div class="stat-icon" style="background:#e0f2fe;color:#0891b2;"><i class="fa fa-user-plus"></i></div><div class="stat-body"><div class="stat-value">{{ custom_roles|length }}</div><div class="stat-label">Custom Roles</div></div></div>
    <div class="stat-card green"><div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-sign-in"></i></div><div class="stat-body"><div class="stat-value">{{ login_policies|length }}</div><div class="stat-label">Login Policies</div></div></div>
    <div class="stat-card red"><div class="stat-icon" style="background:#fee2e2;color:#ef4444;"><i class="fa fa-clock-o"></i></div><div class="stat-body"><div class="stat-value">{{ temporary_access_list|length }}</div><div class="stat-label">Temporary Access</div></div></div>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-sitemap a-accent" style="margin-right:6px;"></i>Define Role-Based Permissions</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Role</th><th>Users</th><th>Permissions</th></tr></thead>
            <tbody>
            {% for r in permission_matrix %}
            <tr>
                <td style="font-weight:700;">{{ r.role }}</td>
                <td>{{ r.users }}</td>
                <td>{{ r.permissions|join(', ') }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_permissions') }}">
            <input type="hidden" name="action" value="save_role_permissions">
            <button class="btn-purple" type="submit"><i class="fa fa-save"></i> Save Role Permissions</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-user-secret a-accent" style="margin-right:6px;"></i>Restrict Access to Sensitive Data</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Data Domain</th><th>Access</th><th>Protection</th><th>Status</th></tr></thead>
            <tbody>
            {% for p in sensitive_policies %}
            <tr>
                <td style="font-weight:700;">{{ p.name }}</td>
                <td>{{ p.access_level }}</td>
                <td>{{ p.protection }}</td>
                <td><span class="role-badge status-active">{{ p.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_permissions') }}">
            <input type="hidden" name="action" value="save_sensitive_access">
            <button class="btn-purple" type="submit"><i class="fa fa-save"></i> Save Sensitive Access Rules</button>
        </form>
    </div>
</div>

<div class="grid-2" style="gap:20px;margin-top:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-user-plus a-accent" style="margin-right:6px;"></i>Create Custom Roles</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Role</th><th>Scope</th><th>Status</th></tr></thead>
            <tbody>
            {% for c in custom_roles %}
            <tr>
                <td style="font-weight:700;">{{ c.name }}</td>
                <td>{{ c.scope }}</td>
                <td><span class="role-badge {{ c.status == 'active' ? 'status-active' : 'status-pending' }}">{{ c.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_permissions') }}" style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;">
            <input type="hidden" name="action" value="create_custom_role">
            <div class="form-group" style="margin-bottom:0;"><label class="form-label">Role Name</label><input class="form-control" name="role_name" placeholder="Exam Coordinator"></div>
            <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-plus"></i> Add Role</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-sign-in a-accent" style="margin-right:6px;"></i>Manage Login Policies</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Policy</th><th>Rule</th><th>Status</th></tr></thead>
            <tbody>
            {% for l in login_policies %}
            <tr>
                <td style="font-weight:700;">{{ l.name }}</td>
                <td>{{ l.rule }}</td>
                <td><span class="role-badge {{ l.status == 'active' ? 'status-active' : 'status-pending' }}">{{ l.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_permissions') }}">
            <input type="hidden" name="action" value="save_login_policy">
            <button class="btn-purple" type="submit"><i class="fa fa-save"></i> Save Login Policies</button>
        </form>
    </div>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-star a-accent" style="margin-right:6px;"></i>Premium Access Control</span></div>
    <div class="grid-2" style="gap:20px;">
        <div style="border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;padding:12px;">
            <div style="font-size:13px;font-weight:800;color:#4c1d95;margin-bottom:8px;">Fine-Grained Permissions (Per Feature/Action)</div>
            <table class="portal-table" style="margin-bottom:10px;">
                <thead><tr><th>Feature</th><th>Action</th><th>Granted To</th></tr></thead>
                <tbody>
                {% for f in fine_grained %}
                <tr><td style="font-weight:700;">{{ f.feature }}</td><td>{{ f.action }}</td><td>{{ f.granted_to }}</td></tr>
                {% endfor %}
                </tbody>
            </table>
            <form method="post" action="{{ path('admin_permissions') }}"><input type="hidden" name="action" value="save_fine_grained"><button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-save"></i> Save Fine-Grained Rules</button></form>
        </div>

        <div style="border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;padding:12px;">
            <div style="font-size:13px;font-weight:800;color:#4c1d95;margin-bottom:8px;">Temporary Access (Time-Limited Roles)</div>
            <table class="portal-table" style="margin-bottom:10px;">
                <thead><tr><th>User</th><th>Role</th><th>Expires</th><th>Status</th></tr></thead>
                <tbody>
                {% for t in temporary_access_list %}
                <tr>
                    <td style="font-weight:700;">{{ t.user }}</td>
                    <td>{{ t.role }}</td>
                    <td>{{ t.expires_at }}</td>
                    <td><span class="role-badge status-pending">{{ t.status }}</span></td>
                </tr>
                {% endfor %}
                </tbody>
            </table>
            <form method="post" action="{{ path('admin_permissions') }}" style="display:flex;gap:8px;flex-wrap:wrap;align-items:end;">
                <input type="hidden" name="action" value="grant_temporary_access">
                <div class="form-group" style="margin-bottom:0;"><label class="form-label">User</label><input class="form-control" name="user" placeholder="Ms. Sarah Lee"></div>
                <div class="form-group" style="margin-bottom:0;"><label class="form-label">Role</label><input class="form-control" name="role" placeholder="Exam Coordinator"></div>
                <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-clock-o"></i> Grant Temporary Access</button>
            </form>
        </div>
    </div>
</div>

{% endblock %}
