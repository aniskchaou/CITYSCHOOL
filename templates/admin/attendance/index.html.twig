{% extends 'admin/base.html.twig' %}
{% block title %}Attendance Management{% endblock %}
{% block page_title %}Attendance Management{% endblock %}

{% block content %}

{% set low_students = student_attendance|filter(s => s.rate < 85) %}
{% set low_teachers = teacher_attendance|filter(t => t.rate < 90) %}

<div class="stats-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px;">
    <div class="stat-card"><div class="stat-icon" style="background:#ede9fe;color:#7c3aed;"><i class="fa fa-user"></i></div><div class="stat-body"><div class="stat-value">{{ student_attendance|length }}</div><div class="stat-label">Students Tracked</div></div></div>
    <div class="stat-card teal"><div class="stat-icon" style="background:#e0f2fe;color:#0891b2;"><i class="fa fa-user-circle"></i></div><div class="stat-body"><div class="stat-value">{{ teacher_attendance|length }}</div><div class="stat-label">Teachers Tracked</div></div></div>
    <div class="stat-card amber"><div class="stat-icon" style="background:#fef9c3;color:#b45309;"><i class="fa fa-bell"></i></div><div class="stat-body"><div class="stat-value">{{ attendance_alerts|length }}</div><div class="stat-label">Active Alerts</div></div></div>
    <div class="stat-card red"><div class="stat-icon" style="background:#fee2e2;color:#ef4444;"><i class="fa fa-exclamation-triangle"></i></div><div class="stat-body"><div class="stat-value">{{ low_students|length + low_teachers|length }}</div><div class="stat-label">Low Attendance Cases</div></div></div>
    <div class="stat-card green"><div class="stat-icon" style="background:#dcfce7;color:#16a34a;"><i class="fa fa-file-text-o"></i></div><div class="stat-body"><div class="stat-value">{{ absence_requests|length }}</div><div class="stat-label">Absence Requests</div></div></div>
</div>

<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
    <form method="post" action="{{ path('admin_attendance') }}" style="display:inline;"><button class="btn-purple" name="action" value="realtime_tracking"><i class="fa fa-broadcast-tower"></i> Enable Real-Time Tracking</button></form>
    <form method="post" action="{{ path('admin_attendance') }}" style="display:inline;"><button class="btn btn-outline btn-sm" name="action" value="send_low_attendance_alerts"><i class="fa fa-bell"></i> Send Low Attendance Alerts</button></form>
    <form method="post" action="{{ path('admin_attendance') }}" style="display:inline;"><button class="btn btn-outline btn-sm" name="action" value="generate_attendance_report"><i class="fa fa-download"></i> Generate Attendance Report</button></form>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-book a-accent" style="margin-right:6px;"></i>Monitor Student Attendance</span></div>
        <table class="portal-table">
            <thead><tr><th>Student</th><th>Class</th><th>Present</th><th>Rate</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
            {% for s in student_attendance %}
            <tr>
                <td style="font-weight:700;">{{ s.student }}</td>
                <td>{{ s.class }}</td>
                <td>{{ s.present }}/{{ s.total }}</td>
                <td>{{ s.rate }}%</td>
                <td>
                    <span class="role-badge {{ s.status == 'good' ? 'status-active' : (s.status == 'warning' ? 'status-pending' : 'status-overdue') }}">{{ s.status }}</span>
                </td>
                <td>
                    <form method="post" action="{{ path('admin_attendance') }}" style="display:inline;">
                        <input type="hidden" name="action" value="monitor_students">
                        <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-refresh"></i></button>
                    </form>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-user-md a-accent" style="margin-right:6px;"></i>Monitor Teacher Attendance</span></div>
        <table class="portal-table">
            <thead><tr><th>Teacher</th><th>Department</th><th>Present</th><th>Rate</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
            {% for t in teacher_attendance %}
            <tr>
                <td style="font-weight:700;">{{ t.teacher }}</td>
                <td>{{ t.department }}</td>
                <td>{{ t.present }}/{{ t.total }}</td>
                <td>{{ t.rate }}%</td>
                <td>
                    <span class="role-badge {{ t.status == 'good' ? 'status-active' : 'status-pending' }}">{{ t.status }}</span>
                </td>
                <td>
                    <form method="post" action="{{ path('admin_attendance') }}" style="display:inline;">
                        <input type="hidden" name="action" value="monitor_teachers">
                        <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-refresh"></i></button>
                    </form>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-envelope-open-o a-accent" style="margin-right:6px;"></i>Approve/Reject Absence Requests</span></div>
    <table class="portal-table">
        <thead><tr><th>Name</th><th>Type</th><th>Period</th><th>Reason</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        {% for r in absence_requests %}
        <tr>
            <td style="font-weight:700;">{{ r.name }}</td>
            <td>{{ r.type }}</td>
            <td>{{ r.from }} to {{ r.to }}</td>
            <td>{{ r.reason }}</td>
            <td><span class="role-badge {{ r.status == 'approved' ? 'status-active' : 'status-pending' }}">{{ r.status }}</span></td>
            <td style="display:flex;gap:6px;">
                <form method="post" action="{{ path('admin_attendance') }}" style="display:inline;"><input type="hidden" name="action" value="approve_absence"><button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-check"></i> Approve</button></form>
                <form method="post" action="{{ path('admin_attendance') }}" style="display:inline;"><input type="hidden" name="action" value="reject_absence"><button class="btn-danger-sm" type="submit"><i class="fa fa-ban"></i> Reject</button></form>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="grid-2" style="gap:20px;margin-top:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-sliders a-accent" style="margin-right:6px;"></i>Set Attendance Rules (Thresholds)</span></div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Rule</th><th>Value</th><th>Scope</th><th>Status</th></tr></thead>
            <tbody>
            {% for rule in attendance_rules %}
            <tr>
                <td style="font-weight:700;">{{ rule.name }}</td>
                <td>{{ rule.value }}</td>
                <td>{{ rule.scope }}</td>
                <td><span class="role-badge {{ rule.status == 'active' ? 'status-active' : 'status-inactive' }}">{{ rule.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('admin_attendance') }}" style="display:flex;gap:8px;flex-wrap:wrap;">
            <input type="hidden" name="action" value="save_attendance_rule">
            <button class="btn-purple" type="submit"><i class="fa fa-save"></i> Save Threshold Rules</button>
        </form>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-star a-accent" style="margin-right:6px;"></i>Premium: Alerts & Integration</span></div>
        <div style="padding:12px;border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;margin-bottom:12px;">
            <div style="font-size:13px;font-weight:700;color:#4c1d95;">Real-Time Attendance Tracking</div>
            <div style="font-size:12px;color:#6d28d9;margin-top:5px;">Live attendance feed synced every minute from classroom check-ins.</div>
        </div>
        <div style="padding:12px;border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;margin-bottom:12px;">
            <div style="font-size:13px;font-weight:700;color:#4c1d95;">Low Attendance Alerts</div>
            <div style="font-size:12px;color:#6d28d9;margin-top:5px;">Automated alerts to admins/parents when attendance falls below threshold.</div>
        </div>
        <div style="padding:12px;border:1px solid #ede9fe;border-radius:8px;background:#faf5ff;">
            <div style="font-size:13px;font-weight:700;color:#4c1d95;">Biometric / QR Integration</div>
            <div style="font-size:12px;color:#6d28d9;margin-top:5px;">Connect biometric devices or QR scanners to auto-mark attendance.</div>
        </div>
        <form method="post" action="{{ path('admin_attendance') }}" style="margin-top:12px;">
            <input type="hidden" name="action" value="save_biometric_qr">
            <button class="btn btn-outline btn-sm" type="submit"><i class="fa fa-qrcode"></i> Save Biometric/QR Settings</button>
        </form>
    </div>
</div>

<div class="card" style="margin-top:20px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-bell a-accent" style="margin-right:6px;"></i>Low Attendance Alerts Queue</span></div>
    <table class="portal-table">
        <thead><tr><th>Audience</th><th>Target</th><th>Message</th><th>Severity</th></tr></thead>
        <tbody>
        {% for a in attendance_alerts %}
        <tr>
            <td>{{ a.audience }}</td>
            <td style="font-weight:700;">{{ a.target }}</td>
            <td>{{ a.message }}</td>
            <td><span class="role-badge {{ a.severity == 'danger' ? 'status-overdue' : 'status-pending' }}">{{ a.severity }}</span></td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
