{% extends 'super_admin/base.html.twig' %}
{% block title %}Subscriptions{% endblock %}
{% block page_title %}Subscriptions & Plans{% endblock %}

{% block content %}
{% set paidInvoices = invoices|filter(i => i.status == 'paid') %}
{% set pendingInvoices = invoices|filter(i => i.status == 'pending') %}
{% set overdueInvoices = invoices|filter(i => i.status == 'overdue') %}
<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:18px;">
    <div class="super-kpi"><div class="kpi-value">${{ revenue.mrr|number_format }}</div><div class="kpi-label">Monthly Recurring Revenue</div></div>
    <div class="super-kpi"><div class="kpi-value">${{ revenue.collected|number_format }}</div><div class="kpi-label">Collected Revenue</div></div>
    <div class="super-kpi"><div class="kpi-value">${{ revenue.pending|number_format }}</div><div class="kpi-label">Pending Revenue</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ subscriptions|length }}</div><div class="kpi-label">Total Subscriptions</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ failed_payments|length }}</div><div class="kpi-label">Failed Payment Queue</div></div>
</div>

<div class="card" style="margin-bottom:18px;">
    <div class="card-header" style="justify-content:space-between;gap:12px;align-items:flex-start;">
        <span class="card-title"><i class="fa fa-tags" style="margin-right:6px;color:#f97316;"></i>Pricing Plans</span>
        <form method="post" action="{{ path('super_admin_subscriptions') }}" style="display:flex;gap:8px;align-items:end;flex-wrap:wrap;justify-content:flex-end;">
            <input type="hidden" name="action" value="create_plan">
            <div class="form-group" style="margin:0;min-width:140px;"><label class="form-label">Plan Name</label><input class="form-control" name="plan_name" placeholder="Growth"></div>
            <div class="form-group" style="margin:0;min-width:110px;"><label class="form-label">Price</label><input class="form-control" name="plan_price" type="number" min="0" value="999"></div>
            <div class="form-group" style="margin:0;min-width:130px;"><label class="form-label">Billing</label><select class="form-control" name="plan_billing"><option>Monthly</option><option>Yearly</option></select></div>
            <div class="form-group" style="margin:0;min-width:130px;"><label class="form-label">Students</label><input class="form-control" name="student_limit" type="number" min="0" value="500"></div>
            <div class="form-group" style="margin:0;min-width:130px;"><label class="form-label">Storage (GB)</label><input class="form-control" name="storage_limit_gb" type="number" min="0" value="100"></div>
            <div class="form-group" style="margin:0;min-width:220px;"><label class="form-label">Features</label><input class="form-control" name="plan_features" placeholder="Core LMS, Analytics"></div>
            <button class="btn-orange" type="submit"><i class="fa fa-plus"></i> Create Plan</button>
        </form>
    </div>
    <table class="portal-table">
        <thead><tr><th>Plan</th><th>Price</th><th>Billing</th><th>Student Limit</th><th>Storage Limit</th><th>Campuses</th><th>Status</th><th>Features</th></tr></thead>
        <tbody>
        {% for p in plans %}
        <tr>
            <td><span class="role-badge plan-{{ p.name|lower == 'basic' ? 'starter' : p.name|lower }}">{{ p.name }}</span></td>
            <td>${{ p.price|number_format }}</td>
            <td>{{ p.billing }}</td>
            <td>{{ p.studentLimit }}</td>
            <td>{{ p.storageLimitGb }} GB</td>
            <td>{{ p.campuses }}</td>
            <td><span class="super-tag {{ p.status == 'active' ? 'active' : 'trial' }}">{{ p.status }}</span></td>
            <td>
                {% for f in p.features %}
                    <span class="metric-chip" style="margin:2px 4px 2px 0;">{{ f }}</span>
                {% endfor %}
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="grid-2" style="gap:20px;margin-bottom:18px;align-items:start;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-line-chart" style="margin-right:6px;color:#f97316;"></i>Revenue Tracking</span></div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px;">
            <div class="super-card"><div style="font-size:12px;color:#9a3412;text-transform:uppercase;font-weight:700;">ARR</div><div style="font-size:24px;font-weight:900;color:#7c2d12;">${{ revenue.arr|number_format }}</div></div>
            <div class="super-card"><div style="font-size:12px;color:#9a3412;text-transform:uppercase;font-weight:700;">Pending Invoices</div><div style="font-size:24px;font-weight:900;color:#7c2d12;">{{ pendingInvoices|length }}</div></div>
            <div class="super-card"><div style="font-size:12px;color:#9a3412;text-transform:uppercase;font-weight:700;">Overdue Invoices</div><div style="font-size:24px;font-weight:900;color:#7c2d12;">{{ overdueInvoices|length }}</div></div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;align-items:end;min-height:130px;">
            {% set maxTrend = revenue.trend|map(t => t.value)|reduce((carry, value) => value > carry ? value : carry, 1) %}
            {% for point in revenue.trend %}
            <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
                <div style="width:100%;max-width:42px;height:{{ ((point.value / maxTrend) * 100)|round }}px;background:linear-gradient(180deg,#fdba74,#f97316);border-radius:10px 10px 0 0;"></div>
                <div style="font-size:11px;color:#64748b;text-align:center;">{{ point.month }}<br><strong>${{ point.value|number_format }}</strong></div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-pie-chart" style="margin-right:6px;color:#f97316;"></i>Revenue by Plan</span></div>
        <table class="portal-table">
            <thead><tr><th>Plan</th><th>Revenue</th></tr></thead>
            <tbody>
            {% for plan, total in revenue.planBreakdown %}
            <tr>
                <td><span class="role-badge plan-{{ plan|lower }}">{{ plan }}</span></td>
                <td>${{ total|number_format }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="card" style="margin-bottom:18px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-credit-card" style="margin-right:6px;color:#f97316;"></i>All Subscriptions</span></div>
    <table class="portal-table">
        <thead><tr><th>School</th><th>Plan</th><th>Amount</th><th>Billing</th><th>Renewal</th><th>Students</th><th>Storage</th><th>Payment</th><th>Next Invoice</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        {% for s in subscriptions %}
        <tr>
            <td style="font-weight:700;">{{ s.school }}</td>
            <td><span class="role-badge plan-{{ s.plan|lower }}">{{ s.plan }}</span></td>
            <td>${{ s.amount|number_format }}</td>
            <td>{{ s.billing }}</td>
            <td><span class="super-tag {{ s.renewal == 'auto' ? 'active' : 'trial' }}">{{ s.renewal }}</span></td>
            <td>{{ s.studentsBillable }} / {{ s.studentLimit }}</td>
            <td>{{ s.storageUsedGb }} / {{ s.storageLimitGb }} GB</td>
            <td><span class="super-tag {{ s.paymentHealth == 'healthy' ? 'active' : (s.paymentHealth == 'grace_period' ? 'trial' : 'suspended') }}">{{ s.paymentHealth }}</span></td>
            <td>{{ s.nextInvoice }}</td>
            <td><span class="super-tag {{ s.status == 'active' ? 'active' : (s.status == 'suspended' ? 'suspended' : 'trial') }}">{{ s.status }}</span></td>
            <td>
                <form method="post" action="{{ path('super_admin_subscriptions') }}" style="display:flex;gap:6px;flex-wrap:wrap;">
                    <input type="hidden" name="sub_id" value="{{ s.id }}">
                    <select class="form-control" name="target_plan" style="min-width:120px;height:32px;padding:4px 8px;">
                        {% for p in plans %}
                        <option value="{{ p.name }}" {% if p.name == s.plan %}selected{% endif %}>{{ p.name }}</option>
                        {% endfor %}
                    </select>
                    <button class="btn-orange" style="font-size:11px;padding:5px 10px;" name="action" value="assign_plan" type="submit"><i class="fa fa-link"></i> Assign</button>
                    <button class="btn-orange" style="font-size:11px;padding:5px 10px;" name="action" value="renew" type="submit"><i class="fa fa-refresh"></i> Renew</button>
                    <button class="btn-orange" style="font-size:11px;padding:5px 10px;" name="action" value="upgrade" type="submit"><i class="fa fa-arrow-up"></i> Upgrade</button>
                    <button class="btn-orange" style="font-size:11px;padding:5px 10px;" name="action" value="downgrade" type="submit"><i class="fa fa-arrow-down"></i> Downgrade</button>
                </form>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="card" style="margin-bottom:18px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-exclamation-triangle" style="margin-right:6px;color:#f97316;"></i>Failed Payment Operations</span></div>
    <table class="portal-table">
        <thead><tr><th>School</th><th>Plan</th><th>Invoice</th><th>Attempts</th><th>Last Failure</th><th>Next Retry</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
        {% for fp in failed_payments %}
        <tr>
            <td style="font-weight:700;">{{ fp.school }}</td>
            <td>{{ fp.plan }}</td>
            <td>{{ fp.invoice ? fp.invoice.invoiceNo : '-' }}</td>
            <td>{{ fp.failedAttempts }}</td>
            <td>{{ fp.lastFailureAt ?: '-' }}</td>
            <td>{{ fp.nextRetryAt ?: '-' }}</td>
            <td><span class="super-tag {{ fp.status == 'grace_period' ? 'trial' : 'suspended' }}">{{ fp.status }}</span></td>
            <td>
                <form method="post" action="{{ path('super_admin_subscriptions') }}" style="display:flex;gap:6px;flex-wrap:wrap;">
                    <input type="hidden" name="sub_id" value="{{ fp.subscriptionId }}">
                    <input type="hidden" name="school_name" value="{{ fp.school }}">
                    <button class="btn-orange" style="font-size:11px;padding:5px 10px;" name="action" value="retry_failed_payment" type="submit"><i class="fa fa-refresh"></i> Retry</button>
                    <button class="btn-orange" style="font-size:11px;padding:5px 10px;" name="action" value="recover_payment" type="submit"><i class="fa fa-check"></i> Recover</button>
                    <button class="btn-orange" style="font-size:11px;padding:5px 10px;" name="action" value="suspend_failed_payment" type="submit"><i class="fa fa-ban"></i> Suspend</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="8" style="text-align:center;color:#64748b;">No failed payments currently require super-admin attention.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-file-text-o" style="margin-right:6px;color:#f97316;"></i>Invoices & Payments</span></div>
        <table class="portal-table">
            <thead><tr><th>Invoice</th><th>School</th><th>Amount</th><th>Date</th><th>Method</th><th>Status</th></tr></thead>
            <tbody>
            {% for inv in invoices %}
            <tr>
                <td style="font-weight:700;">{{ inv.invoiceNo }}</td>
                <td>{{ inv.school }}</td>
                <td>${{ inv.amount|number_format }}</td>
                <td>{{ inv.date }}</td>
                <td>{{ inv.method }}</td>
                <td><span class="super-tag {{ inv.status == 'paid' ? 'active' : (inv.status == 'overdue' ? 'suspended' : 'trial') }}">{{ inv.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-ticket" style="margin-right:6px;color:#f97316;"></i>Discounts & Coupons</span></div>
        <table class="portal-table" style="margin-bottom:14px;">
            <thead><tr><th>Code</th><th>Type</th><th>Value</th><th>Applies To</th><th>Status</th></tr></thead>
            <tbody>
            {% for c in coupons %}
            <tr>
                <td style="font-weight:800;">{{ c.code }}</td>
                <td>{{ c.type }}</td>
                <td>{{ c.type == 'percent' ? c.value ~ '%' : '$' ~ c.value }}</td>
                <td>{{ c.appliesTo }}</td>
                <td><span class="super-tag {{ c.status == 'active' ? 'active' : 'trial' }}">{{ c.status }}</span></td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <form method="post" action="{{ path('super_admin_subscriptions') }}" style="display:flex;gap:8px;align-items:end;flex-wrap:wrap;">
            <div class="form-group" style="margin:0;min-width:170px;"><label class="form-label">Coupon Code</label><input class="form-control" name="coupon_code" placeholder="WELCOME10"></div>
            <div class="form-group" style="margin:0;min-width:170px;"><label class="form-label">School</label><select class="form-control" name="school_id">{% for sc in schools %}<option value="{{ sc.id }}">{{ sc.name }}</option>{% endfor %}</select></div>
            <button class="btn-orange" type="submit" name="action" value="apply_coupon"><i class="fa fa-check"></i> Apply Coupon</button>
        </form>
    </div>
</div>

<div class="card" style="margin-top:18px;">
    <div class="card-header" style="justify-content:space-between;">
        <span class="card-title"><i class="fa fa-bolt" style="margin-right:6px;color:#f97316;"></i>Premium Monetization Controls</span>
        <form method="post" action="{{ path('super_admin_subscriptions') }}">
            <button class="btn-orange" type="submit" name="action" value="configure_autobilling"><i class="fa fa-plug"></i> Configure Auto Billing (Stripe)</button>
        </form>
    </div>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:14px;">
        <div class="super-card">
            <div style="font-size:14px;font-weight:800;color:#9a3412;margin-bottom:6px;">Automated Billing System</div>
            <div style="font-size:13px;color:#7c2d12;line-height:1.7;">Auto-invoicing, smart retries for failed cards, and webhook reconciliation are enabled in simulation mode.</div>
            <div style="margin-top:8px;"><span class="metric-chip">Provider: Stripe</span> <span class="metric-chip">Retries: 3</span></div>
        </div>
        <div class="super-card">
            <div style="font-size:14px;font-weight:800;color:#9a3412;margin-bottom:6px;">Usage-Based Pricing</div>
            <div style="font-size:13px;color:#7c2d12;line-height:1.7;">Billing can be calculated per active student and feature usage (AI assistant, chat, analytics exports).</div>
            <div style="margin-top:8px;"><span class="metric-chip">Metric: per student</span> <span class="metric-chip">Metric: per feature</span></div>
        </div>
    </div>
</div>
{% endblock %}
