{% extends 'super_admin/base.html.twig' %}
{% block title %}Performance{% endblock %}
{% block page_title %}Monitor Performance & Usage{% endblock %}

{% block content %}
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px;">
    <div class="super-kpi"><div class="kpi-value">{{ performance.uptime }}%</div><div class="kpi-label">Uptime</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ performance.avgLatencyMs }}ms</div><div class="kpi-label">Latency</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ performance.errorRate }}%</div><div class="kpi-label">Error Rate</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ performance.activeUsers|number_format }}</div><div class="kpi-label">Active Users</div></div>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-server" style="margin-right:6px;color:#f97316;"></i>Service Consumption</span></div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;">
            <div class="super-card"><div style="font-size:12px;color:#7c2d12;">API Requests (24h)</div><div style="font-size:22px;font-weight:900;color:#9a3412;">{{ performance.apiRequests|number_format }}</div></div>
            <div class="super-card"><div style="font-size:12px;color:#7c2d12;">Storage Used</div><div style="font-size:22px;font-weight:900;color:#0369a1;">{{ performance.storageUsedGb }} GB</div></div>
            <div class="super-card"><div style="font-size:12px;color:#7c2d12;">Emails Sent</div><div style="font-size:22px;font-weight:900;color:#16a34a;">{{ performance.emailSentToday }}</div></div>
            <div class="super-card"><div style="font-size:12px;color:#7c2d12;">Chat Messages</div><div style="font-size:22px;font-weight:900;color:#c2410c;">{{ performance.chatMessagesToday }}</div></div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-sitemap" style="margin-right:6px;color:#f97316;"></i>Usage by Campus</span></div>
        {% for s in schools %}
        <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;font-size:13px;color:#475569;"><span>{{ s.name }}</span><span>{{ s.utilization }}%</span></div>
            <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:{{ s.utilization }}%;background:#f97316;"></div></div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
