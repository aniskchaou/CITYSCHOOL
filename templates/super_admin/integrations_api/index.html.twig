{% extends 'super_admin/base.html.twig' %}
{% block title %}Integrations & API{% endblock %}
{% block page_title %}Integrations & API Management{% endblock %}

{% block content %}
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px;">
    <div class="super-kpi"><div class="kpi-value">{{ integration_catalog|length }}</div><div class="kpi-label">Available Integrations</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ api_keys|filter(k => k.status == 'active')|length }}</div><div class="kpi-label">Active API Keys</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ webhooks|filter(w => w.status == 'active')|length }}</div><div class="kpi-label">Active Webhooks</div></div>
    <div class="super-kpi"><div class="kpi-value">{{ schools|length }}</div><div class="kpi-label">Schools with Controls</div></div>
</div>

<div class="card" style="margin-bottom:18px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-plug" style="margin-right:6px;color:#f97316;"></i>Third-Party Integrations</span></div>
    <table class="portal-table">
        <thead><tr><th>Integration</th><th>Category</th><th>Status</th><th>Marketplace</th><th>Per-School Toggle</th></tr></thead>
        <tbody>
        {% for i in integration_catalog %}
        <tr>
            <td><strong>{{ i.name }}</strong></td>
            <td>{{ i.category }}</td>
            <td><span class="super-tag {{ i.status == 'enabled' ? 'active' : 'trial' }}">{{ i.status }}</span></td>
            <td><span class="super-tag {{ i.marketplace ? 'active' : 'trial' }}">{{ i.marketplace ? 'listed' : 'private' }}</span></td>
            <td>
                <form method="post" action="{{ path('super_admin_integrations_api') }}" style="display:flex;gap:6px;flex-wrap:wrap;">
                    <input type="hidden" name="integration" value="{{ i.name }}">
                    <select class="form-control" name="school_id" style="min-width:170px;">
                        {% for s in schools %}<option value="{{ s.id }}">{{ s.name }}</option>{% endfor %}
                    </select>
                    <button class="btn-orange" type="submit" name="action" value="toggle_integration"><i class="fa fa-toggle-on"></i> Toggle</button>
                </form>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<div class="grid-2" style="gap:20px;">
    <div class="card">
        <div class="card-header" style="justify-content:space-between;">
            <span class="card-title"><i class="fa fa-key" style="margin-right:6px;color:#f97316;"></i>API Keys</span>
            <form method="post" action="{{ path('super_admin_integrations_api') }}">
                <button class="btn-orange" type="submit" name="action" value="generate_key"><i class="fa fa-plus"></i> Generate Key</button>
            </form>
        </div>
        <table class="portal-table">
            <thead><tr><th>Name</th><th>Scope</th><th>Created</th><th>Last Used</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
            {% for k in api_keys %}
            <tr>
                <td><strong>{{ k.name }}</strong><div style="font-size:11px;color:#94a3b8;">{{ k.key }}</div></td>
                <td>{{ k.scope }}</td>
                <td>{{ k.createdAt }}</td>
                <td>{{ k.lastUsed }}</td>
                <td><span class="super-tag {{ k.status == 'active' ? 'active' : 'suspended' }}">{{ k.status }}</span></td>
                <td>
                    <form method="post" action="{{ path('super_admin_integrations_api') }}">
                        <input type="hidden" name="key_name" value="{{ k.name }}">
                        <button class="btn-orange" style="font-size:11px;padding:5px 10px;background:#b91c1c;" type="submit" name="action" value="revoke_key"><i class="fa fa-ban"></i> Revoke</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="card">
        <div class="card-header" style="justify-content:space-between;">
            <span class="card-title"><i class="fa fa-exchange" style="margin-right:6px;color:#f97316;"></i>Webhooks</span>
            <form method="post" action="{{ path('super_admin_integrations_api') }}">
                <button class="btn-orange" type="submit" name="action" value="save_webhook"><i class="fa fa-save"></i> Save Webhook</button>
            </form>
        </div>
        <table class="portal-table" style="margin-bottom:10px;">
            <thead><tr><th>Event</th><th>URL</th><th>Status</th><th>Last Delivery</th></tr></thead>
            <tbody>
            {% for w in webhooks %}
            <tr>
                <td>{{ w.name }}</td>
                <td style="font-size:12px;">{{ w.url }}</td>
                <td><span class="super-tag {{ w.status == 'active' ? 'active' : 'trial' }}">{{ w.status }}</span></td>
                <td>{{ w.lastDelivery }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        <div style="display:flex;gap:8px;">
            <button class="btn-orange" onclick="return false;"><i class="fa fa-play"></i> Test Delivery</button>
            <button class="btn-orange" onclick="return false;"><i class="fa fa-history"></i> Retry Failed</button>
        </div>
    </div>
</div>

<div class="card" style="margin-top:18px;">
    <div class="card-header"><span class="card-title"><i class="fa fa-code" style="margin-right:6px;color:#f97316;"></i>Premium: Developer Portal & Integration Marketplace</span></div>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:14px;">
        <div class="super-card">
            <div style="font-size:14px;font-weight:800;color:#9a3412;margin-bottom:6px;">Developer Portal for Schools</div>
            <div style="font-size:13px;color:#7c2d12;line-height:1.6;">Per-school API docs, sandbox keys, and webhook logs with self-service key rotation.</div>
            <div style="margin-top:8px;"><span class="metric-chip">Sandbox Enabled</span> <span class="metric-chip">Docs v1.4</span></div>
        </div>
        <div class="super-card">
            <div style="font-size:14px;font-weight:800;color:#9a3412;margin-bottom:6px;">Integration Marketplace</div>
            <div style="font-size:13px;color:#7c2d12;line-height:1.6;">Plugin-style integration listing for schools to discover, enable, and configure modules.</div>
            <form method="post" action="{{ path('super_admin_integrations_api') }}" style="margin-top:8px;">
                <button class="btn-orange" type="submit" name="action" value="publish_marketplace"><i class="fa fa-shopping-bag"></i> Publish Integration</button>
            </form>
        </div>
    </div>
</div>

<div class="card" style="margin-top:18px;">
    <div class="card-header" style="justify-content:space-between;">
        <span class="card-title"><i class="fa fa-line-chart" style="margin-right:6px;color:#f97316;"></i>API Usage Monitoring</span>
        <form method="post" action="{{ path('super_admin_integrations_api') }}">
            <button class="btn-orange" type="submit" name="action" value="monitor_usage"><i class="fa fa-refresh"></i> Refresh Metrics</button>
        </form>
    </div>
    <table class="portal-table">
        <thead><tr><th>Endpoint</th><th>Calls (24h)</th><th>Error Rate</th><th>P95 Latency</th></tr></thead>
        <tbody>
        {% for u in api_usage %}
        <tr>
            <td>{{ u.endpoint }}</td>
            <td>{{ u.calls24h|number_format }}</td>
            <td>{{ u.errorRate }}%</td>
            <td>{{ u.p95Ms }} ms</td>
        </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
