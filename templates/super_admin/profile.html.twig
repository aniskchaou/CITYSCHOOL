{% extends 'super_admin/base.html.twig' %}
{% block title %}My Profile{% endblock %}
{% block page_title %}Super Admin Profile{% endblock %}

{% block content %}
<div class="grid-2" style="gap:20px;">
    <div class="card" style="text-align:center;">
        <div class="av-init" style="width:84px;height:84px;font-size:30px;background:#ffedd5;color:#c2410c;margin:0 auto 14px;">{{ super_admin.avatar }}</div>
        <div style="font-size:20px;font-weight:800;">{{ super_admin.name }}</div>
        <div style="font-size:13px;color:#c2410c;font-weight:700;">{{ super_admin.role }}</div>
        <div style="font-size:12px;color:#64748b;margin:10px 0 14px;">Joined {{ super_admin.joined }} · Last login {{ super_admin.lastLogin }}</div>
        <div style="padding:12px;background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;text-align:left;font-size:13px;color:#475569;line-height:1.8;">
            <div><i class="fa fa-user" style="width:18px;color:#c2410c;"></i>{{ super_admin.username }}</div>
            <div><i class="fa fa-envelope" style="width:18px;color:#c2410c;"></i>{{ super_admin.email }}</div>
            <div><i class="fa fa-phone" style="width:18px;color:#c2410c;"></i>{{ super_admin.phone }}</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><span class="card-title"><i class="fa fa-edit" style="margin-right:6px;color:#f97316;"></i>Edit Account</span></div>
        <form method="post" action="{{ path('super_admin_profile') }}">
            <div class="grid-2" style="gap:14px;">
                <div class="form-group"><label class="form-label">First Name</label><input class="form-control" name="first_name" value="System"></div>
                <div class="form-group"><label class="form-label">Last Name</label><input class="form-control" name="last_name" value="Owner"></div>
            </div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-control" name="email" value="{{ super_admin.email }}"></div>
            <div class="form-group"><label class="form-label">Phone</label><input class="form-control" name="phone" value="{{ super_admin.phone }}"></div>
            <div style="padding-top:12px;border-top:1px solid #fed7aa;margin-top:8px;">
                <div style="font-size:14px;font-weight:800;color:#dc2626;margin-bottom:10px;"><i class="fa fa-lock"></i> Change Password</div>
                <div class="form-group"><label class="form-label">Current Password</label><input type="password" class="form-control" name="current_password"></div>
                <div class="grid-2" style="gap:14px;">
                    <div class="form-group"><label class="form-label">New Password</label><input type="password" class="form-control" name="new_password"></div>
                    <div class="form-group"><label class="form-label">Confirm Password</label><input type="password" class="form-control" name="confirm_password"></div>
                </div>
            </div>
            <button class="btn-orange" type="submit"><i class="fa fa-save"></i> Save Profile</button>
        </form>
    </div>
</div>
{% endblock %}
